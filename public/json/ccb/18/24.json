          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 14,
          "hasVerseLabel": true,
          "verseText": "凶手黎明起来， 杀害贫苦的人， 夜晚又去做贼。 "
        }
      ]
    },
