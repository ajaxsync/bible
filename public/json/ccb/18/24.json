          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "他们整夜赤身露体， 没有被子可以御寒。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
