          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 16,
          "hasVerseLabel": true,
          "verseText": "盗贼夜间挖墙行窃， 日间躲藏起来， 不想认识光明。 "
        }
      ]
