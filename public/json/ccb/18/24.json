          "verseNum": 18,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 19,
          "hasVerseLabel": true,
          "verseText": "阴间吞噬犯罪之人， 如同干热吞噬融雪。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 19,
          "hasVerseLabel": false,
          "verseText": "阴间吞噬犯罪之人， 如同干热吞噬融雪。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
