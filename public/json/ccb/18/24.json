          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 12,
          "hasVerseLabel": true,
          "verseText": "城中传来垂死之人的呻吟， 受伤者不断呼救， 上帝却置之不理。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
