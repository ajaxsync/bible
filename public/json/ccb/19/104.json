          "verseNum": 16,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 17,
          "hasVerseLabel": true,
          "verseText": "鸟儿在树上筑巢， 鹳鸟在松树上栖息。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 17,
          "hasVerseLabel": false,
          "verseText": "鸟儿在树上筑巢， 鹳鸟在松树上栖息。"
        }
      ]
    },
    {
      "type": "line-quote",
