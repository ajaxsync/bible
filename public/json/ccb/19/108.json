          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "上帝啊！我的心坚定不移， 我要用心灵歌颂你。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "上帝啊！我的心坚定不移， 我要用心灵歌颂你。 "
