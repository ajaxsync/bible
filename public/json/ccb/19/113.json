        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "愿耶和华的名受称颂， 从现在直到永远！ "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": "愿耶和华的名受称颂， 从现在直到永远！"
