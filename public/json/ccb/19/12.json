        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "耶和华啊，你必保护我们， 永远不容恶人侵害我们。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "耶和华啊，你必保护我们， 永远不容恶人侵害我们。"
