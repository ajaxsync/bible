          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "儿女是耶和华所赐的礼物， 孩子是祂所给的赏赐。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": "儿女是耶和华所赐的礼物， 孩子是祂所给的赏赐。"
