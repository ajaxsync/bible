          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "愿他们作茧自缚， 而我可以安然逃脱。 "
        }
      ]
    },
    {
