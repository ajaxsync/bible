          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "我想起遥远的过去， 我思想你的一切作为， 回想你所做的事。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": "我想起遥远的过去， 我思想你的一切作为， 回想你所做的事。"
        }
      ]
    },
