          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "耶和华保护寄居异地的人， 看顾孤儿寡妇， 祂挫败恶人的阴谋诡计。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "耶和华保护寄居异地的人， 看顾孤儿寡妇， 祂挫败恶人的阴谋诡计。"
        }
      ]
    },
