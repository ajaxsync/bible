          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "耶和华坐在洪涛之上， 耶和华永远坐着为王。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "耶和华坐在洪涛之上， 耶和华永远坐着为王。"
        }
      ]
    },
    {
