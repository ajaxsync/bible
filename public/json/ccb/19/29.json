          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 11,
          "hasVerseLabel": true,
          "verseText": "耶和华赐力量给自己的子民， 赐给他们平安的福乐。 "
        }
      ]
    },
