          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "不要因生气而犯罪； 躺在床上的时候要默然思想。（细拉） "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
