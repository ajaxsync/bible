          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "上帝啊，我心坚定，我心坚定， 我要唱诗赞美你。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "上帝啊，我心坚定，我心坚定， 我要唱诗赞美你。"
