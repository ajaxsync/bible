          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "我的心啊，要振奋起来！ 琴瑟啊，弹奏吧！ 我要唤醒黎明！ "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": "我的心啊，要振奋起来！ 琴瑟啊，弹奏吧！ 我要唤醒黎明！"
