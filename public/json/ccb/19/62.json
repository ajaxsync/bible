          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "唯有祂才是我的磐石， 我的拯救，我的堡垒， 我必不致动摇。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": "唯有祂才是我的磐石， 我的拯救，我的堡垒， 我必不致动摇。"
        }
      ]
    },
    {
      "type": "line-quote",
