          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "我一生都要赞美你， 奉你的名举手祷告。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
