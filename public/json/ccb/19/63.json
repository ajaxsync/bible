          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "你的慈爱比生命更宝贵， 我的嘴唇要赞美你。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": "你的慈爱比生命更宝贵， 我的嘴唇要赞美你。"
