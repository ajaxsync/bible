          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "愿义人在上帝面前欢欣快乐， 愿他们高兴欢喜。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": "愿义人在上帝面前欢欣快乐， 愿他们高兴欢喜。"
        }
      ]
    },
    {
