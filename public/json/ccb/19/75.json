        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "我要永远宣扬祂的作为， 我要颂赞雅各的上帝。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "我要永远宣扬祂的作为， 我要颂赞雅各的上帝。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
