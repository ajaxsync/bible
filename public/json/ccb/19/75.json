          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "上帝必铲除恶人的势力， 使义人充满力量。 "
        }
      ]
    },
    {
