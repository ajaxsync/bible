        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "我观看你指头创造的穹苍和你摆列的月亮星辰， "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": "我观看你指头创造的穹苍和你摆列的月亮星辰，"
        }
      ]
