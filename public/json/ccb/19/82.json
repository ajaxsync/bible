          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "上帝啊，求你起来审判世界， 因为世上的万国都属于你。 "
        }
      ]
    },
    {
