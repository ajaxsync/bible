          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "不敬虔的张口败坏邻舍， 义人却因知识获得拯救。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "不敬虔的张口败坏邻舍， 义人却因知识获得拯救。"
        }
      ]
    },
    {
      "type": "line-quote",
