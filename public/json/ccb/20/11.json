        },
        {
          "verseNum": 18,
          "hasVerseLabel": true,
          "verseText": "恶人赚来的转眼成空， 播种公义的必获奖赏。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 18,
          "hasVerseLabel": false,
          "verseText": "恶人赚来的转眼成空， 播种公义的必获奖赏。"
