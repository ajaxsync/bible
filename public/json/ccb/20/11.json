          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "义人亨通，全城快乐； 恶人灭亡，人人欢呼。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "义人亨通，全城快乐； 恶人灭亡，人人欢呼。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
