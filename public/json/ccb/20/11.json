          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 14,
          "hasVerseLabel": true,
          "verseText": "缺乏智谋，国必败亡； 谋士众多，战无不胜。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": "缺乏智谋，国必败亡； 谋士众多，战无不胜。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
