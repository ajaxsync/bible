          "verseNum": 18,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 19,
          "hasVerseLabel": true,
          "verseText": "坚持行义，必得生命； 追逐罪恶，终必灭亡。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 19,
          "hasVerseLabel": false,
          "verseText": "坚持行义，必得生命； 追逐罪恶，终必灭亡。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 19,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 20,
          "hasVerseLabel": true,
          "verseText": "心术不正的人令耶和华憎恶， 纯全无过的人蒙耶和华喜爱。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 20,
          "hasVerseLabel": false,
          "verseText": "心术不正的人令耶和华憎恶， 纯全无过的人蒙耶和华喜爱。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
