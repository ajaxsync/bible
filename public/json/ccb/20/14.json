          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 14,
          "hasVerseLabel": true,
          "verseText": "背弃正道，自食恶果； 善人行善，必得善报。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": "背弃正道，自食恶果； 善人行善，必得善报。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
