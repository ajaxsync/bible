          "verseNum": 31,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 32,
          "hasVerseLabel": true,
          "verseText": "恶人因恶行而灭亡， 义人到死仍有倚靠。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 32,
          "hasVerseLabel": false,
          "verseText": "恶人因恶行而灭亡， 义人到死仍有倚靠。"
