          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 17,
          "hasVerseLabel": true,
          "verseText": "急躁易怒的人做事愚昧， 阴险奸诈之人遭人痛恨。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 17,
          "hasVerseLabel": false,
          "verseText": "急躁易怒的人做事愚昧， 阴险奸诈之人遭人痛恨。"
        }
      ]
    },
