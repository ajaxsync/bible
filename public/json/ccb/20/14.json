        },
        {
          "verseNum": 33,
          "hasVerseLabel": true,
          "verseText": "智慧存在哲士心里， 愚人心中充满无知。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 33,
          "hasVerseLabel": false,
          "verseText": "智慧存在哲士心里， 愚人心中充满无知。"
