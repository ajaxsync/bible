          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "行为正直的人敬畏耶和华， 行事邪僻的人轻视耶和华。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": "行为正直的人敬畏耶和华， 行事邪僻的人轻视耶和华。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
