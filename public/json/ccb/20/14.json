          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 31,
          "hasVerseLabel": true,
          "verseText": "欺压穷人等于侮辱造物主， 怜悯贫弱就是尊敬造物主。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 31,
          "hasVerseLabel": false,
          "verseText": "欺压穷人等于侮辱造物主， 怜悯贫弱就是尊敬造物主。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
