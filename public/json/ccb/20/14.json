          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 15,
          "hasVerseLabel": true,
          "verseText": "愚昧人什么都信， 明哲人步步谨慎。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": "愚昧人什么都信， 明哲人步步谨慎。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 16,
          "hasVerseLabel": true,
          "verseText": "智者小心谨慎，远离恶事； 愚人骄傲自负，行事鲁莽。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 16,
          "hasVerseLabel": false,
          "verseText": "智者小心谨慎，远离恶事； 愚人骄傲自负，行事鲁莽。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
