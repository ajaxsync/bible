          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 30,
          "hasVerseLabel": true,
          "verseText": "心平气和，滋润生命； 妒火中烧，啃蚀骨头。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 30,
          "hasVerseLabel": false,
          "verseText": "心平气和，滋润生命； 妒火中烧，啃蚀骨头。"
        }
      ]
    },
