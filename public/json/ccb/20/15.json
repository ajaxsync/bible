          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "耶和华憎恨恶人的行径， 喜爱追求公义的人。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "耶和华憎恨恶人的行径， 喜爱追求公义的人。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
