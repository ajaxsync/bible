          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "智者的舌头传扬知识， 愚人的嘴巴吐露愚昧。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": "智者的舌头传扬知识， 愚人的嘴巴吐露愚昧。"
        }
      ]
