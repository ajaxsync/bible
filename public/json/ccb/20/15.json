        },
        {
          "verseNum": 23,
          "hasVerseLabel": true,
          "verseText": "应对得体，心中愉快； 言语合宜，何等美好！ "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 23,
          "hasVerseLabel": false,
          "verseText": "应对得体，心中愉快； 言语合宜，何等美好！"
