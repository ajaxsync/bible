          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "耶和华憎恨恶人的祭物， 悦纳正直人的祈祷。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": "耶和华憎恨恶人的祭物， 悦纳正直人的祈祷。"
