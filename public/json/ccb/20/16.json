        },
        {
          "verseNum": 15,
          "hasVerseLabel": true,
          "verseText": "王的笑容带给人生命， 他的恩惠像春雨之云。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": "王的笑容带给人生命， 他的恩惠像春雨之云。"
