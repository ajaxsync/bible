          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 19,
          "hasVerseLabel": true,
          "verseText": "宁可谦卑地与贫寒人相处， 也不跟狂傲人共享战利品。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 19,
          "hasVerseLabel": false,
          "verseText": "宁可谦卑地与贫寒人相处， 也不跟狂傲人共享战利品。"
