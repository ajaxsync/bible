          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 20,
          "hasVerseLabel": true,
          "verseText": "听从训言的人受益匪浅， 信靠耶和华的人蒙祝福。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 20,
          "hasVerseLabel": false,
          "verseText": "听从训言的人受益匪浅， 信靠耶和华的人蒙祝福。"
