          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 16,
          "hasVerseLabel": true,
          "verseText": "得智慧胜过得黄金， 获悟性胜过获白银。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
