          "verseNum": 28,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 29,
          "hasVerseLabel": true,
          "verseText": "刑罚对付嘲讽者， 鞭子责打愚人背。 "
        }
      ]
    },
    {
