        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "得到智慧的珍惜生命， 持守悟性的享受福乐。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": "得到智慧的珍惜生命， 持守悟性的享受福乐。"
