        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "作伪证者难免受罚， 撒谎的人自取灭亡。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "作伪证者难免受罚， 撒谎的人自取灭亡。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
