          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 14,
          "hasVerseLabel": true,
          "verseText": "买主总说货物不好， 买走后又连连自夸。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
