          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 13,
          "hasVerseLabel": true,
          "verseText": "不要贪睡，免得贫穷； 勤劳工作，粮食丰足。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": "不要贪睡，免得贫穷； 勤劳工作，粮食丰足。"
