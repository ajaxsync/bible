          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "缺斤少两、尺寸不足， 都为耶和华所憎恶。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
