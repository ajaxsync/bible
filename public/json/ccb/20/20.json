          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 23,
          "hasVerseLabel": true,
          "verseText": "耶和华憎恶缺斤少两， 祂厌恶骗人的天平。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 23,
          "hasVerseLabel": false,
          "verseText": "耶和华憎恶缺斤少两， 祂厌恶骗人的天平。"
