        },
        {
          "verseNum": 12,
          "hasVerseLabel": true,
          "verseText": "能听的耳，能看的眼， 两者都为耶和华所造。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": "能听的耳，能看的眼， 两者都为耶和华所造。"
