          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 22,
          "hasVerseLabel": true,
          "verseText": "不要说：“我要以恶报恶”， 要等候耶和华替你申冤。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 22,
          "hasVerseLabel": false,
          "verseText": "不要说：“我要以恶报恶”， 要等候耶和华替你申冤。"
