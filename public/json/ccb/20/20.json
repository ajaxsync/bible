      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "酒使人放肆，烈酒叫人吵闹。 因酒误事，实为不智。 "
        }
      ]
    },
    {
