        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "谁敢说：“我心灵洁净，纯洁无罪？” "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "谁敢说：“我心灵洁净，纯洁无罪？”"
