          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 14,
          "hasVerseLabel": true,
          "verseText": "暗中送的礼物能平息愤怒， 塞进怀里的贿赂止息盛怒。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": "暗中送的礼物能平息愤怒， 塞进怀里的贿赂止息盛怒。"
        }
      ]
    },
