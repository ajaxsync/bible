          "verseNum": 20,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 21,
          "hasVerseLabel": true,
          "verseText": "追求公义与慈爱的， 必寻得生命、公义和尊荣。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 21,
          "hasVerseLabel": false,
          "verseText": "追求公义与慈爱的， 必寻得生命、公义和尊荣。"
        }
      ]
    },
