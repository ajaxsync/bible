          "verseText": " "
        },
        {
          "verseNum": 24,
          "hasVerseLabel": true,
          "verseText": "嘲讽者狂妄自大， 行事骄横无比。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 24,
          "hasVerseLabel": false,
          "verseText": "嘲讽者狂妄自大， 行事骄横无比。"
