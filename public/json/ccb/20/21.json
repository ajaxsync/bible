          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 22,
          "hasVerseLabel": true,
          "verseText": "智者攀上勇士的城池， 摧毁他们倚仗的坚垒。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 22,
          "hasVerseLabel": false,
          "verseText": "智者攀上勇士的城池， 摧毁他们倚仗的坚垒。"
