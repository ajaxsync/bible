          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 20,
          "hasVerseLabel": true,
          "verseText": "智者家中积存宝物和油， 愚人将所有的挥霍一空。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 20,
          "hasVerseLabel": false,
          "verseText": "智者家中积存宝物和油， 愚人将所有的挥霍一空。"
        }
      ]
    },
