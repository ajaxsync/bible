      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "美名胜过巨富， 恩宠比金银宝贵。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "美名胜过巨富， 恩宠比金银宝贵。"
