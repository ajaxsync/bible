          "verseNum": 25,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 26,
          "hasVerseLabel": true,
          "verseText": "小羊的皮毛可做衣服， 卖山羊的钱可买田地， "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 26,
          "hasVerseLabel": false,
          "verseText": "小羊的皮毛可做衣服， 卖山羊的钱可买田地，"
        }
      ]
    },
