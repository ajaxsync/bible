          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "我比众人都愚蠢， 不具备人的悟性。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
