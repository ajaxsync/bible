          "verseNum": 30,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 31,
          "hasVerseLabel": true,
          "verseText": "愿她享受自己的劳动成果， 愿她的事迹使她在城门口受称赞。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
