      "type": "paragraph",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "这是所罗门的歌，是歌中最美妙的歌。 "
        }
      ]
    },
    {
      "type": "heading",
      "heading": "第一首"
    },
    {
      "type": "heading-ps",
      "contents": []
    },
    {
