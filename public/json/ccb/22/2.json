          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "请用葡萄干来补充我的力气， 用苹果来提振我的精神， 因为我思爱成病。 "
        }
      ]
    },
