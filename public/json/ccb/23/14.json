        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "如今天下太平， 人人欢呼歌唱， "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "如今天下太平， 人人欢呼歌唱，"
