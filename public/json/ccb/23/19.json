        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "纺纱织布的人一筹莫展， 感到绝望。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "纺纱织布的人一筹莫展， 感到绝望。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "埃及的显贵都没落， 靠工钱维生的人都忧心忡忡。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "埃及的显贵都没落， 靠工钱维生的人都忧心忡忡。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
