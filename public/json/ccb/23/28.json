          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "祂必使审判官公正断案， 赐力量给守城退敌之人。 "
        }
      ]
    },
