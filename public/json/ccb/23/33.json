        },
        {
          "verseNum": 17,
          "hasVerseLabel": true,
          "verseText": "你们必目睹君王的荣美， 看到辽阔的土地， "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 17,
          "hasVerseLabel": false,
          "verseText": "你们必目睹君王的荣美， 看到辽阔的土地，"
        }
