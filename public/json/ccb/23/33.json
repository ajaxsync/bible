    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 17,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 18,
          "hasVerseLabel": true,
          "verseText": "你们必想起以往可怕的情景， 说：“登记人口的在哪里？ 收贡银的在哪里？ 数城楼的在哪里？” "
        }
      ]
