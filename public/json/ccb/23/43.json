          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 27,
          "hasVerseLabel": true,
          "verseText": "你的始祖犯了罪， 你的首领也背叛了我。 "
        }
      ]
    },
    {
