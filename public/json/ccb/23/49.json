    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": "祂对我说：“以色列啊， 你是我的仆人， 我要借着你彰显我的荣耀。”"
        }
