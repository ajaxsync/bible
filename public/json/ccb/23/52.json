          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 14,
          "hasVerseLabel": true,
          "verseText": "许多人看见祂就诧异， 祂的面容被毁、身体被残害得不成人样。 "
        }
      ]
    },
