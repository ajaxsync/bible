        {
          "verseNum": 12,
          "hasVerseLabel": true,
          "verseText": "用红宝石建你的城楼、 水晶造你的城门、 宝石建你的城墙。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": "用红宝石建你的城楼、 水晶造你的城门、 宝石建你的城墙。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
