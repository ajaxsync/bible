        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "我使他统管万民， 向万民做见证。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": "我使他统管万民， 向万民做见证。"
        }
