      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": "谨守而不亵渎安息日、 不做恶事的人有福了！”"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": "谨守而不亵渎安息日、 不做恶事的人有福了！”"
