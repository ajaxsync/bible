          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "你们将在撒玛利亚的山上重新栽种葡萄园， 享受园中的果实。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": "你们将在撒玛利亚的山上重新栽种葡萄园， 享受园中的果实。"
