      "type": "line-quote",
      "contents": [
        {
          "verseNum": 21,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 22,
          "hasVerseLabel": true,
          "verseText": "耶和华说：“我的子民愚顽， 不认识我， 是蒙昧无知的儿女， 只知行恶，不知行善。” "
        }
