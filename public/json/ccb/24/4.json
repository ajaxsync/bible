        },
        {
          "verseNum": 21,
          "hasVerseLabel": true,
          "verseText": "我还要看这旌旗、 听这号声到何时呢？ "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 21,
          "hasVerseLabel": false,
          "verseText": "我还要看这旌旗、 听这号声到何时呢？"
