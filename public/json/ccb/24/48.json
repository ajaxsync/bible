      "type": "line-quote",
      "contents": [
        {
          "verseNum": 41,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 42,
          "hasVerseLabel": true,
          "verseText": "摩押必被摧毁，彻底灭亡， 因为她藐视耶和华。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 42,
          "hasVerseLabel": false,
          "verseText": "摩押必被摧毁，彻底灭亡， 因为她藐视耶和华。"
