      "type": "line-quote",
      "contents": [
        {
          "verseNum": 28,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 29,
          "hasVerseLabel": true,
          "verseText": "我们听说摩押人傲气冲天， 他们狂妄自大、心中高傲。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 29,
          "hasVerseLabel": false,
