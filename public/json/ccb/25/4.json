  "sections": [
    {
      "type": "heading",
      "heading": "耶路撒冷陷落之後"
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "黄金竟失去光泽， 纯金竟变色， 宝石竟被弃之街头。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "黄金竟失去光泽， 纯金竟变色， 宝石竟被弃之街头。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "黄金竟失去光泽， 纯金竟变色， 宝石竟被弃之街头。"
