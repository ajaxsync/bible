        {
          "verseNum": 12,
          "hasVerseLabel": true,
          "verseText": "“以法莲的过犯已被记录在册， 他的罪恶已被储存入库。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": "“以法莲的过犯已被记录在册， 他的罪恶已被储存入库。"
