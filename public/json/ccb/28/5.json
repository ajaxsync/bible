          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 12,
          "hasVerseLabel": true,
          "verseText": "我要使以法莲像虫蛀的衣服， 使犹大家像朽烂的木头。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": "我要使以法莲像虫蛀的衣服， 使犹大家像朽烂的木头。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
