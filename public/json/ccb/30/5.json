        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "你们憎恨在城门口主持公道的人， 厌恶正直的人。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "你们憎恨在城门口主持公道的人， 厌恶正直的人。"
