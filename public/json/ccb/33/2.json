        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "因此，他们在耶和华的会众中将无人抽签分地。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": "因此，他们在耶和华的会众中将无人抽签分地。"
