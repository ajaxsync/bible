    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 15,
          "hasVerseLabel": true,
          "verseText": "耶和华说： “我要向他们显出神迹奇事， 就像他们离开埃及时一样。” "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
