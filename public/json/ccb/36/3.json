    {
      "type": "heading",
      "heading": "歡樂之歌"
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 14,
          "hasVerseLabel": true,
          "verseText": "锡安城啊，歌唱吧！ 以色列啊，欢呼吧！ 耶路撒冷城啊，尽情地欢喜快乐吧！ "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": "锡安城啊，歌唱吧！ 以色列啊，欢呼吧！ 耶路撒冷城啊，尽情地欢喜快乐吧！"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": "锡安城啊，歌唱吧！ 以色列啊，欢呼吧！ 耶路撒冷城啊，尽情地欢喜快乐吧！"
        }
