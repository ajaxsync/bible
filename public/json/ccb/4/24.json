          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 18,
          "hasVerseLabel": true,
          "verseText": "他必征服以东， 占领敌疆西珥， 以色列必勇往直前。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 18,
          "hasVerseLabel": false,
          "verseText": "他必征服以东， 占领敌疆西珥， 以色列必勇往直前。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 18,
          "hasVerseLabel": false,
          "verseText": "他必征服以东， 占领敌疆西珥， 以色列必勇往直前。"
        }
      ]
    },
