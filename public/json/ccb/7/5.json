        {
          "verseNum": 20,
          "hasVerseLabel": true,
          "verseText": "星辰从天上、从它们的轨道攻击西西拉。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 20,
          "hasVerseLabel": false,
          "verseText": "星辰从天上、从它们的轨道攻击西西拉。"
        }
      ]
