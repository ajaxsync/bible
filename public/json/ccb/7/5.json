          "verseNum": 20,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 21,
          "hasVerseLabel": true,
          "verseText": "古老的基顺河冲走了敌人。 我的心啊，要奋勇向前！ "
        }
      ]
