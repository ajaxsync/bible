          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 20,
          "hasVerseLabel": true,
          "verseText": "至於亞設，他的食物必定肥美， 他有美食可以供奉君王。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 20,
          "hasVerseLabel": false,
          "verseText": "至於亞設，他的食物必定肥美， 他有美食可以供奉君王。"
        }
      ]
