          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 14,
          "hasVerseLabel": true,
          "verseText": "殺人的黎明起來， 殺戮困苦人與窮人， 夜間又去作盜賊。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": "殺人的黎明起來， 殺戮困苦人與窮人， 夜間又去作盜賊。"
        }
      ]
    },
    {
