          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "有人從母親的懷中搶走孤兒， 又強取窮人的衣物作抵押， "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "有人從母親的懷中搶走孤兒， 又強取窮人的衣物作抵押，"
        }
