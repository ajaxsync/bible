          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "惡人卻不是這樣， 他們好像糠秕， 被風吹散。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": "惡人卻不是這樣， 他們好像糠秕， 被風吹散。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
