          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "我每日早晨必滅絕國中所有的惡人， 好把所有作孽的人都從耶和華的城裡剪除。 "
        }
      ]
    },
