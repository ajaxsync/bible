          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 32,
          "hasVerseLabel": true,
          "verseText": "他注視大地，地就震動； 他觸摸群山，山就冒煙。 "
        }
      ]
    },
    {
