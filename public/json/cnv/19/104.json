        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "你用風作你的使者， 用火燄作你的僕役。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
