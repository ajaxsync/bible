      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 12,
          "hasVerseLabel": true,
          "verseText": "所以　神用苦難治服他們的心； 他們跌倒，也沒有人幫助。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
