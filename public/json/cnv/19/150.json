          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "要用聲音洪亮的鈸讚美他， 要用聲音鏗鏘的鈸讚美他。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
