          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "要擊鼓跳舞讚美他， 要彈奏絲弦的樂器和吹簫讚美他。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": "要擊鼓跳舞讚美他， 要彈奏絲弦的樂器和吹簫讚美他。"
