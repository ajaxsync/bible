        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "要因他大能的作為讚美他， 要因他無限的偉大讚美他。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": "要因他大能的作為讚美他， 要因他無限的偉大讚美他。"
