          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "他們都屈身跌倒， 我們卻起來，挺身而立。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
