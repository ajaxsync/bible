      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "願耶和華在你遭難的日子應允你， 願雅各的　神的名保護你。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
