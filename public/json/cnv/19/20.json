          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "有人靠車，有人靠馬。 我們卻靠耶和華我們　神的名。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "有人靠車，有人靠馬。 我們卻靠耶和華我們　神的名。"
        }
