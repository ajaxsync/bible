        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "願他從聖所幫助你， 從錫安扶持你。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": "願他從聖所幫助你， 從錫安扶持你。"
        }
