    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "我就走到　神的祭壇前， 到　神、我極大的喜樂那裡。 　神啊！我的　神啊！ 我要彈琴稱讚你。 "
        }
      ]
    },
    {
