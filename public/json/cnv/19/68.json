          "verseNum": 27,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 28,
          "hasVerseLabel": true,
          "verseText": "　神啊！召喚你的能力吧。 　神啊！堅立你為我們作成的事吧。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
