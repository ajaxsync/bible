          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 29,
          "hasVerseLabel": true,
          "verseText": "因為你在耶路撒冷的聖殿， 眾王都把禮物帶來獻給你。 "
        }
      ]
    },
