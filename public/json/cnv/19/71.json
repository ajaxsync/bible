        {
          "verseNum": 21,
          "hasVerseLabel": true,
          "verseText": "你必增加我的尊榮， 並轉過來安慰我。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 21,
          "hasVerseLabel": false,
          "verseText": "你必增加我的尊榮， 並轉過來安慰我。"
