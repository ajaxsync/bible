          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "啊！人算甚麼，你竟記念他？ 世人算甚麼，你竟眷顧他？ "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": "啊！人算甚麼，你竟記念他？ 世人算甚麼，你竟眷顧他？"
