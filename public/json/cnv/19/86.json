  "sections": [
    {
      "type": "heading",
      "heading": "求主恩助"
    },
    {
      "type": "desc",
      "contents": []
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "耶和華啊！求你留心聽我、應允我， 因為我是困苦貧窮的。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "耶和華啊！求你留心聽我、應允我， 因為我是困苦貧窮的。"
