      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "耶和華所立的根基在聖山上。 "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "耶和華愛錫安的城門， 勝過雅各的一切居所。 "
