          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 40,
          "hasVerseLabel": true,
          "verseText": "你拆毀了他的一切城牆， 使他的堡壘成廢堆。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 40,
          "hasVerseLabel": false,
