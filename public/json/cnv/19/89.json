          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 42,
          "hasVerseLabel": true,
          "verseText": "你高舉了他敵人的右手， 使他所有的仇敵歡喜。 "
        }
      ]
    },
