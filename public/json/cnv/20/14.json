          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "愚妄人譏笑贖愆祭， 正直人中間卻有恩寵。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "愚妄人譏笑贖愆祭， 正直人中間卻有恩寵。"
