          "verseNum": 25,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 26,
          "hasVerseLabel": true,
          "verseText": "虐待父親，趕走母親的， 是貽羞可恥的兒子。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 26,
          "hasVerseLabel": false,
          "verseText": "虐待父親，趕走母親的， 是貽羞可恥的兒子。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
