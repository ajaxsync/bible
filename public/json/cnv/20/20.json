          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "人心裡的謀略如同深水， 唯有聰明人能汲引出來。 "
        }
      ]
    },
    {
