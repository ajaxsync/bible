          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 13,
          "hasVerseLabel": true,
          "verseText": "不要貪睡，免得你貧窮； 睜開眼睛，你才有飽餐。 "
        }
      ]
    },
