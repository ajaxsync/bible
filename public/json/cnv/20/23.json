    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 18,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 19,
          "hasVerseLabel": true,
          "verseText": "我兒，你要聽，要有智慧， 要引導你的心走在正路上。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 19,
          "hasVerseLabel": false,
          "verseText": "我兒，你要聽，要有智慧， 要引導你的心走在正路上。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
