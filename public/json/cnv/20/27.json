          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 18,
          "hasVerseLabel": true,
          "verseText": "照料無花果樹的，必吃樹上的果子； 事奉主人的，必得尊榮。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 18,
          "hasVerseLabel": false,
          "verseText": "照料無花果樹的，必吃樹上的果子； 事奉主人的，必得尊榮。"
        }
