          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 19,
          "hasVerseLabel": true,
          "verseText": "水怎樣映照人面， 人的心思也怎樣反映其人。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
