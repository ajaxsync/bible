          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 16,
          "hasVerseLabel": true,
          "verseText": "誰要攔阻她，就像攔阻風， 也像右手抓油。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 16,
          "hasVerseLabel": false,
          "verseText": "誰要攔阻她，就像攔阻風， 也像右手抓油。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
