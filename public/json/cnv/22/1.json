        {
          "verseNum": 13,
          "hasVerseLabel": true,
          "verseText": "我以我的良人為一袋沒藥， 掛在我的胸懷之中。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": "我以我的良人為一袋沒藥， 掛在我的胸懷之中。"
