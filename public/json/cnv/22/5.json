        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "我的良人紅光滿面， 是萬人中的表表者。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "我的良人紅光滿面， 是萬人中的表表者。"
