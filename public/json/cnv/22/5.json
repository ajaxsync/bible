          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 12,
          "hasVerseLabel": true,
          "verseText": "他的眼好像溪水旁的鴿子， 在奶中洗淨，塑得合式。 "
        }
      ]
