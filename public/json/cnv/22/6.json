        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "你的兩頰在面紗後面， 如同切開的石榴。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "你的兩頰在面紗後面， 如同切開的石榴。"
