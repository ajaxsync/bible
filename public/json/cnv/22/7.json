        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "你的兩乳像一對小鹿， 像雙生的母羚羊。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": "你的兩乳像一對小鹿， 像雙生的母羚羊。"
