        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "親愛的啊！使人喜悅的啊！ 你多麼美麗，多麼可愛。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": "親愛的啊！使人喜悅的啊！ 你多麼美麗，多麼可愛。"
        }
      ]
