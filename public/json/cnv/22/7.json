          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "你的身量像一棵棕樹； 你的兩乳如樹上纍纍的果子。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "你的身量像一棵棕樹； 你的兩乳如樹上纍纍的果子。"
