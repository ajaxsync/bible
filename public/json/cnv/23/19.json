        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "海中的眾水必乾透， 河床必枯竭乾涸。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": "海中的眾水必乾透， 河床必枯竭乾涸。"
        }
      ]
