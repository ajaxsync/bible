          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "專心倚靠你的，你必保護他一切平安， 因為他倚靠你。 "
        }
      ]
    },
