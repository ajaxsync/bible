    {
      "type": "heading",
      "heading": "耶和華要懲罰以色列"
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "主發出一個信息攻擊雅各家， 信息落在以色列家。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": "主發出一個信息攻擊雅各家， 信息落在以色列家。"
