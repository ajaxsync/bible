      "contents": [
        {
          "verseNum": 49,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 50,
          "hasVerseLabel": true,
          "verseText": "直到耶和華垂顧，從天上關注。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 50,
          "hasVerseLabel": false,
          "verseText": "直到耶和華垂顧，從天上關注。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 50,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 51,
          "hasVerseLabel": true,
          "verseText": "因眼見我城中眾民的遭遇，我的心很痛苦。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 51,
          "hasVerseLabel": false,
          "verseText": "因眼見我城中眾民的遭遇，我的心很痛苦。"
        }
