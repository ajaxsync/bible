          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "你比但以理更有智慧！ 任何祕密的事都不能隱瞞你！ "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": "你比但以理更有智慧！ 任何祕密的事都不能隱瞞你！"
