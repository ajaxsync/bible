          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "基列是作孽之人的城， 他們的腳蹤染滿了血漬。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": "基列是作孽之人的城， 他們的腳蹤染滿了血漬。"
