          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "因为耶和华知道义人的道路， 而恶人的道路却必灭亡。 "
        }
