          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "他在水中为自己的楼阁架栋梁， 以云彩为自己的战车， 乘驾风的翅膀而行。 "
        }
      ]
