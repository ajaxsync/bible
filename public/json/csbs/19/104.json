          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "众水向上漫过群山，向下流入山谷， 归到你为它们指定的地方。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": "众水向上漫过群山，向下流入山谷， 归到你为它们指定的地方。"
        }
