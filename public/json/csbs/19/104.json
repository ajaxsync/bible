      "contents": [
        {
          "verseNum": 25,
          "hasVerseLabel": false,
          "verseText": "其中有巨大的海洋，两面宽阔； 海里游动的活物无法数算，大小生物都有；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 25,
          "hasVerseLabel": false,
          "verseText": "其中有巨大的海洋，两面宽阔； 海里游动的活物无法数算，大小生物都有；"
