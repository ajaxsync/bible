    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "耶和华啊，求你使我们这些被掳之人回归， 好像南地的水回流！ "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": "耶和华啊，求你使我们这些被掳之人回归， 好像南地的水回流！"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
