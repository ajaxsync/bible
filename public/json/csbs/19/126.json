          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "流泪撒种的， 必欢呼收割。 "
        }
      ]
    },
    {
