          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "愿你看到你儿女的儿女， 愿平安临到以色列！ "
        }
      ]
    },
    {
      "type": "line-quote",
