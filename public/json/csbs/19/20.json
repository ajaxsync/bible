          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "耶和华啊，求你拯救！ 在我们呼求的日子里，愿王回应我们。 "
        }
      ]
    },
    {
