          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 16,
          "hasVerseLabel": true,
          "verseText": "求你使你的脸光照你的仆人， 因你的慈爱拯救我。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 16,
          "hasVerseLabel": false,
          "verseText": "求你使你的脸光照你的仆人， 因你的慈爱拯救我。"
