          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "醒来吧，我的灵！ 醒来吧，里拉琴和竖琴， 我要把黎明唤醒！ "
        }
      ]
    },
