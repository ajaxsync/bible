        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "我观看你手指所造的天， 并你所安设的月亮星宿， "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": "我观看你手指所造的天， 并你所安设的月亮星宿，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
