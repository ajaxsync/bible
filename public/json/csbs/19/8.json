          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "啊，人算什么，你竟顾念他！ 世人算什么，你竟眷顾他！ "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": "啊，人算什么，你竟顾念他！ 世人算什么，你竟眷顾他！"
