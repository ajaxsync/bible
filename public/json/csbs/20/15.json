          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 31,
          "hasVerseLabel": true,
          "verseText": "耳朵听从关乎生命的训责， 这样的人必安居在智慧人当中。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
