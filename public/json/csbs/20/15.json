          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 25,
          "hasVerseLabel": true,
          "verseText": "耶和华拔除傲慢者的家， 却要设立寡妇的地界。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 25,
          "hasVerseLabel": false,
          "verseText": "耶和华拔除傲慢者的家， 却要设立寡妇的地界。"
