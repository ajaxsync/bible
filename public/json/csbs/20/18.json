          "verseNum": 23,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 24,
          "hasVerseLabel": true,
          "verseText": "朋友太多的人，会受损害； 但有一知己，比兄弟更亲密。 "
        }
      ]
    },
    {
      "type": "line-quote",
