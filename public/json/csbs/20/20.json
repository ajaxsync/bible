          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "谁能说：“我保持自己的心纯洁， 我是清洁无罪的”？ "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "谁能说：“我保持自己的心纯洁， 我是清洁无罪的”？"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
