          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 14,
          "hasVerseLabel": true,
          "verseText": "清早起来大声祝福邻人， 就被算为对他的诅咒。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
