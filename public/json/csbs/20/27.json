          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 16,
          "hasVerseLabel": true,
          "verseText": "想要拦阻她的，就像拦阻风， 又像用右手去抓膏油。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
