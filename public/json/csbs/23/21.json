        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "当他一看见骈马的战车、 骑驴子的、骑骆驼的， 就要特别留心，多多注意。” "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
