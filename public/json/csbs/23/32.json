        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "高贵人却筹谋高贵的事， 并坚立在高贵的事上。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": "高贵人却筹谋高贵的事， 并坚立在高贵的事上。"
