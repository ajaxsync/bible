        },
        {
          "verseNum": 17,
          "hasVerseLabel": true,
          "verseText": "你的眼睛必仰视荣美中的王， 必看见辽阔之地。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 17,
          "hasVerseLabel": false,
          "verseText": "你的眼睛必仰视荣美中的王， 必看见辽阔之地。"
        }
