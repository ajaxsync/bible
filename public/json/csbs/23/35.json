    {
      "type": "heading",
      "heading": "神聖之路"
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "旷野和干旱之地必欢喜； 荒漠必快乐，如番红花绽放， "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "旷野和干旱之地必欢喜； 荒漠必快乐，如番红花绽放，"
