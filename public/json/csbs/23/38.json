          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 18,
          "hasVerseLabel": true,
          "verseText": "阴间不会称颂你，死亡不会赞美你， 下阴坑的人也不会盼望你的信实； "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 18,
          "hasVerseLabel": false,
          "verseText": "阴间不会称颂你，死亡不会赞美你， 下阴坑的人也不会盼望你的信实；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 18,
          "hasVerseLabel": false,
          "verseText": "阴间不会称颂你，死亡不会赞美你， 下阴坑的人也不会盼望你的信实；"
        }
      ]
    },
    {
      "type": "line-quote",
