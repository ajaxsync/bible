        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "草必枯干，花必凋零， 但我们神的话却永远坚立。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": "草必枯干，花必凋零， 但我们神的话却永远坚立。"
