          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "天怎样高过地， 照样，我的道路高过你们的道路， 我的意念高过你们的意念。 "
        }
