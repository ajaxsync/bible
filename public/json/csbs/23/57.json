        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "进入平安； 行事坦诚的人安息在自己的躺卧处。 "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "进入平安； 行事坦诚的人安息在自己的躺卧处。 "
