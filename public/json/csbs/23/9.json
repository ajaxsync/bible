        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "主针对雅各家发话， 这话就落在以色列家； "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": "主针对雅各家发话， 这话就落在以色列家；"
