{
  "book": 19,
  "chapter": 112,
  "sections": [
    {
      "type": "heading",
      "heading": "义人之福"
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "你们要赞美耶和华！"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "敬畏耶和华，甚喜爱他命令的，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "这人便为有福！"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "他的后裔在世必强盛；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": "正直人的后代必要蒙福。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "他家中有货物，有钱财；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": "他的公义存到永远。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "正直人在黑暗中，有光向他发现；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": "他有恩惠，有怜悯，有公义。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "施恩与人、借贷与人的，这人事情顺利；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": "他被审判的时候要诉明自己的冤。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "他永不动摇；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": "义人被记念，直到永远。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "他必不怕凶恶的信息；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "他心坚定，倚靠耶和华。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "他心确定，总不惧怕，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": "直到他看见敌人遭报。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "他施舍钱财，赒济贫穷；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "他的仁义存到永远。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "他的角必被高举，大有荣耀。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "恶人看见便恼恨，必咬牙而消化；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "恶人的心愿要归灭绝。"
        }
      ]
    }
  ]
}