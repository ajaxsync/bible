{
  "book": 20,
  "chapter": 14,
  "sections": [
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "智慧妇人建立家室；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "愚妄妇人亲手拆毁。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "行动正直的，敬畏耶和华；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": "行事乖僻的，却藐视他。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "愚妄人口中骄傲，如杖责打己身；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": "智慧人的嘴必保守自己。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "家里无牛，槽头干净；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": "土产加多乃凭牛力。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "诚实见证人不说谎话；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": "假见证人吐出谎言。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "亵慢人寻智慧，却寻不着；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": "聪明人易得知识。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "到愚昧人面前，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "不见他嘴中有知识。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "通达人的智慧在乎明白己道；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "愚昧人的愚妄乃是诡诈。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "愚妄人犯罪，以为戏耍；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "正直人互相喜悦。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "心中的苦楚，自己知道；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "心里的喜乐，外人无干。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 11,
          "hasVerseLabel": true,
          "verseText": "奸恶人的房屋必倾倒；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": false,
          "verseText": "正直人的帐棚必兴盛。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 12,
          "hasVerseLabel": true,
          "verseText": "有一条路，人以为正，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": "至终成为死亡之路。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 13,
          "hasVerseLabel": true,
          "verseText": "人在喜笑中，心也忧愁；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": "快乐至极就生愁苦。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 14,
          "hasVerseLabel": true,
          "verseText": "心中背道的，必满得自己的结果；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": "善人必从自己的行为得以知足。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 15,
          "hasVerseLabel": true,
          "verseText": "愚蒙人是话都信；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": "通达人步步谨慎。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 16,
          "hasVerseLabel": true,
          "verseText": "智慧人惧怕，就远离恶事；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 16,
          "hasVerseLabel": false,
          "verseText": "愚妄人却狂傲自恃。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 16,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 17,
          "hasVerseLabel": true,
          "verseText": "轻易发怒的，行事愚妄；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 17,
          "hasVerseLabel": false,
          "verseText": "设立诡计的，被人恨恶。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 17,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 18,
          "hasVerseLabel": true,
          "verseText": "愚蒙人得愚昧为产业；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 18,
          "hasVerseLabel": false,
          "verseText": "通达人得知识为冠冕。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 18,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 19,
          "hasVerseLabel": true,
          "verseText": "坏人俯伏在善人面前；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 19,
          "hasVerseLabel": false,
          "verseText": "恶人俯伏在义人门口。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 19,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 20,
          "hasVerseLabel": true,
          "verseText": "贫穷人连邻舍也恨他；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 20,
          "hasVerseLabel": false,
          "verseText": "富足人朋友最多。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 20,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 21,
          "hasVerseLabel": true,
          "verseText": "藐视邻舍的，这人有罪；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 21,
          "hasVerseLabel": false,
          "verseText": "怜悯贫穷的，这人有福。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 21,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 22,
          "hasVerseLabel": true,
          "verseText": "谋恶的，岂非走入迷途吗？"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 22,
          "hasVerseLabel": false,
          "verseText": "谋善的，必得慈爱和诚实。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 22,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 23,
          "hasVerseLabel": true,
          "verseText": "诸般勤劳都有益处；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 23,
          "hasVerseLabel": false,
          "verseText": "嘴上多言乃致穷乏。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 23,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 24,
          "hasVerseLabel": true,
          "verseText": "智慧人的财为自己的冠冕；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 24,
          "hasVerseLabel": false,
          "verseText": "愚妄人的愚昧终是愚昧。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 24,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 25,
          "hasVerseLabel": true,
          "verseText": "作真见证的，救人性命；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 25,
          "hasVerseLabel": false,
          "verseText": "吐出谎言的，施行诡诈。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 25,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 26,
          "hasVerseLabel": true,
          "verseText": "敬畏耶和华的，大有倚靠；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 26,
          "hasVerseLabel": false,
          "verseText": "他的儿女也有避难所。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 26,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 27,
          "hasVerseLabel": true,
          "verseText": "敬畏耶和华就是生命的泉源，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 27,
          "hasVerseLabel": false,
          "verseText": "可以使人离开死亡的网罗。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 27,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 28,
          "hasVerseLabel": true,
          "verseText": "帝王荣耀在乎民多；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 28,
          "hasVerseLabel": false,
          "verseText": "君王衰败在乎民少。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 28,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 29,
          "hasVerseLabel": true,
          "verseText": "不轻易发怒的，大有聪明；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 29,
          "hasVerseLabel": false,
          "verseText": "性情暴躁的，大显愚妄。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 29,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 30,
          "hasVerseLabel": true,
          "verseText": "心中安静是肉体的生命；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 30,
          "hasVerseLabel": false,
          "verseText": "嫉妒是骨中的朽烂。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 30,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 31,
          "hasVerseLabel": true,
          "verseText": "欺压贫寒的，是辱没造他的主；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 31,
          "hasVerseLabel": false,
          "verseText": "怜悯穷乏的，乃是尊敬主。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 31,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 32,
          "hasVerseLabel": true,
          "verseText": "恶人在所行的恶上必被推倒；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 32,
          "hasVerseLabel": false,
          "verseText": "义人临死，有所投靠。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 32,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 33,
          "hasVerseLabel": true,
          "verseText": "智慧存在聪明人心中；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 33,
          "hasVerseLabel": false,
          "verseText": "愚昧人心里所存的，显而易见。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 33,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 34,
          "hasVerseLabel": true,
          "verseText": "公义使邦国高举；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 34,
          "hasVerseLabel": false,
          "verseText": "罪恶是人民的羞辱。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 34,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 35,
          "hasVerseLabel": true,
          "verseText": "智慧的臣子蒙王恩惠；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 35,
          "hasVerseLabel": false,
          "verseText": "贻羞的仆人遭其震怒。"
        }
      ]
    }
  ]
}