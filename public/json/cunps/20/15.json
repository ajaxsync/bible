{
  "book": 20,
  "chapter": 15,
  "sections": [
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "回答柔和，使怒消退；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "言语暴戾，触动怒气。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "智慧人的舌善发知识；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": "愚昧人的口吐出愚昧。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "耶和华的眼目无处不在；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": "恶人善人，他都鉴察。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "温良的舌是生命树；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": "乖谬的嘴使人心碎。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "愚妄人藐视父亲的管教；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": "领受责备的，得着见识。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "义人家中多有财宝；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": "恶人得利反受扰害。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "智慧人的嘴播扬知识；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "愚昧人的心并不如此。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "恶人献祭，为耶和华所憎恶；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": "正直人祈祷，为他所喜悦。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "恶人的道路，为耶和华所憎恶；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "追求公义的，为他所喜爱。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "舍弃正路的，必受严刑；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "恨恶责备的，必致死亡。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 11,
          "hasVerseLabel": true,
          "verseText": "阴间和灭亡尚在耶和华眼前，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": false,
          "verseText": "何况世人的心呢？"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 12,
          "hasVerseLabel": true,
          "verseText": "亵慢人不爱受责备；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": "他也不就近智慧人。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 13,
          "hasVerseLabel": true,
          "verseText": "心中喜乐，面带笑容；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": "心里忧愁，灵被损伤。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 14,
          "hasVerseLabel": true,
          "verseText": "聪明人心求知识；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": "愚昧人口吃愚昧。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 15,
          "hasVerseLabel": true,
          "verseText": "困苦人的日子都是愁苦；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": "心中欢畅的，常享丰筵。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 16,
          "hasVerseLabel": true,
          "verseText": "少有财宝，敬畏耶和华，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 16,
          "hasVerseLabel": false,
          "verseText": "强如多有财宝，烦乱不安。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 16,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 17,
          "hasVerseLabel": true,
          "verseText": "吃素菜，彼此相爱，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 17,
          "hasVerseLabel": false,
          "verseText": "强如吃肥牛，彼此相恨。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 17,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 18,
          "hasVerseLabel": true,
          "verseText": "暴怒的人挑启争端；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 18,
          "hasVerseLabel": false,
          "verseText": "忍怒的人止息纷争。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 18,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 19,
          "hasVerseLabel": true,
          "verseText": "懒惰人的道像荆棘的篱笆；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 19,
          "hasVerseLabel": false,
          "verseText": "正直人的路是平坦的大道。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 19,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 20,
          "hasVerseLabel": true,
          "verseText": "智慧子使父亲喜乐；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 20,
          "hasVerseLabel": false,
          "verseText": "愚昧人藐视母亲。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 20,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 21,
          "hasVerseLabel": true,
          "verseText": "无知的人以愚妄为乐；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 21,
          "hasVerseLabel": false,
          "verseText": "聪明的人按正直而行。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 21,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 22,
          "hasVerseLabel": true,
          "verseText": "不先商议，所谋无效；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 22,
          "hasVerseLabel": false,
          "verseText": "谋士众多，所谋乃成。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 22,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 23,
          "hasVerseLabel": true,
          "verseText": "口善应对，自觉喜乐；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 23,
          "hasVerseLabel": false,
          "verseText": "话合其时，何等美好。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 23,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 24,
          "hasVerseLabel": true,
          "verseText": "智慧人从生命的道上升，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 24,
          "hasVerseLabel": false,
          "verseText": "使他远离在下的阴间。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 24,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 25,
          "hasVerseLabel": true,
          "verseText": "耶和华必拆毁骄傲人的家，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 25,
          "hasVerseLabel": false,
          "verseText": "却要立定寡妇的地界。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 25,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 26,
          "hasVerseLabel": true,
          "verseText": "恶谋为耶和华所憎恶；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 26,
          "hasVerseLabel": false,
          "verseText": "良言乃为纯净。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 26,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 27,
          "hasVerseLabel": true,
          "verseText": "贪恋财利的，扰害己家；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 27,
          "hasVerseLabel": false,
          "verseText": "恨恶贿赂的，必得存活。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 27,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 28,
          "hasVerseLabel": true,
          "verseText": "义人的心，思量如何回答；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 28,
          "hasVerseLabel": false,
          "verseText": "恶人的口吐出恶言。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 28,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 29,
          "hasVerseLabel": true,
          "verseText": "耶和华远离恶人，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 29,
          "hasVerseLabel": false,
          "verseText": "却听义人的祷告。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 29,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 30,
          "hasVerseLabel": true,
          "verseText": "眼有光，使心喜乐；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 30,
          "hasVerseLabel": false,
          "verseText": "好信息，使骨滋润。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 30,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 31,
          "hasVerseLabel": true,
          "verseText": "听从生命责备的，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 31,
          "hasVerseLabel": false,
          "verseText": "必常在智慧人中。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 31,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 32,
          "hasVerseLabel": true,
          "verseText": "弃绝管教的，轻看自己的生命；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 32,
          "hasVerseLabel": false,
          "verseText": "听从责备的，却得智慧。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 32,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 33,
          "hasVerseLabel": true,
          "verseText": "敬畏耶和华是智慧的训诲；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 33,
          "hasVerseLabel": false,
          "verseText": "尊荣以前，必有谦卑。"
        }
      ]
    }
  ]
}