{
  "book": 25,
  "chapter": 3,
  "sections": [
    {
      "type": "heading",
      "heading": "刑罚、悔改、希望"
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "我是因耶和华忿怒的杖，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "遭遇困苦的人。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "他引导我，使我行在黑暗中，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": "不行在光明里。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "他真是终日再三反手攻击我。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "他使我的皮肉枯干；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "他折断我的骨头。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "他筑垒攻击我，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "用苦楚和艰难围困我。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "他使我住在幽暗之处，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": "像死了许久的人一样。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "他用篱笆围住我，使我不能出去；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "他使我的铜炼沉重。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "我哀号求救；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": "他使我的祷告不得上达。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "他用凿过的石头挡住我的道；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "他使我的路弯曲。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "他向我如熊埋伏，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "如狮子在隐密处。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 11,
          "hasVerseLabel": true,
          "verseText": "他使我转离正路，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": false,
          "verseText": "将我撕碎，使我凄凉。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 12,
          "hasVerseLabel": true,
          "verseText": "他张弓将我当作箭靶子。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 13,
          "hasVerseLabel": true,
          "verseText": "他把箭袋中的箭射入我的肺腑。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 14,
          "hasVerseLabel": true,
          "verseText": "我成了众民的笑话；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": "他们终日以我为歌曲。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 15,
          "hasVerseLabel": true,
          "verseText": "他用苦楚充满我，使我饱用茵𫈟。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 16,
          "hasVerseLabel": true,
          "verseText": "他又用沙石碜断我的牙，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 16,
          "hasVerseLabel": false,
          "verseText": "用灰尘将我蒙蔽。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 16,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 17,
          "hasVerseLabel": true,
          "verseText": "你使我远离平安，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 17,
          "hasVerseLabel": false,
          "verseText": "我忘记好处。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 17,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 18,
          "hasVerseLabel": true,
          "verseText": "我就说：我的力量衰败；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 18,
          "hasVerseLabel": false,
          "verseText": "我在耶和华那里毫无指望！"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 18,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 19,
          "hasVerseLabel": true,
          "verseText": " 耶和华啊，求你记念我"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 19,
          "hasVerseLabel": false,
          "verseText": "如茵𫈟和苦胆的困苦窘迫。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 19,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 20,
          "hasVerseLabel": true,
          "verseText": "我心想念这些，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 20,
          "hasVerseLabel": false,
          "verseText": "就在里面忧闷。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 20,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 21,
          "hasVerseLabel": true,
          "verseText": "我想起这事，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 21,
          "hasVerseLabel": false,
          "verseText": "心里就有指望。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 21,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 22,
          "hasVerseLabel": true,
          "verseText": "我们不致消灭，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 22,
          "hasVerseLabel": false,
          "verseText": "是出于耶和华诸般的慈爱；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 22,
          "hasVerseLabel": false,
          "verseText": "是因他的怜悯不致断绝。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 22,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 23,
          "hasVerseLabel": true,
          "verseText": "每早晨，这都是新的；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 23,
          "hasVerseLabel": false,
          "verseText": "你的诚实极其广大！"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 23,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 24,
          "hasVerseLabel": true,
          "verseText": "我心里说：耶和华是我的分，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 24,
          "hasVerseLabel": false,
          "verseText": "因此，我要仰望他。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 24,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 25,
          "hasVerseLabel": true,
          "verseText": "凡等候耶和华，心里寻求他的，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 25,
          "hasVerseLabel": false,
          "verseText": "耶和华必施恩给他。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 25,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 26,
          "hasVerseLabel": true,
          "verseText": "人仰望耶和华，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 26,
          "hasVerseLabel": false,
          "verseText": "静默等候他的救恩，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 26,
          "hasVerseLabel": false,
          "verseText": "这原是好的。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 26,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 27,
          "hasVerseLabel": true,
          "verseText": "人在幼年负轭，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 27,
          "hasVerseLabel": false,
          "verseText": "这原是好的。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 27,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 28,
          "hasVerseLabel": true,
          "verseText": "他当独坐无言，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 28,
          "hasVerseLabel": false,
          "verseText": "因为这是耶和华加在他身上的。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 28,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 29,
          "hasVerseLabel": true,
          "verseText": "他当口贴尘埃，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 29,
          "hasVerseLabel": false,
          "verseText": "或者有指望。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 29,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 30,
          "hasVerseLabel": true,
          "verseText": "他当由人打他的腮颊，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 30,
          "hasVerseLabel": false,
          "verseText": "要满受凌辱。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 30,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 31,
          "hasVerseLabel": true,
          "verseText": "因为主必不永远丢弃人。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 31,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 32,
          "hasVerseLabel": true,
          "verseText": "主虽使人忧愁，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 32,
          "hasVerseLabel": false,
          "verseText": "还要照他诸般的慈爱发怜悯。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 32,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 33,
          "hasVerseLabel": true,
          "verseText": "因他并不甘心使人受苦，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 33,
          "hasVerseLabel": false,
          "verseText": "使人忧愁。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 33,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 34,
          "hasVerseLabel": true,
          "verseText": "人将世上被囚的踹在脚下，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 34,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 35,
          "hasVerseLabel": true,
          "verseText": "或在至高者面前屈枉人，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 35,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 36,
          "hasVerseLabel": true,
          "verseText": "或在人的讼事上颠倒是非，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 36,
          "hasVerseLabel": false,
          "verseText": "这都是主看不上的。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 36,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 37,
          "hasVerseLabel": true,
          "verseText": "除非主命定，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 37,
          "hasVerseLabel": false,
          "verseText": "谁能说成就成呢？"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 37,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 38,
          "hasVerseLabel": true,
          "verseText": "祸福不都出于至高者的口吗？"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 38,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 39,
          "hasVerseLabel": true,
          "verseText": "活人因自己的罪受罚，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 39,
          "hasVerseLabel": false,
          "verseText": "为何发怨言呢？"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 39,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 40,
          "hasVerseLabel": true,
          "verseText": "我们当深深考察自己的行为，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 40,
          "hasVerseLabel": false,
          "verseText": "再归向耶和华。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 40,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 41,
          "hasVerseLabel": true,
          "verseText": "我们当诚心向天上的神举手祷告。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 41,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 42,
          "hasVerseLabel": true,
          "verseText": "我们犯罪背逆，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 42,
          "hasVerseLabel": false,
          "verseText": "你并不赦免。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 42,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 43,
          "hasVerseLabel": true,
          "verseText": "你自被怒气遮蔽，追赶我们；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 43,
          "hasVerseLabel": false,
          "verseText": "你施行杀戮，并不顾惜。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 43,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 44,
          "hasVerseLabel": true,
          "verseText": "你以黑云遮蔽自己，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 44,
          "hasVerseLabel": false,
          "verseText": "以致祷告不得透入。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 44,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 45,
          "hasVerseLabel": true,
          "verseText": "你使我们在万民中成为污秽和渣滓。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 45,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 46,
          "hasVerseLabel": true,
          "verseText": "我们的仇敌都向我们大大张口。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 46,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 47,
          "hasVerseLabel": true,
          "verseText": "恐惧和陷坑，残害和毁灭，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 47,
          "hasVerseLabel": false,
          "verseText": "都临近我们。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 47,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 48,
          "hasVerseLabel": true,
          "verseText": "因我众民遭的毁灭，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 48,
          "hasVerseLabel": false,
          "verseText": "我就眼泪下流如河。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 48,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 49,
          "hasVerseLabel": true,
          "verseText": "我的眼多多流泪，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 49,
          "hasVerseLabel": false,
          "verseText": "总不止息，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 49,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 50,
          "hasVerseLabel": true,
          "verseText": "直等耶和华垂顾，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 50,
          "hasVerseLabel": false,
          "verseText": "从天观看。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 50,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 51,
          "hasVerseLabel": true,
          "verseText": "因我本城的众民，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 51,
          "hasVerseLabel": false,
          "verseText": "我的眼，使我的心伤痛。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 51,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 52,
          "hasVerseLabel": true,
          "verseText": "无故与我为仇的追逼我，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 52,
          "hasVerseLabel": false,
          "verseText": "像追雀鸟一样。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 52,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 53,
          "hasVerseLabel": true,
          "verseText": "他们使我的命在牢狱中断绝，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 53,
          "hasVerseLabel": false,
          "verseText": "并将一块石头抛在我身上。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 53,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 54,
          "hasVerseLabel": true,
          "verseText": "众水流过我头，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 54,
          "hasVerseLabel": false,
          "verseText": "我说：我命断绝了！"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 54,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 55,
          "hasVerseLabel": true,
          "verseText": "耶和华啊，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 55,
          "hasVerseLabel": false,
          "verseText": "我从深牢中求告你的名。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 55,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 56,
          "hasVerseLabel": true,
          "verseText": "你曾听见我的声音；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 56,
          "hasVerseLabel": false,
          "verseText": "我求你解救，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 56,
          "hasVerseLabel": false,
          "verseText": "你不要掩耳不听。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 56,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 57,
          "hasVerseLabel": true,
          "verseText": "我求告你的日子，你临近我，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 57,
          "hasVerseLabel": false,
          "verseText": "说：不要惧怕！"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 57,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 58,
          "hasVerseLabel": true,
          "verseText": "主啊，你伸明了我的冤；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 58,
          "hasVerseLabel": false,
          "verseText": "你救赎了我的命。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 58,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 59,
          "hasVerseLabel": true,
          "verseText": "耶和华啊，你见了我受的委屈；"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 59,
          "hasVerseLabel": false,
          "verseText": "求你为我伸冤。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 59,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 60,
          "hasVerseLabel": true,
          "verseText": "他们仇恨我，谋害我，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 60,
          "hasVerseLabel": false,
          "verseText": "你都看见了。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 60,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 61,
          "hasVerseLabel": true,
          "verseText": "耶和华啊，你听见他们辱骂我的话，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 61,
          "hasVerseLabel": false,
          "verseText": "知道他们向我所设的计，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 61,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 62,
          "hasVerseLabel": true,
          "verseText": "并那些起来攻击我的人口中所说的话，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 62,
          "hasVerseLabel": false,
          "verseText": "以及终日向我所设的计谋。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 62,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 63,
          "hasVerseLabel": true,
          "verseText": "求你观看，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 63,
          "hasVerseLabel": false,
          "verseText": "他们坐下，起来，都以我为歌曲。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 63,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 64,
          "hasVerseLabel": true,
          "verseText": "耶和华啊，你要按着他们手所做的"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 64,
          "hasVerseLabel": false,
          "verseText": "向他们施行报应。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 64,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 65,
          "hasVerseLabel": true,
          "verseText": "你要使他们心里刚硬，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 65,
          "hasVerseLabel": false,
          "verseText": "使你的咒诅临到他们。"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 65,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 66,
          "hasVerseLabel": true,
          "verseText": "你要发怒追赶他们，"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 66,
          "hasVerseLabel": false,
          "verseText": "从耶和华的天下除灭他们。"
        }
      ]
    }
  ]
}