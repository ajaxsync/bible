      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "And David spoke to the Lord the words of this song on the day when the Lord delivered him from the hand of all his enemies, and from the hand of Saul. "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "He said, “The Lord is my rock and my fortress and my deliverer, "
        }
      ]
