      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 13,
          "hasVerseLabel": true,
          "verseText": "Out of the brightness before him coals of fire flamed forth. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 14,
          "hasVerseLabel": true,
          "verseText": "The Lord thundered from heaven, and the Most High uttered his voice. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": "The Lord thundered from heaven, and the Most High uttered his voice."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 15,
          "hasVerseLabel": true,
          "verseText": "And he sent out arrows and scattered them; lightning, and routed them. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": "And he sent out arrows and scattered them; lightning, and routed them."
        }
      ]
    },
    {
