          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "“For the waves of death encompassed me, the torrents of destruction assailed me; "
        }
      ]
    },
    {
