          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "Smoke went up from his nostrils, and devouring fire from his mouth; glowing coals flamed forth from him. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "Smoke went up from his nostrils, and devouring fire from his mouth; glowing coals flamed forth from him."
