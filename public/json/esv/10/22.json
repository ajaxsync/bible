          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "“In my distress I called upon the Lord; to my God I called. From his temple he heard my voice, and my cry came to his ears. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "“In my distress I called upon the Lord; to my God I called. From his temple he heard my voice, and my cry came to his ears."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "“In my distress I called upon the Lord; to my God I called. From his temple he heard my voice, and my cry came to his ears."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "“In my distress I called upon the Lord; to my God I called. From his temple he heard my voice, and my cry came to his ears."
