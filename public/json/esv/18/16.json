          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 17,
          "hasVerseLabel": true,
          "verseText": "although there is no violence in my hands, and my prayer is pure. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
