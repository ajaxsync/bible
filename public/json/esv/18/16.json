        },
        {
          "verseNum": 16,
          "hasVerseLabel": true,
          "verseText": "My face is red with weeping, and on my eyelids is deep darkness, "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 16,
          "hasVerseLabel": false,
