          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "He has torn me in his wrath and hated me; he has gnashed his teeth at me; my adversary sharpens his eyes against me. "
        }
      ]
    },
