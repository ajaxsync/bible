        {
          "verseNum": 26,
          "hasVerseLabel": true,
          "verseText": "then man  prays to God, and he accepts him; he sees his face with a shout of joy, and he restores to man his righteousness. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 26,
          "hasVerseLabel": false,
          "verseText": "then man  prays to God, and he accepts him; he sees his face with a shout of joy, and he restores to man his righteousness."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 26,
          "hasVerseLabel": false,
          "verseText": "then man  prays to God, and he accepts him; he sees his face with a shout of joy, and he restores to man his righteousness."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 26,
          "hasVerseLabel": false,
          "verseText": "then man  prays to God, and he accepts him; he sees his face with a shout of joy, and he restores to man his righteousness."
        }
      ]
    },
