          "hasVerseLabel": true,
          "verseText": "If not, listen to me; be silent, and I will teach you wisdom.” "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 33,
          "hasVerseLabel": false,
