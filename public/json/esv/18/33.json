      "type": "line-quote",
      "contents": [
        {
          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 16,
          "hasVerseLabel": true,
          "verseText": "then he opens the ears of men and terrifies them with warnings, "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 16,
          "hasVerseLabel": false,
          "verseText": "then he opens the ears of men and terrifies them with warnings,"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
