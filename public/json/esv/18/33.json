      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 25,
          "hasVerseLabel": false,
          "verseText": "let his flesh become fresh with youth; let him return to the days of his youthful vigor’;"
        }
      ]
    },
    {
      "type": "line-quote",
