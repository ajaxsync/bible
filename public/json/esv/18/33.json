      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "Behold, no fear of me need terrify you; my pressure will not be heavy upon you. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "Behold, no fear of me need terrify you; my pressure will not be heavy upon you."
        }
      ]
    },
    {
