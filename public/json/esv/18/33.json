          "verseNum": 29,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 30,
          "hasVerseLabel": true,
          "verseText": "to bring back his soul from the pit, that he may be lighted with the light of life. "
        }
