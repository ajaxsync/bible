          "verseNum": 20,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 21,
          "hasVerseLabel": true,
          "verseText": "His flesh is so wasted away that it cannot be seen, and his bones that were not seen stick out. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 21,
          "hasVerseLabel": false,
          "verseText": "His flesh is so wasted away that it cannot be seen, and his bones that were not seen stick out."
