          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "Behold, I open my mouth; the tongue in my mouth speaks. "
        }
      ]
    },
    {
