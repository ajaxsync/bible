          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 27,
          "hasVerseLabel": true,
          "verseText": "He sings before men and says: ‘I sinned and perverted what was right, and it was not repaid to me. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 27,
          "hasVerseLabel": false,
          "verseText": "He sings before men and says: ‘I sinned and perverted what was right, and it was not repaid to me."
        }
      ]
    },
