      "contents": [
        {
          "verseNum": 28,
          "hasVerseLabel": false,
          "verseText": "He has redeemed my soul from going down into the pit, and my life shall look upon the light.’"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
