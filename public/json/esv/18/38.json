          "verseNum": 24,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 25,
          "hasVerseLabel": true,
          "verseText": "“Who has cleft a channel for the torrents of rain and a way for the thunderbolt, "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 25,
          "hasVerseLabel": false,
          "verseText": "“Who has cleft a channel for the torrents of rain and a way for the thunderbolt,"
