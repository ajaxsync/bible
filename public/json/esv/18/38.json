        {
          "verseNum": 31,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 32,
          "hasVerseLabel": true,
          "verseText": "Can you lead forth the Mazzaroth in their season, or can you guide the Bear with its children? "
        }
      ]
    },
