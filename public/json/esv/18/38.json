          "verseNum": 32,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 33,
          "hasVerseLabel": true,
          "verseText": "Do you know the ordinances of the heavens? Can you establish their rule on the earth? "
        }
