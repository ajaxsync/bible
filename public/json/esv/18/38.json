      "contents": [
        {
          "verseNum": 22,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 23,
          "hasVerseLabel": true,
          "verseText": "which I have reserved for the time of trouble, for the day of battle and war? "
        }
      ]
    },
    {
