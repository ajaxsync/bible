        },
        {
          "verseNum": 19,
          "hasVerseLabel": true,
          "verseText": "“Where is the way to the dwelling of light, and where is the place of darkness, "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 19,
          "hasVerseLabel": false,
          "verseText": "“Where is the way to the dwelling of light, and where is the place of darkness,"
        }
