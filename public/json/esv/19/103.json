    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 17,
          "hasVerseLabel": false,
          "verseText": "But the steadfast love of the Lord is from everlasting to everlasting on those who fear him, and his righteousness to children’s children,"
