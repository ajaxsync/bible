        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "Who will bring me to the fortified city? Who will lead me to Edom? "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "Who will bring me to the fortified city? Who will lead me to Edom?"
