    {
      "type": "heading",
      "heading": "義人之福"
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "Praise the Lord! Blessed is the man who fears the Lord, who greatly delights in his commandments! "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "Praise the Lord! Blessed is the man who fears the Lord, who greatly delights in his commandments!"
        }
