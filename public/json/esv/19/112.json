          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "Light dawns in the darkness for the upright; he is gracious, merciful, and righteous. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": "Light dawns in the darkness for the upright; he is gracious, merciful, and righteous."
