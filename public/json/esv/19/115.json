        },
        {
          "verseNum": 11,
          "hasVerseLabel": true,
          "verseText": "You who fear the Lord, trust in the Lord! He is their help and their shield. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": false,
          "verseText": "You who fear the Lord, trust in the Lord! He is their help and their shield."
