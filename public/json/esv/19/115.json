          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "Their idols are silver and gold, the work of human hands. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
