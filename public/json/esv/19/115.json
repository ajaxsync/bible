        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "O house of Aaron, trust in the Lord! He is their help and their shield. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
