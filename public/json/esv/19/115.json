    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": "The Lord has remembered us; he will bless us; he will bless the house of Israel; he will bless the house of Aaron;"
