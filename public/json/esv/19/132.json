          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "Behold, we heard of it in Ephrathah; we found it in the fields of Jaar. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": "Behold, we heard of it in Ephrathah; we found it in the fields of Jaar."
