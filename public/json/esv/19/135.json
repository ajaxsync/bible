          "verseNum": 19,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 20,
          "hasVerseLabel": true,
          "verseText": "O house of Levi, bless the Lord! You who fear the Lord, bless the Lord! "
