      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": "Praise the Lord, for the Lord is good; sing to his name, for it is pleasant!"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": "Praise the Lord, for the Lord is good; sing to his name, for it is pleasant!"
        }
      ]
    },
    {
