          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "He covers the heavens with clouds; he prepares rain for the earth; he makes grass grow on the hills. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
