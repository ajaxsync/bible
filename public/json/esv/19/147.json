        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 11,
          "hasVerseLabel": true,
          "verseText": "but the Lord  takes pleasure in those who fear him, in those who hope in his steadfast love. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": false,
          "verseText": "but the Lord  takes pleasure in those who fear him, in those who hope in his steadfast love."
