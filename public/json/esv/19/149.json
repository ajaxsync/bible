          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "Let Israel be glad in his Maker; let the children of Zion rejoice in their King! "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": "Let Israel be glad in his Maker; let the children of Zion rejoice in their King!"
        }
