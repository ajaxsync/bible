      "type": "line-quote",
      "contents": [
        {
          "verseNum": 35,
          "hasVerseLabel": false,
          "verseText": "You have given me the shield of your salvation, and your right hand supported me, and your gentleness made me great."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 35,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 36,
          "hasVerseLabel": true,
          "verseText": "You gave a wide place for my steps under me, and my feet did not slip. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 36,
          "hasVerseLabel": false,
          "verseText": "You gave a wide place for my steps under me, and my feet did not slip."
        }
