          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 42,
          "hasVerseLabel": true,
          "verseText": "I beat them fine as dust before the wind; I cast them out like the mire of the streets. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 42,
