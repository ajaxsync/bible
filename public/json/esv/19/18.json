          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 41,
          "hasVerseLabel": true,
          "verseText": "They cried for help, but there was none to save; they cried to the Lord, but he did not answer them. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 41,
          "hasVerseLabel": false,
          "verseText": "They cried for help, but there was none to save; they cried to the Lord, but he did not answer them."
