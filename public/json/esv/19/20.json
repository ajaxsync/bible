        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "May he grant you your heart’s desire and fulfill all your plans! "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": "May he grant you your heart’s desire and fulfill all your plans!"
