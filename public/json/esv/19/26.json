        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "I do not sit with men of falsehood, nor do I consort with hypocrites. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
