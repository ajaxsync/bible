    {
      "type": "heading",
      "heading": "感恩的禱告"
    },
    {
      "type": "desc",
      "contents": []
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "I will extol you, O Lord, for you have drawn me up and have not let my foes rejoice over me. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "I will extol you, O Lord, for you have drawn me up and have not let my foes rejoice over me."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
