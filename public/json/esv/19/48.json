          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "By the east wind you shattered the ships of Tarshish. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
