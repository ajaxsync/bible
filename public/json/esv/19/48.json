        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "As your name, O God, so your praise reaches to the ends of the earth. Your right hand is filled with righteousness. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "As your name, O God, so your praise reaches to the ends of the earth. Your right hand is filled with righteousness."
