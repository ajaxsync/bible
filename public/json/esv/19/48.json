          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "As we have heard, so have we seen in the city of the Lord of hosts, in the city of our God, which God will establish forever. Selah "
        }
