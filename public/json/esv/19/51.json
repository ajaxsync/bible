          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 18,
          "hasVerseLabel": true,
          "verseText": "Do good to Zion in your good pleasure; build up the walls of Jerusalem; "
        }
      ]
    },
    {
