          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 16,
          "hasVerseLabel": true,
          "verseText": "For you will not delight in sacrifice, or I would give it; you will not be pleased with a burnt offering. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 16,
          "hasVerseLabel": false,
          "verseText": "For you will not delight in sacrifice, or I would give it; you will not be pleased with a burnt offering."
