          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 17,
          "hasVerseLabel": true,
          "verseText": "The sacrifices of God are a broken spirit; a broken and contrite heart, O God, you will not despise. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 17,
          "hasVerseLabel": false,
          "verseText": "The sacrifices of God are a broken spirit; a broken and contrite heart, O God, you will not despise."
