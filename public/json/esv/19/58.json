          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "The righteous will rejoice when he sees the vengeance; he will bathe his feet in the blood of the wicked. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "The righteous will rejoice when he sees the vengeance; he will bathe his feet in the blood of the wicked."
