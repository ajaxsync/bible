          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "Sooner than your pots can feel the heat of thorns, whether green or ablaze, may he sweep them away! "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "Sooner than your pots can feel the heat of thorns, whether green or ablaze, may he sweep them away!"
