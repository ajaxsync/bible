          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "Depart from me, all you workers of evil, for the Lord  has heard the sound of my weeping. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": "Depart from me, all you workers of evil, for the Lord  has heard the sound of my weeping."
        }
