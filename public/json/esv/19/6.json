        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "All my enemies shall be ashamed and greatly troubled; they shall turn back and be put to shame in a moment. "
        }
      ]
    },
    {
      "type": "line-quote",
