          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "You have set up a banner for those who fear you, that they may flee to it from the bow.  Selah "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": "You have set up a banner for those who fear you, that they may flee to it from the bow.  Selah"
