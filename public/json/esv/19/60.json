      "contents": []
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "O God, you have rejected us, broken our defenses; you have been angry; oh, restore us. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "O God, you have rejected us, broken our defenses; you have been angry; oh, restore us."
