      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "God has spoken in his holiness: “With exultation I will divide up Shechem and portion out the Vale of Succoth. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": "God has spoken in his holiness: “With exultation I will divide up Shechem and portion out the Vale of Succoth."
        }
