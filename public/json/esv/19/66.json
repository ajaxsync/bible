          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 12,
          "hasVerseLabel": true,
          "verseText": "you let men ride over our heads; we went through fire and through water; yet you have brought us out to a place of abundance. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": "you let men ride over our heads; we went through fire and through water; yet you have brought us out to a place of abundance."
        }
