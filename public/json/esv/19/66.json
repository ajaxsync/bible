    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "who rules by his might forever, whose eyes keep watch on the nations— let not the rebellious exalt themselves. Selah"
