          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 13,
          "hasVerseLabel": true,
          "verseText": "he has prepared for him his deadly weapons, making his arrows fiery shafts. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
