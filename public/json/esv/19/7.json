          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "Oh, let the evil of the wicked come to an end, and may you establish the righteous— you who test the minds and hearts, O righteous God! "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "Oh, let the evil of the wicked come to an end, and may you establish the righteous— you who test the minds and hearts, O righteous God!"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "Oh, let the evil of the wicked come to an end, and may you establish the righteous— you who test the minds and hearts, O righteous God!"
