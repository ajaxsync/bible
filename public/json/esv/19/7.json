      "type": "desc",
      "contents": []
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "O Lord my God, in you do I take refuge; save me from all my pursuers and deliver me, "
        }
      ]
    },
