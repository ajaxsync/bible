          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 14,
          "hasVerseLabel": true,
          "verseText": "Behold, the wicked man conceives evil and is pregnant with mischief and gives birth to lies. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": "Behold, the wicked man conceives evil and is pregnant with mischief and gives birth to lies."
