          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "lest like a lion they tear my soul apart, rending it in pieces, with none to deliver. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
