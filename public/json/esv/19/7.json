          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 15,
          "hasVerseLabel": true,
          "verseText": "He makes a pit, digging it out, and falls into the hole that he has made. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
