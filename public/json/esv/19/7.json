      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": "Arise, O Lord, in your anger; lift yourself up against the fury of my enemies; awake for me; you have appointed a judgment."
        }
      ]
    },
