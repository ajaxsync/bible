          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "The Lord  judges the peoples; judge me, O Lord, according to my righteousness and according to the integrity that is in me. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": "The Lord  judges the peoples; judge me, O Lord, according to my righteousness and according to the integrity that is in me."
