          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 18,
          "hasVerseLabel": true,
          "verseText": "that they may know that you alone, whose name is the Lord, are the Most High over all the earth. "
        }
      ]
    },
    {
