          "verseText": " "
        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "Give ear, O Lord, to my prayer; listen to my plea for grace. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
