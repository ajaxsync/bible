          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 13,
          "hasVerseLabel": true,
          "verseText": "For great is your steadfast love toward me; you have delivered my soul from the depths of Sheol. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": "For great is your steadfast love toward me; you have delivered my soul from the depths of Sheol."
