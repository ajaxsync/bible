        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "For you, O Lord, are good and forgiving, abounding in steadfast love to all who call upon you. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
