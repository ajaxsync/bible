        {
          "verseNum": 12,
          "hasVerseLabel": true,
          "verseText": "I give thanks to you, O Lord my God, with my whole heart, and I will glorify your name forever. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": "I give thanks to you, O Lord my God, with my whole heart, and I will glorify your name forever."
