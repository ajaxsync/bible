        {
          "verseNum": 14,
          "hasVerseLabel": true,
          "verseText": "O God, insolent men have risen up against me; a band of ruthless men seeks my life, and they do not set you before them. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": "O God, insolent men have risen up against me; a band of ruthless men seeks my life, and they do not set you before them."
