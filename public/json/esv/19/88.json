          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 15,
          "hasVerseLabel": true,
          "verseText": "Afflicted and close to death from my youth up, I suffer your terrors; I am helpless. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": "Afflicted and close to death from my youth up, I suffer your terrors; I am helpless."
