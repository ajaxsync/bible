          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 12,
          "hasVerseLabel": true,
          "verseText": "Are your wonders known in the darkness, or your righteousness in the land of forgetfulness? "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": "Are your wonders known in the darkness, or your righteousness in the land of forgetfulness?"
