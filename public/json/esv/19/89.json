          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "O Lord God of hosts, who is mighty as you are, O Lord, with your faithfulness all around you? "
        }
      ]
