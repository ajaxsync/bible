      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "For who in the skies can be compared to the Lord? Who among the heavenly beings is like the Lord, "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": "For who in the skies can be compared to the Lord? Who among the heavenly beings is like the Lord,"
