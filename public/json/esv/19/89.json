          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "‘I will establish your offspring forever, and build your throne for all generations.’” Selah "
        }
