          "verseNum": 20,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 21,
          "hasVerseLabel": true,
          "verseText": "so that my hand shall be established with him; my arm also shall strengthen him. "
        }
      ]
    },
