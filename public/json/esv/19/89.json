          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "a God greatly to be feared in the council of the holy ones, and awesome above all who are around him? "
        }
