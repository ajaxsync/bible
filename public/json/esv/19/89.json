        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "Let the heavens praise your wonders, O Lord, your faithfulness in the assembly of the holy ones! "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": "Let the heavens praise your wonders, O Lord, your faithfulness in the assembly of the holy ones!"
