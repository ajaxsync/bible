        {
          "verseNum": 12,
          "hasVerseLabel": true,
          "verseText": "For he who avenges blood is mindful of them; he does not forget the cry of the afflicted. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
