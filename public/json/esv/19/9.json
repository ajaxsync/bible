        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "You have rebuked the nations; you have made the wicked perish; you have blotted out their name forever and ever. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
