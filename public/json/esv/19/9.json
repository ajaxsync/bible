        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "For you have maintained my just cause; you have sat on the throne, giving righteous judgment. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": "For you have maintained my just cause; you have sat on the throne, giving righteous judgment."
