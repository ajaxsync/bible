        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "For you, O Lord, have made me glad by your work; at the works of your hands I sing for joy. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": "For you, O Lord, have made me glad by your work; at the works of your hands I sing for joy."
