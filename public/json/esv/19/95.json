      "heading": "頌讚之詩"
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "Oh come, let us sing to the Lord; let us make a joyful noise to the rock of our salvation! "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
