          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "For he is our God, and we are the people of his pasture, and the sheep of his hand. Today, if you hear his voice, "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "For he is our God, and we are the people of his pasture, and the sheep of his hand. Today, if you hear his voice,"
        }
