          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "Declare his glory among the nations, his marvelous works among all the peoples! "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": "Declare his glory among the nations, his marvelous works among all the peoples!"
        }
