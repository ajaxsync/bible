          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "Fire goes before him and burns up his adversaries all around. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
