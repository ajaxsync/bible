          "verseText": " "
        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "The heavens proclaim his righteousness, and all the peoples see his glory. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": "The heavens proclaim his righteousness, and all the peoples see his glory."
