    {
      "type": "heading",
      "heading": "神是最高的統治者"
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "The Lord reigns, let the earth rejoice; let the many coastlands be glad! "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
