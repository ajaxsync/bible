        },
        {
          "verseNum": 32,
          "hasVerseLabel": true,
          "verseText": "The lips of the righteous know what is acceptable, but the mouth of the wicked, what is perverse. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 32,
