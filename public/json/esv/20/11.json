          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "The righteousness of the blameless keeps his way straight, but the wicked falls by his own wickedness. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": "The righteousness of the blameless keeps his way straight, but the wicked falls by his own wickedness."
