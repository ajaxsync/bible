          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "From the fruit of his mouth a man eats what is good, but the desire of the treacherous is for violence. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
