        },
        {
          "verseNum": 13,
          "hasVerseLabel": true,
          "verseText": "Whoever despises the word brings destruction on himself, but he who reveres the commandment will be rewarded. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
