        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "One pretends to be rich, yet has nothing; another pretends to be poor, yet has great wealth. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
