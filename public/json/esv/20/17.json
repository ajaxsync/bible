          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "Whoever mocks the poor insults his Maker; he who is glad at calamity will not go unpunished. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": "Whoever mocks the poor insults his Maker; he who is glad at calamity will not go unpunished."
