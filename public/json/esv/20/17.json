          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "A bribe is like a magic stone in the eyes of the one who gives it; wherever he turns he prospers. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": "A bribe is like a magic stone in the eyes of the one who gives it; wherever he turns he prospers."
