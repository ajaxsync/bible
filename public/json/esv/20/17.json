        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "Whoever covers an offense seeks love, but he who repeats a matter separates close friends. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
