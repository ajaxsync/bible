        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "A rebuke goes deeper into a man of understanding than a hundred blows into a fool. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "A rebuke goes deeper into a man of understanding than a hundred blows into a fool."
