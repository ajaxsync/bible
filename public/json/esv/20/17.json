        },
        {
          "verseNum": 12,
          "hasVerseLabel": true,
          "verseText": "Let a man meet a she-bear robbed of her cubs rather than a fool in his folly. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
