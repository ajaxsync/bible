        },
        {
          "verseNum": 11,
          "hasVerseLabel": true,
          "verseText": "An evil man seeks only rebellion, and a cruel messenger will be sent against him. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": false,
          "verseText": "An evil man seeks only rebellion, and a cruel messenger will be sent against him."
