        },
        {
          "verseNum": 26,
          "hasVerseLabel": true,
          "verseText": "To impose a fine on a righteous man is not good, nor to strike the noble for their uprightness. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 26,
          "hasVerseLabel": false,
          "verseText": "To impose a fine on a righteous man is not good, nor to strike the noble for their uprightness."
