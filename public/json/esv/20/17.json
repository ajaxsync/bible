        },
        {
          "verseNum": 17,
          "hasVerseLabel": true,
          "verseText": "A friend loves at all times, and a brother is born for adversity. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 17,
          "hasVerseLabel": false,
