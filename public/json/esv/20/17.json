          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 27,
          "hasVerseLabel": true,
          "verseText": "Whoever restrains his words has knowledge, and he who has a cool spirit is a man of understanding. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 27,
          "hasVerseLabel": false,
          "verseText": "Whoever restrains his words has knowledge, and he who has a cool spirit is a man of understanding."
