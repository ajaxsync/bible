          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "A servant who deals wisely will rule over a son who acts shamefully and will share the inheritance as one of the brothers. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": "A servant who deals wisely will rule over a son who acts shamefully and will share the inheritance as one of the brothers."
