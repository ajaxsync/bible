        },
        {
          "verseNum": 13,
          "hasVerseLabel": true,
          "verseText": "If anyone returns evil for good, evil will not depart from his house. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": "If anyone returns evil for good, evil will not depart from his house."
