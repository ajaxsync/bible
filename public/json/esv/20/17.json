          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "The crucible is for silver, and the furnace is for gold, and the Lord tests hearts. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": "The crucible is for silver, and the furnace is for gold, and the Lord tests hearts."
