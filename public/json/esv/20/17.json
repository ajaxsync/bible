          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 28,
          "hasVerseLabel": true,
          "verseText": "Even a fool who keeps silent is considered wise; when he closes his lips, he is deemed intelligent. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 28,
          "hasVerseLabel": false,
          "verseText": "Even a fool who keeps silent is considered wise; when he closes his lips, he is deemed intelligent."
