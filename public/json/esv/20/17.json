        },
        {
          "verseNum": 15,
          "hasVerseLabel": true,
          "verseText": "He who justifies the wicked and he who condemns the righteous are both alike an abomination to the Lord. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": "He who justifies the wicked and he who condemns the righteous are both alike an abomination to the Lord."
