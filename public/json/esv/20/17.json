          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "An evildoer listens to wicked lips, and a liar gives ear to a mischievous tongue. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": "An evildoer listens to wicked lips, and a liar gives ear to a mischievous tongue."
