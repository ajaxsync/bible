        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "A false witness will not go unpunished, and he who breathes out lies will perish. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "A false witness will not go unpunished, and he who breathes out lies will perish."
        }
