{
  "book": 20,
  "chapter": 19,
  "sections": [
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "Better is a poor person who walks in his integrity than one who is crooked in speech and is a fool. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "Better is a poor person who walks in his integrity than one who is crooked in speech and is a fool."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "Desire without knowledge is not good, and whoever makes haste with his feet misses his way. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": "Desire without knowledge is not good, and whoever makes haste with his feet misses his way."
        }
      ]
    },
    {
