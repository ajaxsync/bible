          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "When a man’s folly brings his way to ruin, his heart rages against the Lord. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": "When a man’s folly brings his way to ruin, his heart rages against the Lord."
        }
      ]
    },
    {
