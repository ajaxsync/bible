    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "All a poor man’s brothers hate him; how much more do his friends go far from him! He pursues them with words, but does not have them. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "All a poor man’s brothers hate him; how much more do his friends go far from him! He pursues them with words, but does not have them."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "All a poor man’s brothers hate him; how much more do his friends go far from him! He pursues them with words, but does not have them."
        }
      ]
    },
