          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "Every way of a man is right in his own eyes, but the Lord  weighs the heart. "
        }
      ]
    },
    {
