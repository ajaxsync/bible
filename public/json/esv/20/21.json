        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "The plans of the diligent lead surely to abundance, but everyone who is hasty comes only to poverty. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
