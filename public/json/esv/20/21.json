    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "The king’s heart is a stream of water in the hand of the Lord; he turns it wherever he will. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "The king’s heart is a stream of water in the hand of the Lord; he turns it wherever he will."
