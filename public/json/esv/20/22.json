          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "Drive out a scoffer, and strife will go out, and quarreling and abuse will cease. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "Drive out a scoffer, and strife will go out, and quarreling and abuse will cease."
