          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 12,
          "hasVerseLabel": true,
          "verseText": "The eyes of the Lord keep watch over knowledge, but he overthrows the words of the traitor. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": "The eyes of the Lord keep watch over knowledge, but he overthrows the words of the traitor."
        }
