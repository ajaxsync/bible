          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "Thorns and snares are in the way of the crooked; whoever guards his soul will keep far from them. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": "Thorns and snares are in the way of the crooked; whoever guards his soul will keep far from them."
        }
      ]
    },
    {
