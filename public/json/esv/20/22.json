{
  "book": 20,
  "chapter": 22,
  "sections": [
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "A good name is to be chosen rather than great riches, and favor is better than silver or gold. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "A good name is to be chosen rather than great riches, and favor is better than silver or gold."
        }
      ]
    },
    {
