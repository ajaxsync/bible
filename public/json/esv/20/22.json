          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 11,
          "hasVerseLabel": true,
          "verseText": "He who loves purity of heart, and whose speech is gracious, will have the king as his friend. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": false,
          "verseText": "He who loves purity of heart, and whose speech is gracious, will have the king as his friend."
