          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 11,
          "hasVerseLabel": true,
          "verseText": "Like a dog that returns to his vomit is a fool who repeats his folly. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": false,
          "verseText": "Like a dog that returns to his vomit is a fool who repeats his folly."
