          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 12,
          "hasVerseLabel": true,
          "verseText": "Do you see a man who is wise in his own eyes? There is more hope for a fool than for him. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": "Do you see a man who is wise in his own eyes? There is more hope for a fool than for him."
