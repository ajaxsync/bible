          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 22,
          "hasVerseLabel": true,
          "verseText": "The words of a whisperer are like delicious morsels; they go down into the inner parts of the body. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 22,
          "hasVerseLabel": false,
          "verseText": "The words of a whisperer are like delicious morsels; they go down into the inner parts of the body."
