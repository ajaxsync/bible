        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "Like a thorn that goes up into the hand of a drunkard is a proverb in the mouth of fools. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "Like a thorn that goes up into the hand of a drunkard is a proverb in the mouth of fools."
