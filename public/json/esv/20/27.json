          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "One who is full loathes honey, but to one who is hungry everything bitter is sweet. "
        }
      ]
    },
