        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "A stone is heavy, and sand is weighty, but a fool’s provocation is heavier than both. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
