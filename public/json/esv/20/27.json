  "sections": [
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "Do not boast about tomorrow, for you do not know what a day may bring. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
