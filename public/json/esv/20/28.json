          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 25,
          "hasVerseLabel": true,
          "verseText": "A greedy man stirs up strife, but the one who trusts in the Lord will be enriched. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 25,
          "hasVerseLabel": false,
          "verseText": "A greedy man stirs up strife, but the one who trusts in the Lord will be enriched."
