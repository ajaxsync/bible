      "contents": [
        {
          "verseNum": 18,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 19,
          "hasVerseLabel": true,
          "verseText": "Whoever works his land will have plenty of bread, but he who follows worthless pursuits will have plenty of poverty. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 19,
          "hasVerseLabel": false,
          "verseText": "Whoever works his land will have plenty of bread, but he who follows worthless pursuits will have plenty of poverty."
        }
      ]
    },
