          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 27,
          "hasVerseLabel": true,
          "verseText": "Whoever gives to the poor will not want, but he who hides his eyes will get many a curse. "
        }
      ]
    },
