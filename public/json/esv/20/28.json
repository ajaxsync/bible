          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 12,
          "hasVerseLabel": true,
          "verseText": "When the righteous triumph, there is great glory, but when the wicked rise, people hide themselves. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": "When the righteous triumph, there is great glory, but when the wicked rise, people hide themselves."
        }
      ]
    },
    {
