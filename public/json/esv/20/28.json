          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 14,
          "hasVerseLabel": true,
          "verseText": "Blessed is the one who fears the Lord always, but whoever hardens his heart will fall into calamity. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": "Blessed is the one who fears the Lord always, but whoever hardens his heart will fall into calamity."
        }
      ]
