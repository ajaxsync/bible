          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 26,
          "hasVerseLabel": true,
          "verseText": "Whoever trusts in his own mind is a fool, but he who walks in wisdom will be delivered. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 26,
          "hasVerseLabel": false,
          "verseText": "Whoever trusts in his own mind is a fool, but he who walks in wisdom will be delivered."
        }
      ]
    },
    {
