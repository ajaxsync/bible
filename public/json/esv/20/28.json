          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 11,
          "hasVerseLabel": true,
          "verseText": "A rich man is wise in his own eyes, but a poor man who has understanding will find him out. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": false,
          "verseText": "A rich man is wise in his own eyes, but a poor man who has understanding will find him out."
        }
      ]
    },
