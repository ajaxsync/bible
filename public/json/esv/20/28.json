          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "Whoever misleads the upright into an evil way will fall into his own pit, but the blameless will have a goodly inheritance. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "Whoever misleads the upright into an evil way will fall into his own pit, but the blameless will have a goodly inheritance."
        }
      ]
    },
    {
