        },
        {
          "verseNum": 28,
          "hasVerseLabel": true,
          "verseText": "When the wicked rise, people hide themselves, but when they perish, the righteous increase. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 28,
          "hasVerseLabel": false,
