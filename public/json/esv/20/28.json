          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "If one turns away his ear from hearing the law, even his prayer is an abomination. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "If one turns away his ear from hearing the law, even his prayer is an abomination."
        }
      ]
    },
    {
