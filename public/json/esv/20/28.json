          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 23,
          "hasVerseLabel": true,
          "verseText": "Whoever rebukes a man will afterward find more favor than he who flatters with his tongue. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 23,
          "hasVerseLabel": false,
          "verseText": "Whoever rebukes a man will afterward find more favor than he who flatters with his tongue."
