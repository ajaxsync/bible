          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 17,
          "hasVerseLabel": true,
          "verseText": "If one is burdened with the blood of another, he will be a fugitive until death; let no one help him. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 17,
          "hasVerseLabel": false,
          "verseText": "If one is burdened with the blood of another, he will be a fugitive until death; let no one help him."
