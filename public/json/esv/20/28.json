          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 16,
          "hasVerseLabel": true,
          "verseText": "A ruler who lacks understanding is a cruel oppressor, but he who hates unjust gain will prolong his days. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 16,
          "hasVerseLabel": false,
          "verseText": "A ruler who lacks understanding is a cruel oppressor, but he who hates unjust gain will prolong his days."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
