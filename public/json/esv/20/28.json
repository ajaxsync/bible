          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 18,
          "hasVerseLabel": true,
          "verseText": "Whoever walks in integrity will be delivered, but he who is crooked in his ways will suddenly fall. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 18,
          "hasVerseLabel": false,
          "verseText": "Whoever walks in integrity will be delivered, but he who is crooked in his ways will suddenly fall."
