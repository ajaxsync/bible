      "type": "line-quote",
      "contents": [
        {
          "verseNum": 19,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 20,
          "hasVerseLabel": true,
          "verseText": "A faithful man will abound with blessings, but whoever hastens to be rich will not go unpunished. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 20,
          "hasVerseLabel": false,
          "verseText": "A faithful man will abound with blessings, but whoever hastens to be rich will not go unpunished."
        }
      ]
    },
    {
