        },
        {
          "verseNum": 14,
          "hasVerseLabel": true,
          "verseText": "If a king faithfully judges the poor, his throne will be established forever. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
