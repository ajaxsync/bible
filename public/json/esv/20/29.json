        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "Scoffers set a city aflame, but the wise turn away wrath. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
