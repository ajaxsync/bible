        },
        {
          "verseNum": 13,
          "hasVerseLabel": true,
          "verseText": "The poor man and the oppressor meet together; the Lord  gives light to the eyes of both. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
