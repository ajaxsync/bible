        },
        {
          "verseNum": 19,
          "hasVerseLabel": true,
          "verseText": "By mere words a servant is not disciplined, for though he understands, he will not respond. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 19,
          "hasVerseLabel": false,
