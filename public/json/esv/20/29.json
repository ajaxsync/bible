        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "If a wise man has an argument with a fool, the fool only rages and laughs, and there is no quiet. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "If a wise man has an argument with a fool, the fool only rages and laughs, and there is no quiet."
