        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "An evil man is ensnared in his transgression, but a righteous man sings and rejoices. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
