        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "A righteous man knows the rights of the poor; a wicked man does not understand such knowledge. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
