          "hasVerseLabel": true,
          "verseText": "An unjust man is an abomination to the righteous, but one whose way is straight is an abomination to the wicked. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 27,
