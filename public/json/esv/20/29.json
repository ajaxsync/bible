          "verseText": " "
        },
        {
          "verseNum": 16,
          "hasVerseLabel": true,
          "verseText": "When the wicked increase, transgression increases, but the righteous will look upon their downfall. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 16,
          "hasVerseLabel": false,
          "verseText": "When the wicked increase, transgression increases, but the righteous will look upon their downfall."
