          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 14,
          "hasVerseLabel": true,
          "verseText": "She sits at the door of her house; she takes a seat on the highest places of the town, "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
