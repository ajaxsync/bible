      "contents": [
        {
          "verseNum": 41,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 42,
          "hasVerseLabel": true,
          "verseText": "They looked, but there was none to save; Even to the Lord, but He did not answer them. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 42,
          "hasVerseLabel": false,
