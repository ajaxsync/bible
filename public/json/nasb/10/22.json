    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 39,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 40,
          "hasVerseLabel": true,
          "verseText": "For You have girded me with strength for battle; You have subdued under me those who rose up against me. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 40,
          "hasVerseLabel": false,
          "verseText": "For You have girded me with strength for battle; You have subdued under me those who rose up against me."
        }
      ]
    },
    {
