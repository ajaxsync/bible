      "contents": [
        {
          "verseNum": 40,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 41,
          "hasVerseLabel": true,
          "verseText": "You have also made my enemies turn their backs to me, And I destroyed those who hated me. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 41,
          "hasVerseLabel": false,
          "verseText": "You have also made my enemies turn their backs to me, And I destroyed those who hated me."
