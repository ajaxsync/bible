          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 49,
          "hasVerseLabel": true,
          "verseText": "Who also brings me out from my enemies; You even lift me above those who rise up against me; You rescue me from the violent man. "
        }
