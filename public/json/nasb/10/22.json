          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 44,
          "hasVerseLabel": true,
          "verseText": "You have also delivered me from the contentions of my people; You have kept me as head of the nations; A people whom I have not known serve me. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 44,
          "hasVerseLabel": false,
          "verseText": "You have also delivered me from the contentions of my people; You have kept me as head of the nations; A people whom I have not known serve me."
        }
      ]
    },
