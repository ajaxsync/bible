        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "“Dominion and awe belong to Him Who establishes peace in His heights. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": "“Dominion and awe belong to Him Who establishes peace in His heights."
