{
  "book": 18,
  "chapter": 33,
  "sections": [
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "“However now, Job, please hear my speech, And listen to all my words. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "“However now, Job, please hear my speech, And listen to all my words."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "Behold now, I open my mouth, My tongue in my mouth speaks. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": "Behold now, I open my mouth, My tongue in my mouth speaks."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "My words are from the uprightness of my heart, And my lips speak knowledge sincerely. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": "My words are from the uprightness of my heart, And my lips speak knowledge sincerely."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "The Spirit of God has made me, And the breath of the Almighty gives me life. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": "The Spirit of God has made me, And the breath of the Almighty gives me life."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "Refute me if you can; Array yourselves before me, take your stand. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": "Refute me if you can; Array yourselves before me, take your stand."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "Behold, I belong to God like you; I too have been formed out of the clay. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": "Behold, I belong to God like you; I too have been formed out of the clay."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "Behold, no fear of me should terrify you, Nor should my pressure weigh heavily on you. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "Behold, no fear of me should terrify you, Nor should my pressure weigh heavily on you."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "“Surely you have spoken in my hearing, And I have heard the sound of your words: "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": "“Surely you have spoken in my hearing, And I have heard the sound of your words:"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "‘I am pure, without transgression; I am innocent and there is no guilt in me. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "‘I am pure, without transgression; I am innocent and there is no guilt in me."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "Behold, He invents pretexts against me; He counts me as His enemy. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "Behold, He invents pretexts against me; He counts me as His enemy."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 11,
          "hasVerseLabel": true,
          "verseText": "He puts my feet in the stocks; He watches all my paths.’ "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": false,
          "verseText": "He puts my feet in the stocks; He watches all my paths.’"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 12,
          "hasVerseLabel": true,
          "verseText": "Behold, let me tell you, you are not right in this, For God is greater than man. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": "Behold, let me tell you, you are not right in this, For God is greater than man."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 13,
          "hasVerseLabel": true,
          "verseText": "“Why do you complain against Him That He does not give an account of all His doings? "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": "“Why do you complain against Him That He does not give an account of all His doings?"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 14,
          "hasVerseLabel": true,
          "verseText": "Indeed God speaks once, Or twice, yet no one notices it. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": "Indeed God speaks once, Or twice, yet no one notices it."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 15,
          "hasVerseLabel": true,
          "verseText": "In a dream, a vision of the night, When sound sleep falls on men, While they slumber in their beds, "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": "In a dream, a vision of the night, When sound sleep falls on men, While they slumber in their beds,"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 16,
          "hasVerseLabel": true,
          "verseText": "Then He opens the ears of men, And seals their instruction, "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 16,
          "hasVerseLabel": false,
          "verseText": "Then He opens the ears of men, And seals their instruction,"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 16,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 17,
          "hasVerseLabel": true,
          "verseText": "That He may turn man aside from his conduct, And keep man from pride; "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 17,
          "hasVerseLabel": true,
          "verseText": "That He may turn man aside from his conduct, And keep man from pride; "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 17,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 18,
          "hasVerseLabel": true,
          "verseText": "He keeps back his soul from the pit, And his life from passing over into Sheol. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 18,
          "hasVerseLabel": false,
          "verseText": "He keeps back his soul from the pit, And his life from passing over into Sheol."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 18,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 19,
          "hasVerseLabel": true,
          "verseText": "“Man is also chastened with pain on his bed, And with unceasing complaint in his bones; "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 19,
          "hasVerseLabel": false,
          "verseText": "“Man is also chastened with pain on his bed, And with unceasing complaint in his bones;"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 19,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 20,
          "hasVerseLabel": true,
          "verseText": "So that his life loathes bread, And his soul favorite food. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 20,
          "hasVerseLabel": false,
          "verseText": "So that his life loathes bread, And his soul favorite food."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 20,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 21,
          "hasVerseLabel": true,
          "verseText": "His flesh wastes away from sight, And his bones which were not seen stick out. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 21,
          "hasVerseLabel": false,
          "verseText": "His flesh wastes away from sight, And his bones which were not seen stick out."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 21,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 22,
          "hasVerseLabel": true,
          "verseText": "Then his soul draws near to the pit, And his life to those who bring death. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 22,
          "hasVerseLabel": false,
          "verseText": "Then his soul draws near to the pit, And his life to those who bring death."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 22,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 23,
          "hasVerseLabel": true,
          "verseText": "“If there is an angel as mediator for him, One out of a thousand, To remind a man what is right for him, "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 23,
          "hasVerseLabel": false,
          "verseText": "“If there is an angel as mediator for him, One out of a thousand, To remind a man what is right for him,"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 23,
          "hasVerseLabel": false,
          "verseText": "“If there is an angel as mediator for him, One out of a thousand, To remind a man what is right for him,"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 23,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 24,
          "hasVerseLabel": true,
          "verseText": "Then let him be gracious to him, and say, ‘Deliver him from going down to the pit, I have found a ransom’; "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 24,
          "hasVerseLabel": false,
          "verseText": "Then let him be gracious to him, and say, ‘Deliver him from going down to the pit, I have found a ransom’;"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 24,
          "hasVerseLabel": false,
          "verseText": "Then let him be gracious to him, and say, ‘Deliver him from going down to the pit, I have found a ransom’;"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 24,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 25,
          "hasVerseLabel": true,
          "verseText": "Let his flesh become fresher than in youth, Let him return to the days of his youthful vigor; "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 25,
          "hasVerseLabel": false,
          "verseText": "Let his flesh become fresher than in youth, Let him return to the days of his youthful vigor;"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 25,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 26,
          "hasVerseLabel": true,
          "verseText": "Then he will pray to God, and He will accept him, That he may see His face with joy, And He may restore His righteousness to man. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 26,
          "hasVerseLabel": false,
          "verseText": "Then he will pray to God, and He will accept him, That he may see His face with joy, And He may restore His righteousness to man."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 26,
          "hasVerseLabel": false,
          "verseText": "Then he will pray to God, and He will accept him, That he may see His face with joy, And He may restore His righteousness to man."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 26,
          "hasVerseLabel": false,
          "verseText": "Then he will pray to God, and He will accept him, That he may see His face with joy, And He may restore His righteousness to man."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 26,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 27,
          "hasVerseLabel": true,
          "verseText": "He will sing to men and say, ‘I have sinned and perverted what is right, And it is not proper for me. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 27,
          "hasVerseLabel": false,
          "verseText": "He will sing to men and say, ‘I have sinned and perverted what is right, And it is not proper for me."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 27,
          "hasVerseLabel": false,
          "verseText": "He will sing to men and say, ‘I have sinned and perverted what is right, And it is not proper for me."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 27,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 28,
          "hasVerseLabel": true,
          "verseText": "He has redeemed my soul from going to the pit, And my life shall see the light.’ "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 28,
          "hasVerseLabel": false,
          "verseText": "He has redeemed my soul from going to the pit, And my life shall see the light.’"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 28,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 29,
          "hasVerseLabel": true,
          "verseText": "“Behold, God does all these oftentimes with men, "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 29,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 30,
          "hasVerseLabel": true,
          "verseText": "To bring back his soul from the pit, That he may be enlightened with the light of life. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 30,
          "hasVerseLabel": false,
          "verseText": "To bring back his soul from the pit, That he may be enlightened with the light of life."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 30,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 31,
          "hasVerseLabel": true,
          "verseText": "Pay attention, O Job, listen to me; Keep silent, and let me speak. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 31,
          "hasVerseLabel": false,
          "verseText": "Pay attention, O Job, listen to me; Keep silent, and let me speak."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 31,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 32,
          "hasVerseLabel": true,
          "verseText": "Then if you have anything to say, answer me; Speak, for I desire to justify you. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 32,
          "hasVerseLabel": false,
          "verseText": "Then if you have anything to say, answer me; Speak, for I desire to justify you."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 32,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 33,
          "hasVerseLabel": true,
          "verseText": "If not, listen to me; Keep silent, and I will teach you wisdom.” "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 33,
          "hasVerseLabel": false,
          "verseText": "If not, listen to me; Keep silent, and I will teach you wisdom.”"
        }
      ]
    }
  ]
}