      "type": "line-quote",
      "contents": [
        {
          "verseNum": 26,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 27,
          "hasVerseLabel": true,
          "verseText": "But You are the same, And Your years will not come to an end. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 27,
          "hasVerseLabel": false,
          "verseText": "But You are the same, And Your years will not come to an end."
        }
