      "type": "line-quote",
      "contents": [
        {
          "verseNum": 31,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 32,
          "hasVerseLabel": true,
          "verseText": "He looks at the earth, and it trembles; He touches the mountains, and they smoke. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 32,
          "hasVerseLabel": false,
          "verseText": "He looks at the earth, and it trembles; He touches the mountains, and they smoke."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 32,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 33,
          "hasVerseLabel": true,
          "verseText": "I will sing to the Lord as long as I live; I will sing praise to my God while I have my being. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
