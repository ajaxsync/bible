          "verseNum": 19,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 20,
          "hasVerseLabel": true,
          "verseText": "You appoint darkness and it becomes night, In which all the beasts of the forest prowl about. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 20,
          "hasVerseLabel": false,
          "verseText": "You appoint darkness and it becomes night, In which all the beasts of the forest prowl about."
