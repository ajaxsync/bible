      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": "And wine which makes man’s heart glad, So that he may make his face glisten with oil, And food which sustains man’s heart."
