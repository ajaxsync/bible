          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "He lays the beams of His upper chambers in the waters; He makes the clouds His chariot; He walks upon the wings of the wind; "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": "He lays the beams of His upper chambers in the waters; He makes the clouds His chariot; He walks upon the wings of the wind;"
