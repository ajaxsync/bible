      "type": "line-quote",
      "contents": [
        {
          "verseNum": 35,
          "hasVerseLabel": false,
          "verseText": "Let sinners be consumed from the earth And let the wicked be no more. Bless the Lord, O my soul. Praise the Lord!"
        }
      ]
    },
    {
