{
  "book": 19,
  "chapter": 112,
  "sections": [
    {
      "type": "heading",
      "heading": "義人之福"
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "Praise the Lord! How blessed is the man who fears the Lord, Who greatly delights in His commandments. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "Praise the Lord! How blessed is the man who fears the Lord, Who greatly delights in His commandments."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "Praise the Lord! How blessed is the man who fears the Lord, Who greatly delights in His commandments."
