    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "“Had it not been the Lord who was on our side,” Let Israel now say, "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "“Had it not been the Lord who was on our side,” Let Israel now say,"
        }
