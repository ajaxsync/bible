        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "My soul waits for the Lord More than the watchmen for the morning; Indeed, more than the watchmen for the morning. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": "My soul waits for the Lord More than the watchmen for the morning; Indeed, more than the watchmen for the morning."
