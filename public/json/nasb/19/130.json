    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "O Israel, hope in the Lord; For with the Lord there is lovingkindness, And with Him is abundant redemption."
