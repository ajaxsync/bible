          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 11,
          "hasVerseLabel": true,
          "verseText": "The Lord has sworn to David A truth from which He will not turn back: “Of the fruit of your body I will set upon your throne. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": false,
          "verseText": "The Lord has sworn to David A truth from which He will not turn back: “Of the fruit of your body I will set upon your throne."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": false,
          "verseText": "The Lord has sworn to David A truth from which He will not turn back: “Of the fruit of your body I will set upon your throne."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": false,
          "verseText": "The Lord has sworn to David A truth from which He will not turn back: “Of the fruit of your body I will set upon your throne."
        }
