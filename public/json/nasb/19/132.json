    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": "If your sons will keep My covenant And My testimony which I will teach them, Their sons also shall sit upon your throne forever.”"
        }
