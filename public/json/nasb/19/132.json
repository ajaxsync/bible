          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 13,
          "hasVerseLabel": true,
          "verseText": "For the Lord has chosen Zion; He has desired it for His habitation. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": "For the Lord has chosen Zion; He has desired it for His habitation."
        }
      ]
    },
    {
