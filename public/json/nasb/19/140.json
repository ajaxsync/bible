    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "Keep me, O Lord, from the hands of the wicked; Preserve me from violent men Who have purposed to trip up my feet. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": "Keep me, O Lord, from the hands of the wicked; Preserve me from violent men Who have purposed to trip up my feet."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": "Keep me, O Lord, from the hands of the wicked; Preserve me from violent men Who have purposed to trip up my feet."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "The proud have hidden a trap for me, and cords; They have spread a net by the wayside; They have set snares for me. Selah. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": "The proud have hidden a trap for me, and cords; They have spread a net by the wayside; They have set snares for me. Selah."
        }
