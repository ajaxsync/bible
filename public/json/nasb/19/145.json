          "verseText": " "
        },
        {
          "verseNum": 13,
          "hasVerseLabel": true,
          "verseText": "Your kingdom is an everlasting kingdom, And Your dominion endures throughout all generations. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
