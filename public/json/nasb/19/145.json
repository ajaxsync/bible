        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "Great is the Lord, and highly to be praised, And His greatness is unsearchable. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
