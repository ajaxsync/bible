          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 18,
          "hasVerseLabel": true,
          "verseText": "He sends forth His word and melts them; He causes His wind to blow and the waters to flow. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 18,
          "hasVerseLabel": false,
          "verseText": "He sends forth His word and melts them; He causes His wind to blow and the waters to flow."
