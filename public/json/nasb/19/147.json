        },
        {
          "verseNum": 19,
          "hasVerseLabel": true,
          "verseText": "He declares His words to Jacob, His statutes and His ordinances to Israel. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 19,
          "hasVerseLabel": false,
          "verseText": "He declares His words to Jacob, His statutes and His ordinances to Israel."
        }
