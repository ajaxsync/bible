      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "The Lord  supports the afflicted; He brings down the wicked to the ground. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": "The Lord  supports the afflicted; He brings down the wicked to the ground."
        }
