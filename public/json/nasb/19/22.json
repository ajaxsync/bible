          "verseNum": 27,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 28,
          "hasVerseLabel": true,
          "verseText": "For the kingdom is the Lord’s And He rules over the nations. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 28,
          "hasVerseLabel": false,
          "verseText": "For the kingdom is the Lord’s And He rules over the nations."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 28,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 29,
          "hasVerseLabel": true,
          "verseText": "All the prosperous of the earth will eat and worship, All those who go down to the dust will bow before Him, Even he who cannot keep his soul alive. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 29,
          "hasVerseLabel": false,
          "verseText": "All the prosperous of the earth will eat and worship, All those who go down to the dust will bow before Him, Even he who cannot keep his soul alive."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
