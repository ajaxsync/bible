          "verseNum": 26,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 27,
          "hasVerseLabel": true,
          "verseText": "All the ends of the earth will remember and turn to the Lord, And all the families of the nations will worship before You. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 27,
          "hasVerseLabel": false,
          "verseText": "All the ends of the earth will remember and turn to the Lord, And all the families of the nations will worship before You."
        }
      ]
    },
    {
