          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "He who has clean hands and a pure heart, Who has not lifted up his soul to falsehood And has not sworn deceitfully. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
