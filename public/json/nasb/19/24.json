        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "Who may ascend into the hill of the Lord? And who may stand in His holy place? "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
