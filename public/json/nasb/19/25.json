          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 20,
          "hasVerseLabel": true,
          "verseText": "Guard my soul and deliver me; Do not let me be ashamed, for I take refuge in You. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 20,
          "hasVerseLabel": false,
          "verseText": "Guard my soul and deliver me; Do not let me be ashamed, for I take refuge in You."
