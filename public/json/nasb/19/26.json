        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "For Your lovingkindness is before my eyes, And I have walked in Your truth. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": "For Your lovingkindness is before my eyes, And I have walked in Your truth."
