        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "But You, O Lord, are a shield about me, My glory, and the One who lifts my head. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
