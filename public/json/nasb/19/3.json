      "type": "heading",
      "heading": "求助的晨禱"
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "O Lord, how my adversaries have increased! Many are rising up against me. "
