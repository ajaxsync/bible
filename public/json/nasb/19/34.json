        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "I sought the Lord, and He answered me, And delivered me from all my fears. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
