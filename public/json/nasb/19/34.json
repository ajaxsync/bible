      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "The young lions do lack and suffer hunger; But they who seek the Lord shall not be in want of any good thing. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "The young lions do lack and suffer hunger; But they who seek the Lord shall not be in want of any good thing."
