          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "O taste and see that the Lord is good; How blessed is the man who takes refuge in Him! "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": "O taste and see that the Lord is good; How blessed is the man who takes refuge in Him!"
