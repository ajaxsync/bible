          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "My soul will make its boast in the Lord; The humble will hear it and rejoice. "
        }
      ]
    },
    {
