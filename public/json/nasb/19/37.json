        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "Rest in the Lord and wait patiently for Him; Do not fret because of him who prospers in his way, Because of the man who carries out wicked schemes. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "Rest in the Lord and wait patiently for Him; Do not fret because of him who prospers in his way, Because of the man who carries out wicked schemes."
