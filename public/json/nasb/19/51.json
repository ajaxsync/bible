          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 17,
          "hasVerseLabel": true,
          "verseText": "The sacrifices of God are a broken spirit; A broken and a contrite heart, O God, You will not despise. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 17,
          "hasVerseLabel": false,
          "verseText": "The sacrifices of God are a broken spirit; A broken and a contrite heart, O God, You will not despise."
