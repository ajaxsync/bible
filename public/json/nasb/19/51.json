    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 16,
          "hasVerseLabel": true,
          "verseText": "For You do not delight in sacrifice, otherwise I would give it; You are not pleased with burnt offering. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 16,
          "hasVerseLabel": false,
          "verseText": "For You do not delight in sacrifice, otherwise I would give it; You are not pleased with burnt offering."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
