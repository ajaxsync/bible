          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "Before your pots can feel the fire of thorns He will sweep them away with a whirlwind, the green and the burning alike. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "Before your pots can feel the fire of thorns He will sweep them away with a whirlwind, the green and the burning alike."
