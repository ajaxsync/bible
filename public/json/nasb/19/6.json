  "sections": [
    {
      "type": "heading",
      "heading": "患難中求助的祈禱"
    },
    {
      "type": "desc",
      "contents": []
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "O Lord, do not rebuke me in Your anger, Nor chasten me in Your wrath. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "O Lord, do not rebuke me in Your anger, Nor chasten me in Your wrath."
        }
      ]
    },
