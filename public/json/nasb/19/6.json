      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "Be gracious to me, O Lord, for I am pining away; Heal me, O Lord, for my bones are dismayed. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": "Be gracious to me, O Lord, for I am pining away; Heal me, O Lord, for my bones are dismayed."
