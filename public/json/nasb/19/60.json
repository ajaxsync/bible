    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "Have not You Yourself, O God, rejected us? And will You not go forth with our armies, O God? "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "Have not You Yourself, O God, rejected us? And will You not go forth with our armies, O God?"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
