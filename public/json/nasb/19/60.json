      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "That Your beloved may be delivered, Save with Your right hand, and answer us! "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": "That Your beloved may be delivered, Save with Your right hand, and answer us!"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "God has spoken in His holiness: “I will exult, I will portion out Shechem and measure out the valley of Succoth. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": "God has spoken in His holiness: “I will exult, I will portion out Shechem and measure out the valley of Succoth."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "Gilead is Mine, and Manasseh is Mine; Ephraim also is the helmet of My head; Judah is My scepter. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "Gilead is Mine, and Manasseh is Mine; Ephraim also is the helmet of My head; Judah is My scepter."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "Gilead is Mine, and Manasseh is Mine; Ephraim also is the helmet of My head; Judah is My scepter."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "Moab is My washbowl; Over Edom I shall throw My shoe; Shout loud, O Philistia, because of Me!” "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": "Moab is My washbowl; Over Edom I shall throw My shoe; Shout loud, O Philistia, because of Me!”"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": "Moab is My washbowl; Over Edom I shall throw My shoe; Shout loud, O Philistia, because of Me!”"
