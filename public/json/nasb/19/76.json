        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "At Your rebuke, O God of Jacob, Both rider and horse were cast into a dead sleep. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
