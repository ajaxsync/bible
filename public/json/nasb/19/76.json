        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "There He broke the flaming arrows, The shield and the sword and the weapons of war. Selah. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
