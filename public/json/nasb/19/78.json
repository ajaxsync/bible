        {
          "verseNum": 52,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 53,
          "hasVerseLabel": true,
          "verseText": "He led them safely, so that they did not fear; But the sea engulfed their enemies. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 53,
          "hasVerseLabel": false,
