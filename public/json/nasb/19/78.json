        {
          "verseNum": 54,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 55,
          "hasVerseLabel": true,
          "verseText": "He also drove out the nations before them And apportioned them for an inheritance by measurement, And made the tribes of Israel dwell in their tents. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 55,
          "hasVerseLabel": false,
          "verseText": "He also drove out the nations before them And apportioned them for an inheritance by measurement, And made the tribes of Israel dwell in their tents."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 55,
          "hasVerseLabel": false,
          "verseText": "He also drove out the nations before them And apportioned them for an inheritance by measurement, And made the tribes of Israel dwell in their tents."
