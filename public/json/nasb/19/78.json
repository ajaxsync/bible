      "type": "line-quote",
      "contents": [
        {
          "verseNum": 46,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 47,
          "hasVerseLabel": true,
          "verseText": "He destroyed their vines with hailstones And their sycamore trees with frost. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 47,
          "hasVerseLabel": false,
          "verseText": "He destroyed their vines with hailstones And their sycamore trees with frost."
