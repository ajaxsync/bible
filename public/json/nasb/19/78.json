        },
        {
          "verseNum": 39,
          "hasVerseLabel": true,
          "verseText": "Thus He remembered that they were but flesh, A wind that passes and does not return. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 39,
          "hasVerseLabel": false,
          "verseText": "Thus He remembered that they were but flesh, A wind that passes and does not return."
