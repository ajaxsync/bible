      "type": "line-quote",
      "contents": [
        {
          "verseNum": 45,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 46,
          "hasVerseLabel": true,
          "verseText": "He gave also their crops to the grasshopper And the product of their labor to the locust. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 46,
          "hasVerseLabel": false,
          "verseText": "He gave also their crops to the grasshopper And the product of their labor to the locust."
        }
      ]
    },
