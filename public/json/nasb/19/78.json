      "contents": [
        {
          "verseNum": 47,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 48,
          "hasVerseLabel": true,
          "verseText": "He gave over their cattle also to the hailstones And their herds to bolts of lightning. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 48,
          "hasVerseLabel": false,
          "verseText": "He gave over their cattle also to the hailstones And their herds to bolts of lightning."
