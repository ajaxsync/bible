        {
          "verseNum": 43,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 44,
          "hasVerseLabel": true,
          "verseText": "And turned their rivers to blood, And their streams, they could not drink. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 44,
          "hasVerseLabel": false,
