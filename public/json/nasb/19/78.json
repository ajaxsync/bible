      "contents": [
        {
          "verseNum": 69,
          "hasVerseLabel": false,
          "verseText": "And He built His sanctuary like the heights, Like the earth which He has founded forever."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 69,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 70,
          "hasVerseLabel": true,
          "verseText": "He also chose David His servant And took him from the sheepfolds; "
        }
