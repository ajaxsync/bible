      "type": "line-quote",
      "contents": [
        {
          "verseNum": 60,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 61,
          "hasVerseLabel": true,
          "verseText": "And gave up His strength to captivity And His glory into the hand of the adversary. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 61,
          "hasVerseLabel": false,
          "verseText": "And gave up His strength to captivity And His glory into the hand of the adversary."
        }
      ]
    },
