          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 71,
          "hasVerseLabel": true,
          "verseText": "From the care of the ewes with suckling lambs He brought him To shepherd Jacob His people, And Israel His inheritance. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 71,
          "hasVerseLabel": false,
          "verseText": "From the care of the ewes with suckling lambs He brought him To shepherd Jacob His people, And Israel His inheritance."
        }
