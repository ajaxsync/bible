      "contents": [
        {
          "verseNum": 42,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 43,
          "hasVerseLabel": true,
          "verseText": "When He performed His signs in Egypt And His marvels in the field of Zoan, "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 43,
          "hasVerseLabel": false,
          "verseText": "When He performed His signs in Egypt And His marvels in the field of Zoan,"
