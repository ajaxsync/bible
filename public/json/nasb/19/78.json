        {
          "verseNum": 44,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 45,
          "hasVerseLabel": true,
          "verseText": "He sent among them swarms of flies which devoured them, And frogs which destroyed them. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 45,
          "hasVerseLabel": false,
          "verseText": "He sent among them swarms of flies which devoured them, And frogs which destroyed them."
        }
      ]
    },
