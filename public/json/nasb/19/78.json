      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 55,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 56,
          "hasVerseLabel": true,
          "verseText": "Yet they tempted and rebelled against the Most High God And did not keep His testimonies, "
