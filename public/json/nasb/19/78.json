      "contents": [
        {
          "verseNum": 51,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 52,
          "hasVerseLabel": true,
          "verseText": "But He led forth His own people like sheep And guided them in the wilderness like a flock; "
        }
