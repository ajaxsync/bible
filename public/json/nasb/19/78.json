      "type": "line-quote",
      "contents": [
        {
          "verseNum": 71,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 72,
          "hasVerseLabel": true,
          "verseText": "So he shepherded them according to the integrity of his heart, And guided them with his skillful hands. "
        }
