    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 49,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 50,
          "hasVerseLabel": true,
          "verseText": "He leveled a path for His anger; He did not spare their soul from death, But gave over their life to the plague, "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 50,
          "hasVerseLabel": false,
          "verseText": "He leveled a path for His anger; He did not spare their soul from death, But gave over their life to the plague,"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 50,
          "hasVerseLabel": false,
          "verseText": "He leveled a path for His anger; He did not spare their soul from death, But gave over their life to the plague,"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 50,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 51,
          "hasVerseLabel": true,
          "verseText": "And smote all the firstborn in Egypt, The first issue of their virility in the tents of Ham. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 51,
          "hasVerseLabel": false,
