        {
          "verseNum": 41,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 42,
          "hasVerseLabel": true,
          "verseText": "They did not remember His power, The day when He redeemed them from the adversary, "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 42,
          "hasVerseLabel": false,
