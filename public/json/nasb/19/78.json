      "contents": [
        {
          "verseNum": 53,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 54,
          "hasVerseLabel": true,
          "verseText": "So He brought them to His holy land, To this hill country which His right hand had gained. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 54,
          "hasVerseLabel": false,
          "verseText": "So He brought them to His holy land, To this hill country which His right hand had gained."
