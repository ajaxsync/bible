      "contents": [
        {
          "verseNum": 48,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 49,
          "hasVerseLabel": true,
          "verseText": "He sent upon them His burning anger, Fury and indignation and trouble, A band of destroying angels. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 49,
          "hasVerseLabel": false,
          "verseText": "He sent upon them His burning anger, Fury and indignation and trouble, A band of destroying angels."
