      "type": "line-quote",
      "contents": [
        {
          "verseNum": 61,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 62,
          "hasVerseLabel": true,
          "verseText": "He also delivered His people to the sword, And was filled with wrath at His inheritance. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 62,
          "hasVerseLabel": false,
          "verseText": "He also delivered His people to the sword, And was filled with wrath at His inheritance."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 62,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 63,
          "hasVerseLabel": true,
          "verseText": "Fire devoured His young men, And His virgins had no wedding songs. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 63,
          "hasVerseLabel": false,
          "verseText": "Fire devoured His young men, And His virgins had no wedding songs."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 63,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 64,
          "hasVerseLabel": true,
          "verseText": "His priests fell by the sword, And His widows could not weep. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 64,
          "hasVerseLabel": false,
          "verseText": "His priests fell by the sword, And His widows could not weep."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 64,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 65,
          "hasVerseLabel": true,
          "verseText": "Then the Lord awoke as if from sleep, Like a warrior overcome by wine. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 65,
          "hasVerseLabel": false,
          "verseText": "Then the Lord awoke as if from sleep, Like a warrior overcome by wine."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 65,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 66,
          "hasVerseLabel": true,
          "verseText": "He drove His adversaries backward; He put on them an everlasting reproach. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 66,
          "hasVerseLabel": false,
