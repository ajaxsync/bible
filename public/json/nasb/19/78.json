        {
          "verseNum": 40,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 41,
          "hasVerseLabel": true,
          "verseText": "Again and again they tempted God, And pained the Holy One of Israel. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 41,
          "hasVerseLabel": false,
          "verseText": "Again and again they tempted God, And pained the Holy One of Israel."
