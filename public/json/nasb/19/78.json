      "contents": [
        {
          "verseNum": 68,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 69,
          "hasVerseLabel": true,
          "verseText": "And He built His sanctuary like the heights, Like the earth which He has founded forever. "
        }
      ]
    },
