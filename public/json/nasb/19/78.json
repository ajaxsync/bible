      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 59,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 60,
          "hasVerseLabel": true,
          "verseText": "So that He abandoned the dwelling place at Shiloh, The tent which He had pitched among men, "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 60,
          "hasVerseLabel": false,
          "verseText": "So that He abandoned the dwelling place at Shiloh, The tent which He had pitched among men,"
        }
      ]
    },
