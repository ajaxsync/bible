          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "Lovingkindness and truth have met together; Righteousness and peace have kissed each other. "
        }
      ]
    },
