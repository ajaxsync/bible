      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 13,
          "hasVerseLabel": true,
          "verseText": "Be gracious to me, O Lord; See my affliction from those who hate me, You who lift me up from the gates of death, "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": "Be gracious to me, O Lord; See my affliction from those who hate me, You who lift me up from the gates of death,"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 14,
          "hasVerseLabel": true,
          "verseText": "That I may tell of all Your praises, That in the gates of the daughter of Zion I may rejoice in Your salvation. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": true,
          "verseText": "That I may tell of all Your praises, That in the gates of the daughter of Zion I may rejoice in Your salvation. "
        }
      ]
    },
