      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "The enemy has come to an end in perpetual ruins, And You have uprooted the cities; The very memory of them has perished. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": "The enemy has come to an end in perpetual ruins, And You have uprooted the cities; The very memory of them has perished."
        }
      ]
    },
