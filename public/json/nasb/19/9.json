          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 15,
          "hasVerseLabel": true,
          "verseText": "The nations have sunk down in the pit which they have made; In the net which they hid, their own foot has been caught. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": "The nations have sunk down in the pit which they have made; In the net which they hid, their own foot has been caught."
