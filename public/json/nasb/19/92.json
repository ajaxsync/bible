    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "It is good to give thanks to the Lord And to sing praises to Your name, O Most High; "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "It is good to give thanks to the Lord And to sing praises to Your name, O Most High;"
