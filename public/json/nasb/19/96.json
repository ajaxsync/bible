          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "Sing to the Lord, bless His name; Proclaim good tidings of His salvation from day to day. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": "Sing to the Lord, bless His name; Proclaim good tidings of His salvation from day to day."
