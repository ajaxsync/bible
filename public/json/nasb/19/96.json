          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "Ascribe to the Lord, O families of the peoples, Ascribe to the Lord glory and strength. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "Ascribe to the Lord, O families of the peoples, Ascribe to the Lord glory and strength."
