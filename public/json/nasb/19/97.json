  "sections": [
    {
      "type": "heading",
      "heading": "神是最高的統治者"
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "The Lord reigns, let the earth rejoice; Let the many islands be glad. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
