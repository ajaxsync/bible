        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "The mountains melted like wax at the presence of the Lord, At the presence of the Lord of the whole earth. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
