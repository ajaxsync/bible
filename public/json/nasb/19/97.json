          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "Fire goes before Him And burns up His adversaries round about. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
