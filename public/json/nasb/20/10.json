          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 23,
          "hasVerseLabel": true,
          "verseText": "Doing wickedness is like sport to a fool, And so is wisdom to a man of understanding. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 23,
          "hasVerseLabel": false,
          "verseText": "Doing wickedness is like sport to a fool, And so is wisdom to a man of understanding."
