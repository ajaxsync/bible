        },
        {
          "verseNum": 20,
          "hasVerseLabel": true,
          "verseText": "The tongue of the righteous is as choice silver, The heart of the wicked is worth little. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 20,
          "hasVerseLabel": false,
