          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 11,
          "hasVerseLabel": true,
          "verseText": "The mouth of the righteous is a fountain of life, But the mouth of the wicked conceals violence. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": false,
          "verseText": "The mouth of the righteous is a fountain of life, But the mouth of the wicked conceals violence."
