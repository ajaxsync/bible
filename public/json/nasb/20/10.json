          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 16,
          "hasVerseLabel": true,
          "verseText": "The wages of the righteous is life, The income of the wicked, punishment. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 16,
          "hasVerseLabel": true,
          "verseText": "The wages of the righteous is life, The income of the wicked, punishment. "
        }
