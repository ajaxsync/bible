          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 17,
          "hasVerseLabel": true,
          "verseText": "He is on the path of life who heeds instruction, But he who ignores reproof goes astray. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 17,
          "hasVerseLabel": false,
          "verseText": "He is on the path of life who heeds instruction, But he who ignores reproof goes astray."
