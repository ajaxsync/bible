        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "The righteousness of the upright will deliver them, But the treacherous will be caught by their own greed. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
