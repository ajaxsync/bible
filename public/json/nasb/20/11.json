        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "With his mouth the godless man destroys his neighbor, But through knowledge the righteous will be delivered. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
