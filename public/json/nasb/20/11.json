          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "The integrity of the upright will guide them, But the crookedness of the treacherous will destroy them. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": "The integrity of the upright will guide them, But the crookedness of the treacherous will destroy them."
