        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "Righteousness guards the one whose way is blameless, But wickedness subverts the sinner. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
