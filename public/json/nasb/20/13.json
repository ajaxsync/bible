          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "From the fruit of a man’s mouth he enjoys good, But the desire of the treacherous is violence. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
