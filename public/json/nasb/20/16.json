        },
        {
          "verseNum": 16,
          "hasVerseLabel": true,
          "verseText": "How much better it is to get wisdom than gold! And to get understanding is to be chosen above silver. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 16,
          "hasVerseLabel": false,
