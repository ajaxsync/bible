        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "Everyone who is proud in heart is an abomination to the Lord; Assuredly, he will not be unpunished. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": "Everyone who is proud in heart is an abomination to the Lord; Assuredly, he will not be unpunished."
