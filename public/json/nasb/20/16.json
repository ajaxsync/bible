        },
        {
          "verseNum": 12,
          "hasVerseLabel": true,
          "verseText": "It is an abomination for kings to commit wicked acts, For a throne is established on righteousness. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
