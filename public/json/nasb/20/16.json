          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "Better is a little with righteousness Than great income with injustice. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
