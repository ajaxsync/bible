        },
        {
          "verseNum": 13,
          "hasVerseLabel": true,
          "verseText": "He who returns evil for good, Evil will not depart from his house. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": "He who returns evil for good, Evil will not depart from his house."
