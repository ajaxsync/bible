        },
        {
          "verseNum": 11,
          "hasVerseLabel": true,
          "verseText": "A rebellious man seeks only evil, So a cruel messenger will be sent against him. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": false,
          "verseText": "A rebellious man seeks only evil, So a cruel messenger will be sent against him."
