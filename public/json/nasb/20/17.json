        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "He who conceals a transgression seeks love, But he who repeats a matter separates intimate friends. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "He who conceals a transgression seeks love, But he who repeats a matter separates intimate friends."
