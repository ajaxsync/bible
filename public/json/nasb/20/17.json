        },
        {
          "verseNum": 23,
          "hasVerseLabel": true,
          "verseText": "A wicked man receives a bribe from the bosom To pervert the ways of justice. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 23,
          "hasVerseLabel": false,
          "verseText": "A wicked man receives a bribe from the bosom To pervert the ways of justice."
