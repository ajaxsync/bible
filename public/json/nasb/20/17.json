        },
        {
          "verseNum": 24,
          "hasVerseLabel": true,
          "verseText": "Wisdom is in the presence of the one who has understanding, But the eyes of a fool are on the ends of the earth. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 24,
          "hasVerseLabel": false,
          "verseText": "Wisdom is in the presence of the one who has understanding, But the eyes of a fool are on the ends of the earth."
        }
      ]
    },
    {
      "type": "line-quote",
