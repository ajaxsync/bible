          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 16,
          "hasVerseLabel": true,
          "verseText": "Why is there a price in the hand of a fool to buy wisdom, When he has no sense? "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 16,
          "hasVerseLabel": false,
          "verseText": "Why is there a price in the hand of a fool to buy wisdom, When he has no sense?"
