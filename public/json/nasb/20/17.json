          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 28,
          "hasVerseLabel": true,
          "verseText": "Even a fool, when he keeps silent, is considered wise; When he closes his lips, he is considered prudent. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 28,
          "hasVerseLabel": false,
          "verseText": "Even a fool, when he keeps silent, is considered wise; When he closes his lips, he is considered prudent."
