        },
        {
          "verseNum": 12,
          "hasVerseLabel": true,
          "verseText": "Let a man meet a bear robbed of her cubs, Rather than a fool in his folly. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
