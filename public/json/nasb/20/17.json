        },
        {
          "verseNum": 19,
          "hasVerseLabel": true,
          "verseText": "He who loves transgression loves strife; He who raises his door seeks destruction. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 19,
          "hasVerseLabel": false,
          "verseText": "He who loves transgression loves strife; He who raises his door seeks destruction."
