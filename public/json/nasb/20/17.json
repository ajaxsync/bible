          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 20,
          "hasVerseLabel": true,
          "verseText": "He who has a crooked mind finds no good, And he who is perverted in his language falls into evil. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 20,
          "hasVerseLabel": false,
          "verseText": "He who has a crooked mind finds no good, And he who is perverted in his language falls into evil."
