        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "A rebuke goes deeper into one who has understanding Than a hundred blows into a fool. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "A rebuke goes deeper into one who has understanding Than a hundred blows into a fool."
