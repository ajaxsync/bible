        },
        {
          "verseNum": 18,
          "hasVerseLabel": true,
          "verseText": "A man lacking in sense pledges And becomes guarantor in the presence of his neighbor. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 18,
          "hasVerseLabel": false,
