          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "He who mocks the poor taunts his Maker; He who rejoices at calamity will not go unpunished. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": "He who mocks the poor taunts his Maker; He who rejoices at calamity will not go unpunished."
        }
      ]
