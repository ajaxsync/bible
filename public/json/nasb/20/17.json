          "verseNum": 25,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 26,
          "hasVerseLabel": true,
          "verseText": "It is also not good to fine the righteous, Nor to strike the noble for their uprightness. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 26,
          "hasVerseLabel": false,
          "verseText": "It is also not good to fine the righteous, Nor to strike the noble for their uprightness."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 26,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 27,
          "hasVerseLabel": true,
          "verseText": "He who restrains his words has knowledge, And he who has a cool spirit is a man of understanding. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 27,
          "hasVerseLabel": false,
          "verseText": "He who restrains his words has knowledge, And he who has a cool spirit is a man of understanding."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
