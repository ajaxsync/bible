          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "Excellent speech is not fitting for a fool, Much less are lying lips to a prince. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "Excellent speech is not fitting for a fool, Much less are lying lips to a prince."
