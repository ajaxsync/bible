        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "The words of a man’s mouth are deep waters; The fountain of wisdom is a bubbling brook. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
