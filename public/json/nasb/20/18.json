    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "He who separates himself seeks his own desire, He quarrels against all sound wisdom. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
