        },
        {
          "verseNum": 11,
          "hasVerseLabel": true,
          "verseText": "A man’s discretion makes him slow to anger, And it is his glory to overlook a transgression. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
