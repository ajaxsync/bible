          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "The foolishness of man ruins his way, And his heart rages against the Lord. "
        }
      ]
    },
    {
