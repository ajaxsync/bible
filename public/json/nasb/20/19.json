        },
        {
          "verseNum": 17,
          "hasVerseLabel": true,
          "verseText": "One who is gracious to a poor man lends to the Lord, And He will repay him for his good deed. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 17,
