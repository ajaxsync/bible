          "verseText": " "
        },
        {
          "verseNum": 13,
          "hasVerseLabel": true,
          "verseText": "A foolish son is destruction to his father, And the contentions of a wife are a constant dripping. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": "A foolish son is destruction to his father, And the contentions of a wife are a constant dripping."
