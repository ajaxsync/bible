          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "Keeping away from strife is an honor for a man, But any fool will quarrel. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
