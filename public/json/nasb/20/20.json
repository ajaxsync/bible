      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "Wine is a mocker, strong drink a brawler, And whoever is intoxicated by it is not wise. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
