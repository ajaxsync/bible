        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "The sluggard does not plow after the autumn, So he begs during the harvest and has nothing. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
