          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 30,
          "hasVerseLabel": true,
          "verseText": "There is no wisdom and no understanding And no counsel against the Lord. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 30,
          "hasVerseLabel": false,
          "verseText": "There is no wisdom and no understanding And no counsel against the Lord."
        }
      ]
