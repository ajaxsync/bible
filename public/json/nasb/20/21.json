          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 29,
          "hasVerseLabel": true,
          "verseText": "A wicked man displays a bold face, But as for the upright, he makes his way sure. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 29,
          "hasVerseLabel": false,
          "verseText": "A wicked man displays a bold face, But as for the upright, he makes his way sure."
        }
