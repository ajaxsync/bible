        {
          "verseNum": 11,
          "hasVerseLabel": true,
          "verseText": "Be wise, my son, and make my heart glad, That I may reply to him who reproaches me. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": false,
          "verseText": "Be wise, my son, and make my heart glad, That I may reply to him who reproaches me."
