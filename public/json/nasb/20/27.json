        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "Do not forsake your own friend or your father’s friend, And do not go to your brother’s house in the day of your calamity; Better is a neighbor who is near than a brother far away. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
