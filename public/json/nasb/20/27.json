          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "Oil and perfume make the heart glad, So a man’s counsel is sweet to his friend. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "Oil and perfume make the heart glad, So a man’s counsel is sweet to his friend."
