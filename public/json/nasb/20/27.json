        },
        {
          "verseNum": 21,
          "hasVerseLabel": true,
          "verseText": "The crucible is for silver and the furnace for gold, And each is tested by the praise accorded him. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 21,
          "hasVerseLabel": false,
          "verseText": "The crucible is for silver and the furnace for gold, And each is tested by the praise accorded him."
