        },
        {
          "verseNum": 13,
          "hasVerseLabel": true,
          "verseText": "Take his garment when he becomes surety for a stranger; And for an adulterous woman hold him in pledge. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": "Take his garment when he becomes surety for a stranger; And for an adulterous woman hold him in pledge."
