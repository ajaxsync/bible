        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "Better is the poor who walks in his integrity Than he who is crooked though he be rich. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": "Better is the poor who walks in his integrity Than he who is crooked though he be rich."
