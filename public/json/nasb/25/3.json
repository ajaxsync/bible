          "verseNum": 64,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 65,
          "hasVerseLabel": true,
          "verseText": "You will give them hardness of heart, Your curse will be on them. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 65,
          "hasVerseLabel": false,
