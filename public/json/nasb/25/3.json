      "type": "line-quote",
      "contents": [
        {
          "verseNum": 60,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 61,
          "hasVerseLabel": true,
          "verseText": "You have heard their reproach, O Lord, All their schemes against me. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 61,
          "hasVerseLabel": false,
          "verseText": "You have heard their reproach, O Lord, All their schemes against me."
