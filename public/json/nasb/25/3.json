{
  "book": 25,
  "chapter": 3,
  "sections": [
    {
      "type": "heading",
      "heading": "刑罰、悔改、希望"
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "I am the man who has seen affliction Because of the rod of His wrath. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "I am the man who has seen affliction Because of the rod of His wrath."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "He has driven me and made me walk In darkness and not in light. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": "He has driven me and made me walk In darkness and not in light."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "Surely against me He has turned His hand Repeatedly all the day. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "He has caused my flesh and my skin to waste away, He has broken my bones. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "He has caused my flesh and my skin to waste away, He has broken my bones. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "He has besieged and encompassed me with bitterness and hardship. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "He has besieged and encompassed me with bitterness and hardship. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "In dark places He has made me dwell, Like those who have long been dead. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": "In dark places He has made me dwell, Like those who have long been dead."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "He has walled me in so that I cannot go out; He has made my chain heavy. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "He has walled me in so that I cannot go out; He has made my chain heavy."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "Even when I cry out and call for help, He shuts out my prayer. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": "Even when I cry out and call for help, He shuts out my prayer."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "He has blocked my ways with hewn stone; He has made my paths crooked. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "He has blocked my ways with hewn stone; He has made my paths crooked."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "He is to me like a bear lying in wait, Like a lion in secret places. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "He is to me like a bear lying in wait, Like a lion in secret places."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 11,
          "hasVerseLabel": true,
          "verseText": "He has turned aside my ways and torn me to pieces; He has made me desolate. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": false,
          "verseText": "He has turned aside my ways and torn me to pieces; He has made me desolate."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 12,
          "hasVerseLabel": true,
          "verseText": "He bent His bow And set me as a target for the arrow. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 13,
          "hasVerseLabel": true,
          "verseText": "He made the arrows of His quiver To enter into my inward parts. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 14,
          "hasVerseLabel": true,
          "verseText": "I have become a laughingstock to all my people, Their mocking song all the day. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": "I have become a laughingstock to all my people, Their mocking song all the day."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 15,
          "hasVerseLabel": true,
          "verseText": "He has filled me with bitterness, He has made me drunk with wormwood. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 16,
          "hasVerseLabel": true,
          "verseText": "He has broken my teeth with gravel; He has made me cower in the dust. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 16,
          "hasVerseLabel": false,
          "verseText": "He has broken my teeth with gravel; He has made me cower in the dust."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 16,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 17,
          "hasVerseLabel": true,
          "verseText": "My soul has been rejected from peace; I have forgotten happiness. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 17,
          "hasVerseLabel": false,
          "verseText": "My soul has been rejected from peace; I have forgotten happiness."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 17,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 18,
          "hasVerseLabel": true,
          "verseText": "So I say, “My strength has perished, And so has my hope from the Lord.” "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 18,
          "hasVerseLabel": false,
          "verseText": "So I say, “My strength has perished, And so has my hope from the Lord.”"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 18,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 19,
          "hasVerseLabel": true,
          "verseText": "Remember my affliction and my wandering, the wormwood and bitterness. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 19,
          "hasVerseLabel": false,
          "verseText": "Remember my affliction and my wandering, the wormwood and bitterness."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 19,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 20,
          "hasVerseLabel": true,
          "verseText": "Surely my soul remembers And is bowed down within me. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 20,
          "hasVerseLabel": false,
          "verseText": "Surely my soul remembers And is bowed down within me."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 20,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 21,
          "hasVerseLabel": true,
          "verseText": "This I recall to my mind, Therefore I have hope. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 21,
          "hasVerseLabel": false,
          "verseText": "This I recall to my mind, Therefore I have hope."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 21,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 22,
          "hasVerseLabel": true,
          "verseText": "The Lord’s lovingkindnesses indeed never cease, For His compassions never fail. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 22,
          "hasVerseLabel": false,
          "verseText": "The Lord’s lovingkindnesses indeed never cease, For His compassions never fail."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 22,
          "hasVerseLabel": false,
          "verseText": "The Lord’s lovingkindnesses indeed never cease, For His compassions never fail."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 22,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 23,
          "hasVerseLabel": true,
          "verseText": "They are new every morning; Great is Your faithfulness. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 23,
          "hasVerseLabel": false,
          "verseText": "They are new every morning; Great is Your faithfulness."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 23,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 24,
          "hasVerseLabel": true,
          "verseText": "“The Lord is my portion,” says my soul, “Therefore I have hope in Him.” "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 24,
          "hasVerseLabel": false,
          "verseText": "“The Lord is my portion,” says my soul, “Therefore I have hope in Him.”"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 24,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 25,
          "hasVerseLabel": true,
          "verseText": "The Lord is good to those who wait for Him, To the person who seeks Him. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 25,
          "hasVerseLabel": false,
          "verseText": "The Lord is good to those who wait for Him, To the person who seeks Him."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 25,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 26,
          "hasVerseLabel": true,
          "verseText": "It is good that he waits silently For the salvation of the Lord. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 26,
          "hasVerseLabel": false,
          "verseText": "It is good that he waits silently For the salvation of the Lord."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 26,
          "hasVerseLabel": false,
          "verseText": "It is good that he waits silently For the salvation of the Lord."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 26,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 27,
          "hasVerseLabel": true,
          "verseText": "It is good for a man that he should bear The yoke in his youth. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 27,
          "hasVerseLabel": false,
          "verseText": "It is good for a man that he should bear The yoke in his youth."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 27,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 28,
          "hasVerseLabel": true,
          "verseText": "Let him sit alone and be silent Since He has laid it on him. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 28,
          "hasVerseLabel": false,
          "verseText": "Let him sit alone and be silent Since He has laid it on him."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 28,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 29,
          "hasVerseLabel": true,
          "verseText": "Let him put his mouth in the dust, Perhaps there is hope. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 29,
          "hasVerseLabel": false,
          "verseText": "Let him put his mouth in the dust, Perhaps there is hope."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 29,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 30,
          "hasVerseLabel": true,
          "verseText": "Let him give his cheek to the smiter, Let him be filled with reproach. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 30,
          "hasVerseLabel": false,
          "verseText": "Let him give his cheek to the smiter, Let him be filled with reproach."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 30,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 31,
          "hasVerseLabel": true,
          "verseText": "For the Lord will not reject forever, "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 31,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 32,
          "hasVerseLabel": true,
          "verseText": "For if He causes grief, Then He will have compassion According to His abundant lovingkindness. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 32,
          "hasVerseLabel": false,
          "verseText": "For if He causes grief, Then He will have compassion According to His abundant lovingkindness."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 32,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 33,
          "hasVerseLabel": true,
          "verseText": "For He does not afflict willingly Or grieve the sons of men. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 33,
          "hasVerseLabel": false,
          "verseText": "For He does not afflict willingly Or grieve the sons of men."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 33,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 34,
          "hasVerseLabel": true,
          "verseText": "To crush under His feet All the prisoners of the land, "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 34,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 35,
          "hasVerseLabel": true,
          "verseText": "To deprive a man of justice In the presence of the Most High, "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 35,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 36,
          "hasVerseLabel": true,
          "verseText": "To defraud a man in his lawsuit— Of these things the Lord does not approve. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 36,
          "hasVerseLabel": false,
          "verseText": "To defraud a man in his lawsuit— Of these things the Lord does not approve."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 36,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 37,
          "hasVerseLabel": true,
          "verseText": "Who is there who speaks and it comes to pass, Unless the Lord has commanded it? "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 37,
          "hasVerseLabel": false,
          "verseText": "Who is there who speaks and it comes to pass, Unless the Lord has commanded it?"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 37,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 38,
          "hasVerseLabel": true,
          "verseText": "Is it not from the mouth of the Most High That both good and ill go forth? "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 38,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 39,
          "hasVerseLabel": true,
          "verseText": "Why should any living mortal, or any man, Offer complaint in view of his sins? "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 39,
          "hasVerseLabel": false,
          "verseText": "Why should any living mortal, or any man, Offer complaint in view of his sins?"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 39,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 40,
          "hasVerseLabel": true,
          "verseText": "Let us examine and probe our ways, And let us return to the Lord. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 40,
          "hasVerseLabel": false,
          "verseText": "Let us examine and probe our ways, And let us return to the Lord."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 40,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 41,
          "hasVerseLabel": true,
          "verseText": "We lift up our heart and hands Toward God in heaven; "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 41,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 42,
          "hasVerseLabel": true,
          "verseText": "We have transgressed and rebelled, You have not pardoned. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 42,
          "hasVerseLabel": false,
          "verseText": "We have transgressed and rebelled, You have not pardoned."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 42,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 43,
          "hasVerseLabel": true,
          "verseText": "You have covered Yourself with anger And pursued us; You have slain and have not spared. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 43,
          "hasVerseLabel": false,
          "verseText": "You have covered Yourself with anger And pursued us; You have slain and have not spared."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 43,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 44,
          "hasVerseLabel": true,
          "verseText": "You have covered Yourself with a cloud So that no prayer can pass through. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 44,
          "hasVerseLabel": false,
          "verseText": "You have covered Yourself with a cloud So that no prayer can pass through."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 44,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 45,
          "hasVerseLabel": true,
          "verseText": "You have made us mere offscouring and refuse In the midst of the peoples. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 45,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 46,
          "hasVerseLabel": true,
          "verseText": "All our enemies have opened their mouths against us. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 46,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 47,
          "hasVerseLabel": true,
          "verseText": "Panic and pitfall have befallen us, Devastation and destruction; "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 47,
          "hasVerseLabel": false,
          "verseText": "Panic and pitfall have befallen us, Devastation and destruction;"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 47,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 48,
          "hasVerseLabel": true,
          "verseText": "My eyes run down with streams of water Because of the destruction of the daughter of my people. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 48,
          "hasVerseLabel": false,
          "verseText": "My eyes run down with streams of water Because of the destruction of the daughter of my people."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 48,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 49,
          "hasVerseLabel": true,
          "verseText": "My eyes pour down unceasingly, Without stopping, "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 49,
          "hasVerseLabel": false,
          "verseText": "My eyes pour down unceasingly, Without stopping,"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 49,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 50,
          "hasVerseLabel": true,
          "verseText": "Until the Lord looks down And sees from heaven. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 50,
          "hasVerseLabel": false,
          "verseText": "Until the Lord looks down And sees from heaven."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 50,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 51,
          "hasVerseLabel": true,
          "verseText": "My eyes bring pain to my soul Because of all the daughters of my city. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 51,
          "hasVerseLabel": false,
          "verseText": "My eyes bring pain to my soul Because of all the daughters of my city."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 51,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 52,
          "hasVerseLabel": true,
          "verseText": "My enemies without cause Hunted me down like a bird; "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 52,
          "hasVerseLabel": false,
          "verseText": "My enemies without cause Hunted me down like a bird;"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 52,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 53,
          "hasVerseLabel": true,
          "verseText": "They have silenced me in the pit And have placed a stone on me. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 53,
          "hasVerseLabel": false,
          "verseText": "They have silenced me in the pit And have placed a stone on me."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 53,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 54,
          "hasVerseLabel": true,
          "verseText": "Waters flowed over my head; I said, “I am cut off!” "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 54,
          "hasVerseLabel": false,
          "verseText": "Waters flowed over my head; I said, “I am cut off!”"
