      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 54,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 55,
          "hasVerseLabel": true,
          "verseText": "I called on Your name, O Lord, Out of the lowest pit. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 55,
          "hasVerseLabel": false,
          "verseText": "I called on Your name, O Lord, Out of the lowest pit."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 55,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 56,
          "hasVerseLabel": true,
          "verseText": "You have heard my voice, “Do not hide Your ear from my prayer for relief, From my cry for help.” "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 56,
          "hasVerseLabel": false,
          "verseText": "You have heard my voice, “Do not hide Your ear from my prayer for relief, From my cry for help.”"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 56,
          "hasVerseLabel": false,
          "verseText": "You have heard my voice, “Do not hide Your ear from my prayer for relief, From my cry for help.”"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 56,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 57,
          "hasVerseLabel": true,
          "verseText": "You drew near when I called on You; You said, “Do not fear!” "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 57,
          "hasVerseLabel": false,
          "verseText": "You drew near when I called on You; You said, “Do not fear!”"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 57,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 58,
          "hasVerseLabel": true,
          "verseText": "O Lord, You have pleaded my soul’s cause; You have redeemed my life. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 58,
          "hasVerseLabel": false,
          "verseText": "O Lord, You have pleaded my soul’s cause; You have redeemed my life."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 58,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 59,
          "hasVerseLabel": true,
          "verseText": "O Lord, You have seen my oppression; Judge my case. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 59,
          "hasVerseLabel": false,
          "verseText": "O Lord, You have seen my oppression; Judge my case."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 59,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 60,
          "hasVerseLabel": true,
          "verseText": "You have seen all their vengeance, All their schemes against me. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 60,
          "hasVerseLabel": false,
          "verseText": "You have seen all their vengeance, All their schemes against me."
