          "verseNum": 62,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 63,
          "hasVerseLabel": true,
          "verseText": "Look on their sitting and their rising; I am their mocking song. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 63,
          "hasVerseLabel": false,
          "verseText": "Look on their sitting and their rising; I am their mocking song."
