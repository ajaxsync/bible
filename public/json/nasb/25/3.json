          "verseNum": 63,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 64,
          "hasVerseLabel": true,
          "verseText": "You will recompense them, O Lord, According to the work of their hands. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 64,
          "hasVerseLabel": false,
          "verseText": "You will recompense them, O Lord, According to the work of their hands."
