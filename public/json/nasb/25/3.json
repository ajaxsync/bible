      "type": "line-quote",
      "contents": [
        {
          "verseNum": 61,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 62,
          "hasVerseLabel": true,
          "verseText": "The lips of my assailants and their whispering Are against me all day long. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 62,
          "hasVerseLabel": false,
          "verseText": "The lips of my assailants and their whispering Are against me all day long."
