          "verseText": " "
        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "“I called to the Lord, who is worthy of praise, and have been saved from my enemies. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": "“I called to the Lord, who is worthy of praise, and have been saved from my enemies."
