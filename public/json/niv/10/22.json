    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "The cords of the grave coiled around me; the snares of death confronted me. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": "The cords of the grave coiled around me; the snares of death confronted me."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "“In my distress I called to the Lord; I called out to my God. From his temple he heard my voice; my cry came to his ears. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "“In my distress I called to the Lord; I called out to my God. From his temple he heard my voice; my cry came to his ears."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "“In my distress I called to the Lord; I called out to my God. From his temple he heard my voice; my cry came to his ears."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "“In my distress I called to the Lord; I called out to my God. From his temple he heard my voice; my cry came to his ears."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
