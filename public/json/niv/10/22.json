    {
      "type": "paragraph",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "David sang to the Lord the words of this song when the Lord delivered him from the hand of all his enemies and from the hand of Saul. "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "He said: “The Lord is my rock, my fortress and my deliverer; "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": "He said: “The Lord is my rock, my fortress and my deliverer;"
        }
      ]
    },
