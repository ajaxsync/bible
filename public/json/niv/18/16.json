      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": "his archers surround me. Without pity, he pierces my kidneys and spills my gall on the ground."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": "his archers surround me. Without pity, he pierces my kidneys and spills my gall on the ground."
        }
      ]
    },
    {
