          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 12,
          "hasVerseLabel": true,
          "verseText": "All was well with me, but he shattered me; he seized me by the neck and crushed me. He has made me his target; "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": "All was well with me, but he shattered me; he seized me by the neck and crushed me. He has made me his target;"
        }
