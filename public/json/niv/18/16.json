        },
        {
          "verseNum": 15,
          "hasVerseLabel": true,
          "verseText": "“I have sewed sackcloth over my skin and buried my brow in the dust. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": "“I have sewed sackcloth over my skin and buried my brow in the dust."
