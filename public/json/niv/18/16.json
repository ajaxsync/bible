          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "God assails me and tears me in his anger and gnashes his teeth at me; my opponent fastens on me his piercing eyes. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "God assails me and tears me in his anger and gnashes his teeth at me; my opponent fastens on me his piercing eyes."
