  "sections": [
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "My spirit is broken, my days are cut short, the grave awaits me. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "My spirit is broken, my days are cut short, the grave awaits me."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
