          "verseNum": 16,
          "hasVerseLabel": true,
          "verseText": "“If I have denied the desires of the poor or let the eyes of the widow grow weary, "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 16,
          "hasVerseLabel": false,
