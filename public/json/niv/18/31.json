          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 13,
          "hasVerseLabel": true,
          "verseText": "“If I have denied justice to any of my servants, whether male or female, when they had a grievance against me, "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": "“If I have denied justice to any of my servants, whether male or female, when they had a grievance against me,"
        }
