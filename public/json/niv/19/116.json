          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 16,
          "hasVerseLabel": true,
          "verseText": "Truly I am your servant, Lord; I serve you just as my mother did; you have freed me from my chains. "
        }
      ]
    },
    {
