          "verseNum": 24,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 25,
          "hasVerseLabel": true,
          "verseText": "Lord, save us! Lord, grant us success! "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 25,
          "hasVerseLabel": false,
          "verseText": "Lord, save us! Lord, grant us success!"
