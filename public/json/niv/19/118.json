  "sections": [
    {
      "type": "heading",
      "heading": "因勝利而稱謝耶和華"
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "Give thanks to the Lord, for he is good; his love endures forever. "
        }
      ]
