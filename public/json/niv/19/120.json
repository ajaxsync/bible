    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "I call on the Lord in my distress, and he answers me. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "I call on the Lord in my distress, and he answers me."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "Save me, Lord, from lying lips and from deceitful tongues. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "What will he do to you, and what more besides, you deceitful tongue? "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": "What will he do to you, and what more besides, you deceitful tongue?"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "He will punish you with a warrior’s sharp arrows, with burning coals of the broom bush. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "Woe to me that I dwell in Meshek, that I live among the tents of Kedar! "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": "Woe to me that I dwell in Meshek, that I live among the tents of Kedar!"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "Too long have I lived among those who hate peace. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "I am for peace; but when I speak, they are for war. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "I am for peace; but when I speak, they are for war."
        }
      ]
    }
  ]
