          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "Our help is in the name of the Lord, the Maker of heaven and earth. "
        }
      ]
    },
    {
