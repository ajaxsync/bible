          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "He sent his signs and wonders into your midst, Egypt, against Pharaoh and all his servants. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "He sent his signs and wonders into your midst, Egypt, against Pharaoh and all his servants."
