          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "He makes clouds rise from the ends of the earth; he sends lightning with the rain and brings out the wind from his storehouses. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "He makes clouds rise from the ends of the earth; he sends lightning with the rain and brings out the wind from his storehouses."
        }
      ]
    },
