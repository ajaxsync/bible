          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "He struck down the firstborn of Egypt, the firstborn of people and animals. "
        }
      ]
    },
    {
