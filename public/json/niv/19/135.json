        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "The Lord does whatever pleases him, in the heavens and on the earth, in the seas and all their depths. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": "The Lord does whatever pleases him, in the heavens and on the earth, in the seas and all their depths."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": "The Lord does whatever pleases him, in the heavens and on the earth, in the seas and all their depths."
        }
      ]
