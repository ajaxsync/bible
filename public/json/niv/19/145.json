        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "Every day I will praise you and extol your name for ever and ever. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
