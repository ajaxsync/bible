          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "They speak of the glorious splendor of your majesty— and I will meditate on your wonderful works. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": "They speak of the glorious splendor of your majesty— and I will meditate on your wonderful works."
