        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "Let Israel rejoice in their Maker; let the people of Zion be glad in their King. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
