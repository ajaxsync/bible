    {
      "type": "heading",
      "heading": "求助的晨禱"
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "Lord, how many are my foes! How many rise up against me! "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
