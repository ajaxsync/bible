          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 11,
          "hasVerseLabel": true,
          "verseText": "You turned my wailing into dancing; you removed my sackcloth and clothed me with joy, "
        }
