          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "You, Lord, brought me up from the realm of the dead; you spared me from going down to the pit. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": "You, Lord, brought me up from the realm of the dead; you spared me from going down to the pit."
