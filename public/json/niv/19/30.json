          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "For his anger lasts only a moment, but his favor lasts a lifetime; weeping may stay for the night, but rejoicing comes in the morning. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": "For his anger lasts only a moment, but his favor lasts a lifetime; weeping may stay for the night, but rejoicing comes in the morning."
        }
      ]
    },
    {
