        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "Fear the Lord, you his holy people, for those who fear him lack nothing. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "Fear the Lord, you his holy people, for those who fear him lack nothing."
