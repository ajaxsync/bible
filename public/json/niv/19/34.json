          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 16,
          "hasVerseLabel": true,
          "verseText": "but the face of the Lord is against those who do evil, to blot out their name from the earth. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
