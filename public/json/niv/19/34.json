          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 15,
          "hasVerseLabel": true,
          "verseText": "The eyes of the Lord are on the righteous, and his ears are attentive to their cry; "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": "The eyes of the Lord are on the righteous, and his ears are attentive to their cry;"
