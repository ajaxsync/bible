          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "Continue your love to those who know you, your righteousness to the upright in heart. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
