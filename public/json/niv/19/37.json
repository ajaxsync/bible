        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "Be still before the Lord and wait patiently for him; do not fret when people succeed in their ways, when they carry out their wicked schemes. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
