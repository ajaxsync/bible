  "sections": [
    {
      "type": "heading",
      "heading": "求主保護"
    },
    {
      "type": "desc",
      "contents": []
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "We have heard it with our ears, O God; our ancestors have told us what you did in their days, in days long ago. "
        }
      ]
