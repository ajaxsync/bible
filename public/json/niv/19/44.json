          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "With your hand you drove out the nations and planted our ancestors; you crushed the peoples and made our ancestors flourish. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": "With your hand you drove out the nations and planted our ancestors; you crushed the peoples and made our ancestors flourish."
        }
