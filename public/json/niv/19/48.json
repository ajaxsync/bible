        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "Within your temple, O God, we meditate on your unfailing love. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "Like your name, O God, your praise reaches to the ends of the earth; your right hand is filled with righteousness. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "Like your name, O God, your praise reaches to the ends of the earth; your right hand is filled with righteousness."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 11,
          "hasVerseLabel": true,
          "verseText": "Mount Zion rejoices, the villages of Judah are glad because of your judgments. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": true,
          "verseText": "Mount Zion rejoices, the villages of Judah are glad because of your judgments. "
