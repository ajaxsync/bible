          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "Before your pots can feel the heat of the thorns— whether they be green or dry—the wicked will be swept away. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "Before your pots can feel the heat of the thorns— whether they be green or dry—the wicked will be swept away."
