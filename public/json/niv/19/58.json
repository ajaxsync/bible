        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "The righteous will be glad when they are avenged, when they dip their feet in the blood of the wicked. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "The righteous will be glad when they are avenged, when they dip their feet in the blood of the wicked."
