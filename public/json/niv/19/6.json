        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "All my enemies will be overwhelmed with shame and anguish; they will turn back and suddenly be put to shame. "
        }
      ]
    },
    {
      "type": "line-quote",
