          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "Gilead is mine, and Manasseh is mine; Ephraim is my helmet, Judah is my scepter. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "Gilead is mine, and Manasseh is mine; Ephraim is my helmet, Judah is my scepter."
        }
