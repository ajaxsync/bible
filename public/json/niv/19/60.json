        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "God has spoken from his sanctuary: “In triumph I will parcel out Shechem and measure off the Valley of Sukkoth. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": "God has spoken from his sanctuary: “In triumph I will parcel out Shechem and measure off the Valley of Sukkoth."
