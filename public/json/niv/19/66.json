          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 20,
          "hasVerseLabel": true,
          "verseText": "Praise be to God, who has not rejected my prayer or withheld his love from me! "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 20,
          "hasVerseLabel": false,
          "verseText": "Praise be to God, who has not rejected my prayer or withheld his love from me!"
        }
      ]
    },
