          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "Arise, Lord, in your anger; rise up against the rage of my enemies. Awake, my God; decree justice. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": "Arise, Lord, in your anger; rise up against the rage of my enemies. Awake, my God; decree justice."
        }
