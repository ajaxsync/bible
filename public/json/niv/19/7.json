    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "then let my enemy pursue and overtake me; let him trample my life to the ground and make me sleep in the dust. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": "then let my enemy pursue and overtake me; let him trample my life to the ground and make me sleep in the dust."
        }
