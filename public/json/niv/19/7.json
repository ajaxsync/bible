          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "Let the Lord judge the peoples. Vindicate me, Lord, according to my righteousness, according to my integrity, O Most High. "
        }
      ]
    },
