          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "Do not lift your horns against heaven; do not speak so defiantly.’ ” "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
