  "sections": [
    {
      "type": "heading",
      "heading": "神是勝利者"
    },
    {
      "type": "desc",
      "contents": []
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "God is renowned in Judah; in Israel his name is great. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "God is renowned in Judah; in Israel his name is great."
