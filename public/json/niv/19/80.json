        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "How long, Lord God Almighty, will your anger smolder against the prayers of your people? "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
