          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "You have made us an object of derision to our neighbors, and our enemies mock us. "
        }
      ]
    },
    {
