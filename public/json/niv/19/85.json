{
  "book": 19,
  "chapter": 85,
  "sections": [
    {
      "type": "heading",
      "heading": "為國求福"
    },
    {
      "type": "desc",
      "contents": []
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "You, Lord, showed favor to your land; you restored the fortunes of Jacob. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
