          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "I will listen to what God the Lord says; he promises peace to his people, his faithful servants— but let them not turn to folly. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": "I will listen to what God the Lord says; he promises peace to his people, his faithful servants— but let them not turn to folly."
        }
      ]
    },
