          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "You have taken from me my closest friends and have made me repulsive to them. I am confined and cannot escape; "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": "You have taken from me my closest friends and have made me repulsive to them. I am confined and cannot escape;"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": "You have taken from me my closest friends and have made me repulsive to them. I am confined and cannot escape;"
