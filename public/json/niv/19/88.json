        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "my eyes are dim with grief. I call to you, Lord, every day; I spread out my hands to you. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "my eyes are dim with grief. I call to you, Lord, every day; I spread out my hands to you."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "Do you show your wonders to the dead? Do their spirits rise up and praise you? "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "Do you show your wonders to the dead? Do their spirits rise up and praise you?"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 11,
          "hasVerseLabel": true,
          "verseText": "Is your love declared in the grave, your faithfulness in Destruction? "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": false,
          "verseText": "Is your love declared in the grave, your faithfulness in Destruction?"
