          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "I am set apart with the dead, like the slain who lie in the grave, whom you remember no more, who are cut off from your care. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": "I am set apart with the dead, like the slain who lie in the grave, whom you remember no more, who are cut off from your care."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": "I am set apart with the dead, like the slain who lie in the grave, whom you remember no more, who are cut off from your care."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": "I am set apart with the dead, like the slain who lie in the grave, whom you remember no more, who are cut off from your care."
