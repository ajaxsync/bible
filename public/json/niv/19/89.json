          "verseNum": 39,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 40,
          "hasVerseLabel": true,
          "verseText": "You have broken through all his walls and reduced his strongholds to ruins. "
        }
