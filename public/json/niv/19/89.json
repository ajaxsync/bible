          "verseNum": 49,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 50,
          "hasVerseLabel": true,
          "verseText": "Remember, Lord, how your servant has been mocked, how I bear in my heart the taunts of all the nations, "
        }
