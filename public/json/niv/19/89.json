    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 38,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 39,
          "hasVerseLabel": true,
          "verseText": "You have renounced the covenant with your servant and have defiled his crown in the dust. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
