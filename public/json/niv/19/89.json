          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "The heavens praise your wonders, Lord, your faithfulness too, in the assembly of the holy ones. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": "The heavens praise your wonders, Lord, your faithfulness too, in the assembly of the holy ones."
        }
