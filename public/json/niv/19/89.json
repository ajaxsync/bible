          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 49,
          "hasVerseLabel": true,
          "verseText": "Lord, where is your former great love, which in your faithfulness you swore to David? "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 49,
          "hasVerseLabel": false,
