          "verseNum": 47,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 48,
          "hasVerseLabel": true,
          "verseText": "Who can live and not see death, or who can escape the power of the grave? "
        }
      ]
    },
