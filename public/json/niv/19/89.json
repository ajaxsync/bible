          "verseText": " "
        },
        {
          "verseNum": 43,
          "hasVerseLabel": true,
          "verseText": "Indeed, you have turned back the edge of his sword and have not supported him in battle. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 43,
          "hasVerseLabel": false,
