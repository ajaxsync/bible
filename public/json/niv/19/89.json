        },
        {
          "verseNum": 47,
          "hasVerseLabel": true,
          "verseText": "Remember how fleeting is my life. For what futility you have created all humanity! "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 47,
          "hasVerseLabel": false,
          "verseText": "Remember how fleeting is my life. For what futility you have created all humanity!"
