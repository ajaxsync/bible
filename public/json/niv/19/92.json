        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "For surely your enemies, Lord, surely your enemies will perish; all evildoers will be scattered. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
