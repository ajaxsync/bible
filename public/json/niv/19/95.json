{
  "book": 19,
  "chapter": 95,
  "sections": [
    {
      "type": "heading",
      "heading": "頌讚之詩"
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "Come, let us sing for joy to the Lord; let us shout aloud to the Rock of our salvation. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "Come, let us sing for joy to the Lord; let us shout aloud to the Rock of our salvation."
        }
