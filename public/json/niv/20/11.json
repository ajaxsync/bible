        },
        {
          "verseNum": 15,
          "hasVerseLabel": true,
          "verseText": "Whoever puts up security for a stranger will surely suffer, but whoever refuses to shake hands in pledge is safe. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 15,
          "hasVerseLabel": false,
