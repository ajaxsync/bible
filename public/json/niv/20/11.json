          "verseText": " "
        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "When the righteous prosper, the city rejoices; when the wicked perish, there are shouts of joy. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "When the righteous prosper, the city rejoices; when the wicked perish, there are shouts of joy."
