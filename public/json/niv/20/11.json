          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 22,
          "hasVerseLabel": true,
          "verseText": "Like a gold ring in a pig’s snout is a beautiful woman who shows no discretion. "
        }
      ]
    },
