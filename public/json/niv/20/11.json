        },
        {
          "verseNum": 11,
          "hasVerseLabel": true,
          "verseText": "Through the blessing of the upright a city is exalted, but by the mouth of the wicked it is destroyed. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": false,
          "verseText": "Through the blessing of the upright a city is exalted, but by the mouth of the wicked it is destroyed."
