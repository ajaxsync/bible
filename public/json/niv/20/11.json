          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "The integrity of the upright guides them, but the unfaithful are destroyed by their duplicity. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": "The integrity of the upright guides them, but the unfaithful are destroyed by their duplicity."
