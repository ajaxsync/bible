          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "With their mouths the godless destroy their neighbors, but through knowledge the righteous escape. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "With their mouths the godless destroy their neighbors, but through knowledge the righteous escape."
