        {
          "verseNum": 19,
          "hasVerseLabel": true,
          "verseText": "Truly the righteous attain life, but whoever pursues evil finds death. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 19,
          "hasVerseLabel": false,
          "verseText": "Truly the righteous attain life, but whoever pursues evil finds death."
