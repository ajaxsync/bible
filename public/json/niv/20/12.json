          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 25,
          "hasVerseLabel": true,
          "verseText": "Anxiety weighs down the heart, but a kind word cheers it up. "
        }
      ]
    },
    {
