          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 20,
          "hasVerseLabel": true,
          "verseText": "Deceit is in the hearts of those who plot evil, but those who promote peace have joy. "
        }
      ]
    },
