      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "The righteous care for the needs of their animals, but the kindest acts of the wicked are cruel. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "The righteous care for the needs of their animals, but the kindest acts of the wicked are cruel."
        }
      ]
    },
