          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 14,
          "hasVerseLabel": true,
          "verseText": "From the fruit of their lips people are filled with good things, and the work of their hands brings them reward. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": "From the fruit of their lips people are filled with good things, and the work of their hands brings them reward."
