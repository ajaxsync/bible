          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 11,
          "hasVerseLabel": true,
          "verseText": "Honest scales and balances belong to the Lord; all the weights in the bag are of his making. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": false,
          "verseText": "Honest scales and balances belong to the Lord; all the weights in the bag are of his making."
        }
