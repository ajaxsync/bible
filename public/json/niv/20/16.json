          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 20,
          "hasVerseLabel": true,
          "verseText": "Whoever gives heed to instruction prospers, and blessed is the one who trusts in the Lord. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 20,
          "hasVerseLabel": false,
          "verseText": "Whoever gives heed to instruction prospers, and blessed is the one who trusts in the Lord."
