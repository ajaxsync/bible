          "verseText": " "
        },
        {
          "verseNum": 27,
          "hasVerseLabel": true,
          "verseText": "A scoundrel plots evil, and on their lips it is like a scorching fire. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 27,
          "hasVerseLabel": false,
          "verseText": "A scoundrel plots evil, and on their lips it is like a scorching fire."
