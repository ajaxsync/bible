      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 14,
          "hasVerseLabel": true,
          "verseText": "A king’s wrath is a messenger of death, but the wise will appease it. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": "A king’s wrath is a messenger of death, but the wise will appease it."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
