          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 13,
          "hasVerseLabel": true,
          "verseText": "Kings take pleasure in honest lips; they value the one who speaks what is right. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": "Kings take pleasure in honest lips; they value the one who speaks what is right."
        }
      ]
    },
    {
