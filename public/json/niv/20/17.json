          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 26,
          "hasVerseLabel": true,
          "verseText": "If imposing a fine on the innocent is not good, surely to flog honest officials is not right. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 26,
          "hasVerseLabel": false,
          "verseText": "If imposing a fine on the innocent is not good, surely to flog honest officials is not right."
        }
      ]
