          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 20,
          "hasVerseLabel": true,
          "verseText": "One whose heart is corrupt does not prosper; one whose tongue is perverse falls into trouble. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 20,
          "hasVerseLabel": false,
          "verseText": "One whose heart is corrupt does not prosper; one whose tongue is perverse falls into trouble."
