          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "The crucible for silver and the furnace for gold, but the Lord tests the heart. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": "The crucible for silver and the furnace for gold, but the Lord tests the heart."
        }
      ]
    },
