          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 12,
          "hasVerseLabel": true,
          "verseText": "Better to meet a bear robbed of her cubs than a fool bent on folly. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": "Better to meet a bear robbed of her cubs than a fool bent on folly."
        }
      ]
    },
