          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 14,
          "hasVerseLabel": true,
          "verseText": "Starting a quarrel is like breaching a dam; so drop the matter before a dispute breaks out. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": "Starting a quarrel is like breaching a dam; so drop the matter before a dispute breaks out."
        }
