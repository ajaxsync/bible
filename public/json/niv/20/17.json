          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 24,
          "hasVerseLabel": true,
          "verseText": "A discerning person keeps wisdom in view, but a fool’s eyes wander to the ends of the earth. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 24,
          "hasVerseLabel": false,
          "verseText": "A discerning person keeps wisdom in view, but a fool’s eyes wander to the ends of the earth."
