          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 15,
          "hasVerseLabel": true,
          "verseText": "Acquitting the guilty and condemning the innocent— the Lord detests them both. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": "Acquitting the guilty and condemning the innocent— the Lord detests them both."
        }
      ]
    },
