          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "Whoever would foster love covers over an offense, but whoever repeats the matter separates close friends. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "Whoever would foster love covers over an offense, but whoever repeats the matter separates close friends."
