        },
        {
          "verseNum": 19,
          "hasVerseLabel": true,
          "verseText": "Whoever loves a quarrel loves sin; whoever builds a high gate invites destruction. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 19,
          "hasVerseLabel": false,
          "verseText": "Whoever loves a quarrel loves sin; whoever builds a high gate invites destruction."
