          "verseNum": 26,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 27,
          "hasVerseLabel": true,
          "verseText": "The one who has knowledge uses words with restraint, and whoever has understanding is even-tempered. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 27,
          "hasVerseLabel": false,
          "verseText": "The one who has knowledge uses words with restraint, and whoever has understanding is even-tempered."
        }
      ]
    },
