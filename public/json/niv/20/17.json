      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 13,
          "hasVerseLabel": true,
          "verseText": "Evil will never leave the house of one who pays back evil for good. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": "Evil will never leave the house of one who pays back evil for good."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
