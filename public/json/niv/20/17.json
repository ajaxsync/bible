          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 21,
          "hasVerseLabel": true,
          "verseText": "To have a fool for a child brings grief; there is no joy for the parent of a godless fool. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 21,
          "hasVerseLabel": false,
          "verseText": "To have a fool for a child brings grief; there is no joy for the parent of a godless fool."
