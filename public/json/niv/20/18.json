        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "It is not good to be partial to the wicked and so deprive the innocent of justice. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
