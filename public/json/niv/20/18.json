          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "Fools find no pleasure in understanding but delight in airing their own opinions. "
        }
      ]
    },
    {
