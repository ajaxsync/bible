    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "An unfriendly person pursues selfish ends and against all sound judgment starts quarrels. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
