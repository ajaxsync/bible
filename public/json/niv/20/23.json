      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "for he is the kind of person who is always thinking about the cost. “Eat and drink,” he says to you, but his heart is not with you. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "for he is the kind of person who is always thinking about the cost. “Eat and drink,” he says to you, but his heart is not with you."
        }
