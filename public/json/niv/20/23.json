          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "Do not wear yourself out to get rich; do not trust your own cleverness. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": "Do not wear yourself out to get rich; do not trust your own cleverness."
        }
      ]
    },
    {
