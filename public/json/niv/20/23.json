          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 13,
          "hasVerseLabel": true,
          "verseText": "Do not withhold discipline from a child; if you punish them with the rod, they will not die. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": "Do not withhold discipline from a child; if you punish them with the rod, they will not die."
        }
