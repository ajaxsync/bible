          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 11,
          "hasVerseLabel": true,
          "verseText": "for their Defender is strong; he will take up their case against you. "
        }
      ]
    },
    {
