          "verseNum": 31,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 33,
          "hasVerseLabel": true,
          "verseText": "Your eyes will see strange sights, and your mind will imagine confusing things. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 33,
          "hasVerseLabel": false,
          "verseText": "Your eyes will see strange sights, and your mind will imagine confusing things."
        }
      ]
    },
    {
