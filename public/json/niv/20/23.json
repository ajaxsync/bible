        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "Do not speak to fools, for they will scorn your prudent words. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "Do not speak to fools, for they will scorn your prudent words."
