          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 14,
          "hasVerseLabel": true,
          "verseText": "If anyone loudly blesses their neighbor early in the morning, it will be taken as a curse. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": "If anyone loudly blesses their neighbor early in the morning, it will be taken as a curse."
