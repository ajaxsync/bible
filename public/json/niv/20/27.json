          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 13,
          "hasVerseLabel": true,
          "verseText": "Take the garment of one who puts up security for a stranger; hold it in pledge if it is done for an outsider. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": "Take the garment of one who puts up security for a stranger; hold it in pledge if it is done for an outsider."
        }
