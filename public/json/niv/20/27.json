        },
        {
          "verseNum": 11,
          "hasVerseLabel": true,
          "verseText": "Be wise, my son, and bring joy to my heart; then I can answer anyone who treats me with contempt. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": false,
          "verseText": "Be wise, my son, and bring joy to my heart; then I can answer anyone who treats me with contempt."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 12,
          "hasVerseLabel": true,
          "verseText": "The prudent see danger and take refuge, but the simple keep going and pay the penalty. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": "The prudent see danger and take refuge, but the simple keep going and pay the penalty."
        }
      ]
    },
    {
