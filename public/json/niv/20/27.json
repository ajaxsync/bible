        },
        {
          "verseNum": 17,
          "hasVerseLabel": true,
          "verseText": "As iron sharpens iron, so one person sharpens another. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 17,
          "hasVerseLabel": true,
          "verseText": "As iron sharpens iron, so one person sharpens another. "
