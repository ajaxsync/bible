          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 12,
          "hasVerseLabel": true,
          "verseText": "When the righteous triumph, there is great elation; but when the wicked rise to power, people go into hiding. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": "When the righteous triumph, there is great elation; but when the wicked rise to power, people go into hiding."
        }
      ]
    },
    {
