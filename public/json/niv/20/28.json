          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 19,
          "hasVerseLabel": true,
          "verseText": "Those who work their land will have abundant food, but those who chase fantasies will have their fill of poverty. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 19,
          "hasVerseLabel": false,
          "verseText": "Those who work their land will have abundant food, but those who chase fantasies will have their fill of poverty."
