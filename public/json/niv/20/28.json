          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 14,
          "hasVerseLabel": true,
          "verseText": "Blessed is the one who always trembles before God, but whoever hardens their heart falls into trouble. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": "Blessed is the one who always trembles before God, but whoever hardens their heart falls into trouble."
