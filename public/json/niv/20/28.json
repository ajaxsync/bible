          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 13,
          "hasVerseLabel": true,
          "verseText": "Whoever conceals their sins does not prosper, but the one who confesses and renounces them finds mercy. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": "Whoever conceals their sins does not prosper, but the one who confesses and renounces them finds mercy."
