    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "Whoever increases wealth by taking interest or profit from the poor amasses it for another, who will be kind to the poor. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": "Whoever increases wealth by taking interest or profit from the poor amasses it for another, who will be kind to the poor."
