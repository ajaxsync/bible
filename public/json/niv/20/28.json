          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 16,
          "hasVerseLabel": true,
          "verseText": "A tyrannical ruler practices extortion, but one who hates ill-gotten gain will enjoy a long reign. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 16,
          "hasVerseLabel": false,
          "verseText": "A tyrannical ruler practices extortion, but one who hates ill-gotten gain will enjoy a long reign."
