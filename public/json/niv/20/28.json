        },
        {
          "verseNum": 20,
          "hasVerseLabel": true,
          "verseText": "A faithful person will be richly blessed, but one eager to get rich will not go unpunished. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 20,
          "hasVerseLabel": false,
          "verseText": "A faithful person will be richly blessed, but one eager to get rich will not go unpunished."
