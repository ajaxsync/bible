          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "If anyone turns a deaf ear to my instruction, even their prayers are detestable. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "If anyone turns a deaf ear to my instruction, even their prayers are detestable."
