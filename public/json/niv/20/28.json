        },
        {
          "verseNum": 24,
          "hasVerseLabel": true,
          "verseText": "Whoever robs their father or mother and says, “It’s not wrong,” is partner to one who destroys. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 24,
