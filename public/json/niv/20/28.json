          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 11,
          "hasVerseLabel": true,
          "verseText": "The rich are wise in their own eyes; one who is poor and discerning sees how deluded they are. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": false,
          "verseText": "The rich are wise in their own eyes; one who is poor and discerning sees how deluded they are."
