        },
        {
          "verseNum": 18,
          "hasVerseLabel": true,
          "verseText": "The one whose walk is blameless is kept safe, but the one whose ways are perverse will fall into the pit. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 18,
          "hasVerseLabel": false,
          "verseText": "The one whose walk is blameless is kept safe, but the one whose ways are perverse will fall into the pit."
