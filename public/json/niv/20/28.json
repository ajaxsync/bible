          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "Whoever leads the upright along an evil path will fall into their own trap, but the blameless will receive a good inheritance. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "Whoever leads the upright along an evil path will fall into their own trap, but the blameless will receive a good inheritance."
        }
