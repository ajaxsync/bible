        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "Evildoers are snared by their own sin, but the righteous shout for joy and are glad. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
