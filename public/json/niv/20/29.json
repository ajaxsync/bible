          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 16,
          "hasVerseLabel": true,
          "verseText": "When the wicked thrive, so does sin, but the righteous will see their downfall. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
