        },
        {
          "verseNum": 11,
          "hasVerseLabel": true,
          "verseText": "Fools give full vent to their rage, but the wise bring calm in the end. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": false,
