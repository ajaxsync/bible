          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "When the righteous thrive, the people rejoice; when the wicked rule, the people groan. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
