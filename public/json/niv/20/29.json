        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "The bloodthirsty hate a person of integrity and seek to kill the upright. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
