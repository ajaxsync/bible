        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "If a wise person goes to court with a fool, the fool rages and scoffs, and there is no peace. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
