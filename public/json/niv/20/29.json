          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "A man who loves wisdom brings joy to his father, but a companion of prostitutes squanders his wealth. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": "A man who loves wisdom brings joy to his father, but a companion of prostitutes squanders his wealth."
