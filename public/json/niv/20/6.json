          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 20,
          "hasVerseLabel": true,
          "verseText": "My son, keep your father’s command and do not forsake your mother’s teaching. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 20,
          "hasVerseLabel": true,
          "verseText": "My son, keep your father’s command and do not forsake your mother’s teaching. "
