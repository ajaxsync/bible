          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 32,
          "hasVerseLabel": true,
          "verseText": "But a man who commits adultery has no sense; whoever does so destroys himself. "
        }
      ]
    },
    {
