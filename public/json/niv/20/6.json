      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "Free yourself, like a gazelle from the hand of the hunter, like a bird from the snare of the fowler. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": "Free yourself, like a gazelle from the hand of the hunter, like a bird from the snare of the fowler."
        }
