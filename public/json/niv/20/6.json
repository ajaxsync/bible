        {
          "verseNum": 21,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 22,
          "hasVerseLabel": true,
          "verseText": "When you walk, they will guide you; when you sleep, they will watch over you; when you awake, they will speak to you. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 22,
          "hasVerseLabel": false,
          "verseText": "When you walk, they will guide you; when you sleep, they will watch over you; when you awake, they will speak to you."
