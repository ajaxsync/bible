      "contents": [
        {
          "verseNum": 22,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 23,
          "hasVerseLabel": true,
          "verseText": "For this command is a lamp, this teaching is a light, and correction and instruction are the way to life, "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 23,
          "hasVerseLabel": false,
          "verseText": "For this command is a lamp, this teaching is a light, and correction and instruction are the way to life,"
        }
      ]
    },
