          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "Keep my commands and you will live; guard my teachings as the apple of your eye. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "Keep my commands and you will live; guard my teachings as the apple of your eye. "
