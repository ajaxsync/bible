  "sections": [
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "My son, keep my words and store up my commands within you. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
