          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 12,
          "hasVerseLabel": true,
          "verseText": "If you are wise, your wisdom will reward you; if you are a mocker, you alone will suffer. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": "If you are wise, your wisdom will reward you; if you are a mocker, you alone will suffer."
