      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "Instruct the wise and they will be wiser still; teach the righteous and they will add to their learning. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "Instruct the wise and they will be wiser still; teach the righteous and they will add to their learning."
        }
      ]
    },
