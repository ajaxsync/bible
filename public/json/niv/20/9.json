        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "The fear of the Lord is the beginning of wisdom, and knowledge of the Holy One is understanding. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "The fear of the Lord is the beginning of wisdom, and knowledge of the Holy One is understanding."
        }
      ]
    },
