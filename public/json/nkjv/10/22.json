      "contents": [
        {
          "verseNum": 48,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 49,
          "hasVerseLabel": true,
          "verseText": "He delivers me from my enemies. You also lift me up above those who rise against me; You have delivered me from the violent man. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 49,
          "hasVerseLabel": false,
          "verseText": "He delivers me from my enemies. You also lift me up above those who rise against me; You have delivered me from the violent man."
