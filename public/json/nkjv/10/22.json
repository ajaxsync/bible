          "verseNum": 44,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 45,
          "hasVerseLabel": true,
          "verseText": "The foreigners submit to me; As soon as they hear, they obey me. "
        }
