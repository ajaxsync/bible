          "verseNum": 43,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 44,
          "hasVerseLabel": true,
          "verseText": "“You have also delivered me from the strivings of my people; You have kept me as the head of the nations. A people I have not known shall serve me. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 44,
          "hasVerseLabel": false,
          "verseText": "“You have also delivered me from the strivings of my people; You have kept me as the head of the nations. A people I have not known shall serve me."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 44,
          "hasVerseLabel": false,
          "verseText": "“You have also delivered me from the strivings of my people; You have kept me as the head of the nations. A people I have not known shall serve me."
        }
