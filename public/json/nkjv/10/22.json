          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 46,
          "hasVerseLabel": true,
          "verseText": "The foreigners fade away, And come frightened from their hideouts. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
