          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 50,
          "hasVerseLabel": true,
          "verseText": "Therefore I will give thanks to You, O Lord, among the Gentiles, And sing praises to Your name. "
        }
