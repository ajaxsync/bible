          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 47,
          "hasVerseLabel": true,
          "verseText": "“The Lord lives! Blessed be my Rock! Let God be exalted, The Rock of my salvation! "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 47,
          "hasVerseLabel": false,
          "verseText": "“The Lord lives! Blessed be my Rock! Let God be exalted, The Rock of my salvation!"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 47,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 48,
          "hasVerseLabel": true,
          "verseText": "It  is God who avenges me, And subdues the peoples under me; "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 48,
          "hasVerseLabel": false,
          "verseText": "It  is God who avenges me, And subdues the peoples under me;"
