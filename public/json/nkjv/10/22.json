      "contents": [
        {
          "verseNum": 42,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 43,
          "hasVerseLabel": true,
          "verseText": "Then I beat them as fine as the dust of the earth; I trod them like dirt in the streets, And I spread them out. "
        }
      ]
    },
    {
