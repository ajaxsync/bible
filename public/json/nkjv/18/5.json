{
  "book": 18,
  "chapter": 5,
  "sections": [
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "“Call out now; Is there anyone who will answer you? And to which of the holy ones will you turn? "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "“Call out now; Is there anyone who will answer you? And to which of the holy ones will you turn?"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "For wrath kills a foolish man, And envy slays a simple one. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": "For wrath kills a foolish man, And envy slays a simple one."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "I have seen the foolish taking root, But suddenly I cursed his dwelling place. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": "I have seen the foolish taking root, But suddenly I cursed his dwelling place."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "His sons are far from safety, They are crushed in the gate, And there  is no deliverer. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": "His sons are far from safety, They are crushed in the gate, And there  is no deliverer."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "Because the hungry eat up his harvest, Taking it even from the thorns, And a snare snatches their substance. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": "Because the hungry eat up his harvest, Taking it even from the thorns, And a snare snatches their substance."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": "Because the hungry eat up his harvest, Taking it even from the thorns, And a snare snatches their substance."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "For affliction does not come from the dust, Nor does trouble spring from the ground; "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": "For affliction does not come from the dust, Nor does trouble spring from the ground;"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "Yet man is born to trouble, As the sparks fly upward. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "Yet man is born to trouble, As the sparks fly upward."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "“But as for me, I would seek God, And to God I would commit my cause— "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": "“But as for me, I would seek God, And to God I would commit my cause—"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "Who does great things, and unsearchable, Marvelous things without number. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "Who does great things, and unsearchable, Marvelous things without number."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "He gives rain on the earth, And sends waters on the fields. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "He gives rain on the earth, And sends waters on the fields."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 11,
          "hasVerseLabel": true,
          "verseText": "He sets on high those who are lowly, And those who mourn are lifted to safety. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": false,
          "verseText": "He sets on high those who are lowly, And those who mourn are lifted to safety."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 12,
          "hasVerseLabel": true,
          "verseText": "He frustrates the devices of the crafty, So that their hands cannot carry out their plans. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": "He frustrates the devices of the crafty, So that their hands cannot carry out their plans."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 13,
          "hasVerseLabel": true,
          "verseText": "He catches the wise in their own craftiness, And the counsel of the cunning comes quickly upon them. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": "He catches the wise in their own craftiness, And the counsel of the cunning comes quickly upon them."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 14,
          "hasVerseLabel": true,
          "verseText": "They meet with darkness in the daytime, And grope at noontime as in the night. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": "They meet with darkness in the daytime, And grope at noontime as in the night."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 15,
          "hasVerseLabel": true,
          "verseText": "But He saves the needy from the sword, From the mouth of the mighty, And from their hand. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": "But He saves the needy from the sword, From the mouth of the mighty, And from their hand."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 16,
          "hasVerseLabel": true,
          "verseText": "So the poor have hope, And injustice shuts her mouth. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 16,
          "hasVerseLabel": false,
          "verseText": "So the poor have hope, And injustice shuts her mouth."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 16,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 17,
          "hasVerseLabel": true,
          "verseText": "“Behold, happy is the man whom God corrects; Therefore do not despise the chastening of the Almighty. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 17,
          "hasVerseLabel": false,
          "verseText": "“Behold, happy is the man whom God corrects; Therefore do not despise the chastening of the Almighty."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 17,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 18,
          "hasVerseLabel": true,
          "verseText": "For He bruises, but He binds up; He wounds, but His hands make whole. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 18,
          "hasVerseLabel": false,
          "verseText": "For He bruises, but He binds up; He wounds, but His hands make whole."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 18,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 19,
          "hasVerseLabel": true,
          "verseText": "He shall deliver you in six troubles, Yes, in seven no evil shall touch you. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 19,
          "hasVerseLabel": false,
          "verseText": "He shall deliver you in six troubles, Yes, in seven no evil shall touch you."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 19,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 20,
          "hasVerseLabel": true,
          "verseText": "In famine He shall redeem you from death, And in war from the power of the sword. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 20,
          "hasVerseLabel": false,
          "verseText": "In famine He shall redeem you from death, And in war from the power of the sword."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 20,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 21,
          "hasVerseLabel": true,
          "verseText": "You shall be hidden from the scourge of the tongue, And you shall not be afraid of destruction when it comes. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 21,
          "hasVerseLabel": false,
          "verseText": "You shall be hidden from the scourge of the tongue, And you shall not be afraid of destruction when it comes."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 21,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 22,
          "hasVerseLabel": true,
          "verseText": "You shall laugh at destruction and famine, And you shall not be afraid of the beasts of the earth. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 22,
          "hasVerseLabel": false,
          "verseText": "You shall laugh at destruction and famine, And you shall not be afraid of the beasts of the earth."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 22,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 23,
          "hasVerseLabel": true,
          "verseText": "For you shall have a covenant with the stones of the field, And the beasts of the field shall be at peace with you. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 23,
          "hasVerseLabel": false,
          "verseText": "For you shall have a covenant with the stones of the field, And the beasts of the field shall be at peace with you."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 23,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 24,
          "hasVerseLabel": true,
          "verseText": "You shall know that your tent is in peace; You shall visit your dwelling and find nothing amiss. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 24,
          "hasVerseLabel": false,
          "verseText": "You shall know that your tent is in peace; You shall visit your dwelling and find nothing amiss."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 24,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 25,
          "hasVerseLabel": true,
          "verseText": "You shall also know that your descendants shall  be many, And your offspring like the grass of the earth. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 25,
          "hasVerseLabel": false,
          "verseText": "You shall also know that your descendants shall  be many, And your offspring like the grass of the earth."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 25,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 26,
          "hasVerseLabel": true,
          "verseText": "You shall come to the grave at a full age, As a sheaf of grain ripens in its season. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 26,
          "hasVerseLabel": false,
          "verseText": "You shall come to the grave at a full age, As a sheaf of grain ripens in its season."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 26,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 27,
          "hasVerseLabel": true,
          "verseText": "Behold, this we have searched out; It is true. Hear it, and know for yourself.” "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 27,
          "hasVerseLabel": false,
          "verseText": "Behold, this we have searched out; It is true. Hear it, and know for yourself.”"
        }
      ]
    }
  ]
}