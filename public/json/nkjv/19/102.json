          "verseNum": 23,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 24,
          "hasVerseLabel": true,
          "verseText": "I said, “O my God, Do not take me away in the midst of my days; Your years are throughout all generations. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 24,
          "hasVerseLabel": false,
          "verseText": "I said, “O my God, Do not take me away in the midst of my days; Your years are throughout all generations."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 24,
          "hasVerseLabel": false,
          "verseText": "I said, “O my God, Do not take me away in the midst of my days; Your years are throughout all generations."
        }
      ]
