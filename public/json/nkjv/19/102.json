          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 19,
          "hasVerseLabel": true,
          "verseText": "For He looked down from the height of His sanctuary; From heaven the Lord viewed the earth, "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 19,
          "hasVerseLabel": false,
          "verseText": "For He looked down from the height of His sanctuary; From heaven the Lord viewed the earth,"
