          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "Do not hide Your face from me in the day of my trouble; Incline Your ear to me; In the day that I call, answer me speedily. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
