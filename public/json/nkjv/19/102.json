      "type": "line-quote",
      "contents": [
        {
          "verseNum": 25,
          "hasVerseLabel": false,
          "verseText": "Of old You laid the foundation of the earth, And the heavens are the work of Your hands."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 25,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 26,
          "hasVerseLabel": true,
          "verseText": "They will perish, but You will endure; Yes, they will all grow old like a garment; Like a cloak You will change them, And they will be changed. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 26,
          "hasVerseLabel": false,
          "verseText": "They will perish, but You will endure; Yes, they will all grow old like a garment; Like a cloak You will change them, And they will be changed."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 26,
          "hasVerseLabel": false,
          "verseText": "They will perish, but You will endure; Yes, they will all grow old like a garment; Like a cloak You will change them, And they will be changed."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 26,
          "hasVerseLabel": false,
          "verseText": "They will perish, but You will endure; Yes, they will all grow old like a garment; Like a cloak You will change them, And they will be changed."
        }
