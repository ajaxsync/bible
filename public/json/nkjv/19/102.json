          "verseNum": 24,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 25,
          "hasVerseLabel": true,
          "verseText": "Of old You laid the foundation of the earth, And the heavens are the work of Your hands. "
        }
      ]
    },
