          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 15,
          "hasVerseLabel": true,
          "verseText": "So the nations shall fear the name of the Lord, And all the kings of the earth Your glory. "
        }
