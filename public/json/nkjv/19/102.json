          "verseNum": 26,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 27,
          "hasVerseLabel": true,
          "verseText": "But You are the same, And Your years will have no end. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
