          "verseNum": 22,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 23,
          "hasVerseLabel": true,
          "verseText": "He weakened my strength in the way; He shortened my days. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 23,
          "hasVerseLabel": false,
          "verseText": "He weakened my strength in the way; He shortened my days."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
