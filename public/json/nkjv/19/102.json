          "hasVerseLabel": true,
          "verseText": "The children of Your servants will continue, And their descendants will be established before You.” "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 28,
          "hasVerseLabel": false,
