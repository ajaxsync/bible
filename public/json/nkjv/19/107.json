        },
        {
          "verseNum": 31,
          "hasVerseLabel": true,
          "verseText": "Oh, that men would give thanks to the Lord  for His goodness, And for His wonderful works to the children of men! "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 31,
          "hasVerseLabel": false,
          "verseText": "Oh, that men would give thanks to the Lord  for His goodness, And for His wonderful works to the children of men!"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 31,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 32,
          "hasVerseLabel": true,
          "verseText": "Let them exalt Him also in the assembly of the people, And praise Him in the company of the elders. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 32,
          "hasVerseLabel": false,
          "verseText": "Let them exalt Him also in the assembly of the people, And praise Him in the company of the elders."
