          "verseNum": 32,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 33,
          "hasVerseLabel": true,
          "verseText": "He turns rivers into a wilderness, And the watersprings into dry ground; "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 33,
          "hasVerseLabel": false,
          "verseText": "He turns rivers into a wilderness, And the watersprings into dry ground;"
        }
