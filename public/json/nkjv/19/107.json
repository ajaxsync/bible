          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "Let the redeemed of the Lord say so, Whom He has redeemed from the hand of the enemy, "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": "Let the redeemed of the Lord say so, Whom He has redeemed from the hand of the enemy,"
