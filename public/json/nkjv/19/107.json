    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "Oh, give thanks to the Lord, for He  is good! For His mercy endures forever. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "Oh, give thanks to the Lord, for He  is good! For His mercy endures forever."
