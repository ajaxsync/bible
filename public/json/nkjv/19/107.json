      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "Oh, that men would give thanks to the Lord  for His goodness, And for His wonderful works to the children of men! "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": "Oh, that men would give thanks to the Lord  for His goodness, And for His wonderful works to the children of men!"
        }
