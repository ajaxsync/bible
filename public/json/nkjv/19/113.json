        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "Who is like the Lord our God, Who dwells on high, "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": "Who is like the Lord our God, Who dwells on high,"
