        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "“Many a time they have afflicted me from my youth; Yet they have not prevailed against me. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": "“Many a time they have afflicted me from my youth; Yet they have not prevailed against me."
