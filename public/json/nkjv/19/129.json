        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "Let all those who hate Zion Be put to shame and turned back. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "Let them be as the grass on the housetops, Which withers before it grows up, "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": "Let them be as the grass on the housetops, Which withers before it grows up,"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "With which the reaper does not fill his hand, Nor he who binds sheaves, his arms. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "With which the reaper does not fill his hand, Nor he who binds sheaves, his arms."
