        },
        {
          "verseNum": 19,
          "hasVerseLabel": true,
          "verseText": "He declares His word to Jacob, His statutes and His judgments to Israel. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 19,
          "hasVerseLabel": false,
          "verseText": "He declares His word to Jacob, His statutes and His judgments to Israel."
