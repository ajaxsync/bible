          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "To execute on them the written judgment— This honor have all His saints. Praise the Lord! "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "To execute on them the written judgment— This honor have all His saints. Praise the Lord!"
        }
