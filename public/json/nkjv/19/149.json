    {
      "type": "heading",
      "heading": "讚美的聖詩"
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "Praise the Lord! Sing to the Lord a new song, And His praise in the assembly of saints. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "Praise the Lord! Sing to the Lord a new song, And His praise in the assembly of saints."
        }
