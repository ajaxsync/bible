          "verseText": " "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "O Lord my God, I cried out to You, And You healed me. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": "O Lord my God, I cried out to You, And You healed me."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
