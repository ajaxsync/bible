      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "Sing praise to the Lord, you saints of His, And give thanks at the remembrance of His holy name. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": "Sing praise to the Lord, you saints of His, And give thanks at the remembrance of His holy name."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "For His anger is  but  for a moment, His favor is  for life; Weeping may endure for a night, But joy comes in the morning. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": "For His anger is  but  for a moment, His favor is  for life; Weeping may endure for a night, But joy comes in the morning."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": "For His anger is  but  for a moment, His favor is  for life; Weeping may endure for a night, But joy comes in the morning."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": "For His anger is  but  for a moment, His favor is  for life; Weeping may endure for a night, But joy comes in the morning."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
