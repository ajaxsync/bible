      "type": "desc",
      "contents": []
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "I will extol You, O Lord, for You have lifted me up, And have not let my foes rejoice over me. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "I will extol You, O Lord, for You have lifted me up, And have not let my foes rejoice over me."
