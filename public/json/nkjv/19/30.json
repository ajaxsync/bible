          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "O Lord, You brought my soul up from the grave; You have kept me alive, that I should not go down to the pit. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": "O Lord, You brought my soul up from the grave; You have kept me alive, that I should not go down to the pit."
        }
