{
  "book": 19,
  "chapter": 34,
  "sections": [
    {
      "type": "heading",
      "heading": "頌讚神的美善"
    },
    {
      "type": "desc",
      "contents": []
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "I will bless the Lord at all times; His praise shall continually be in my mouth. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "I will bless the Lord at all times; His praise shall continually be in my mouth."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "My soul shall make its boast in the Lord; The humble shall hear of  it and be glad. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": "My soul shall make its boast in the Lord; The humble shall hear of  it and be glad."
        }
