{
  "book": 19,
  "chapter": 38,
  "sections": [
    {
      "type": "heading",
      "heading": "受苦者的祈禱"
    },
    {
      "type": "desc",
      "contents": []
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "O Lord, do not rebuke me in Your wrath, Nor chasten me in Your hot displeasure! "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "O Lord, do not rebuke me in Your wrath, Nor chasten me in Your hot displeasure!"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "For Your arrows pierce me deeply, And Your hand presses me down. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": "For Your arrows pierce me deeply, And Your hand presses me down."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "There  is no soundness in my flesh Because of Your anger, Nor any health in my bones Because of my sin. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": "There  is no soundness in my flesh Because of Your anger, Nor any health in my bones Because of my sin."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "For my iniquities have gone over my head; Like a heavy burden they are too heavy for me. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": "For my iniquities have gone over my head; Like a heavy burden they are too heavy for me."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "My wounds are foul and festering Because of my foolishness. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": "My wounds are foul and festering Because of my foolishness."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "I am troubled, I am bowed down greatly; I go mourning all the day long. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": "I am troubled, I am bowed down greatly; I go mourning all the day long."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "For my loins are full of inflammation, And there  is no soundness in my flesh. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "For my loins are full of inflammation, And there  is no soundness in my flesh."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "I am feeble and severely broken; I groan because of the turmoil of my heart. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": "I am feeble and severely broken; I groan because of the turmoil of my heart."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "Lord, all my desire is before You; And my sighing is not hidden from You. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "Lord, all my desire is before You; And my sighing is not hidden from You."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "My heart pants, my strength fails me; As for the light of my eyes, it also has gone from me. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "My heart pants, my strength fails me; As for the light of my eyes, it also has gone from me."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 11,
          "hasVerseLabel": true,
          "verseText": "My loved ones and my friends stand aloof from my plague, And my relatives stand afar off. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": false,
          "verseText": "My loved ones and my friends stand aloof from my plague, And my relatives stand afar off."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 12,
          "hasVerseLabel": true,
          "verseText": "Those also who seek my life lay snares for  me; Those who seek my hurt speak of destruction, And plan deception all the day long. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": "Those also who seek my life lay snares for  me; Those who seek my hurt speak of destruction, And plan deception all the day long."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": "Those also who seek my life lay snares for  me; Those who seek my hurt speak of destruction, And plan deception all the day long."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 13,
          "hasVerseLabel": true,
          "verseText": "But I, like a deaf man, do not hear; And I  am like a mute who does not open his mouth. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": "But I, like a deaf man, do not hear; And I  am like a mute who does not open his mouth."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 14,
          "hasVerseLabel": true,
          "verseText": "Thus I am like a man who does not hear, And in whose mouth is no response. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": "Thus I am like a man who does not hear, And in whose mouth is no response."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 15,
          "hasVerseLabel": true,
          "verseText": "For in You, O Lord, I hope; You will hear, O Lord my God. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": "For in You, O Lord, I hope; You will hear, O Lord my God."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 16,
          "hasVerseLabel": true,
          "verseText": "For I said, “Hear me, lest they rejoice over me, Lest, when my foot slips, they exalt themselves against me.” "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 16,
          "hasVerseLabel": false,
          "verseText": "For I said, “Hear me, lest they rejoice over me, Lest, when my foot slips, they exalt themselves against me.”"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 16,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 17,
          "hasVerseLabel": true,
          "verseText": "For I am ready to fall, And my sorrow is continually before me. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 17,
          "hasVerseLabel": false,
          "verseText": "For I am ready to fall, And my sorrow is continually before me."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 17,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 18,
          "hasVerseLabel": true,
          "verseText": "For I will declare my iniquity; I will be in anguish over my sin. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 18,
          "hasVerseLabel": false,
          "verseText": "For I will declare my iniquity; I will be in anguish over my sin."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 18,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 19,
          "hasVerseLabel": true,
          "verseText": "But my enemies are vigorous, and they are strong; And those who hate me wrongfully have multiplied. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 19,
          "hasVerseLabel": false,
          "verseText": "But my enemies are vigorous, and they are strong; And those who hate me wrongfully have multiplied."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 19,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 20,
          "hasVerseLabel": true,
          "verseText": "Those also who render evil for good, They are my adversaries, because I follow what  is good. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 20,
          "hasVerseLabel": false,
          "verseText": "Those also who render evil for good, They are my adversaries, because I follow what  is good."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 20,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 21,
          "hasVerseLabel": true,
          "verseText": "Do not forsake me, O Lord; O my God, be not far from me! "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 21,
          "hasVerseLabel": false,
          "verseText": "Do not forsake me, O Lord; O my God, be not far from me!"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 21,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 22,
          "hasVerseLabel": true,
          "verseText": "Make haste to help me, O Lord, my salvation! "
        }
      ]
    }
  ]
}