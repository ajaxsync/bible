      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "Great is the Lord, and greatly to be praised In the city of our God, In His holy mountain. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
