    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "Is  it not You, O God, who cast us off? And You, O God, who did not go out with our armies? "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "Is  it not You, O God, who cast us off? And You, O God, who did not go out with our armies?"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
