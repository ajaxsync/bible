      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "O God, You have cast us off; You have broken us down; You have been displeased; Oh, restore us again! "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "O God, You have cast us off; You have broken us down; You have been displeased; Oh, restore us again!"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "You have made the earth tremble; You have broken it; Heal its breaches, for it is shaking. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": "You have made the earth tremble; You have broken it; Heal its breaches, for it is shaking."
