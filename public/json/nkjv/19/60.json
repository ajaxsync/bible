        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "Who will bring me to the strong city? Who will lead me to Edom? "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "Who will bring me to the strong city? Who will lead me to Edom?"
