          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "Moab is My washpot; Over Edom I will cast My shoe; Philistia, shout in triumph because of Me.” "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": "Moab is My washpot; Over Edom I will cast My shoe; Philistia, shout in triumph because of Me.”"
