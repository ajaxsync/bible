          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "You, Yourself, are to be feared; And who may stand in Your presence When once You are angry? "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "You, Yourself, are to be feared; And who may stand in Your presence When once You are angry?"
