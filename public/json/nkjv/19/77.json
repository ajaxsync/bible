      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "And I said, “This is my anguish; But  I  will  remember the years of the right hand of the Most High.” "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "And I said, “This is my anguish; But  I  will  remember the years of the right hand of the Most High.”"
