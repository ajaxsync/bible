          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 15,
          "hasVerseLabel": true,
          "verseText": "You have with Your arm redeemed Your people, The sons of Jacob and Joseph. Selah "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": "You have with Your arm redeemed Your people, The sons of Jacob and Joseph. Selah"
