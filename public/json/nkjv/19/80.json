          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 17,
          "hasVerseLabel": true,
          "verseText": "Let Your hand be upon the man of Your right hand, Upon the son of man whom You made strong for Yourself. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 17,
          "hasVerseLabel": false,
          "verseText": "Let Your hand be upon the man of Your right hand, Upon the son of man whom You made strong for Yourself."
