          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "Mercy and truth have met together; Righteousness and peace have kissed. "
        }
      ]
    },
    {
