        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "You have rebuked the nations, You have destroyed the wicked; You have blotted out their name forever and ever. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
