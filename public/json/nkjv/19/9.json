        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "For You have maintained my right and my cause; You sat on the throne judging in righteousness. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
