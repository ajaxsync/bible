          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 14,
          "hasVerseLabel": true,
          "verseText": "That I may tell of all Your praise In the gates of the daughter of Zion. I will rejoice in Your salvation. "
        }
      ]
    },
