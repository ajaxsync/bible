        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "But my horn You have exalted like a wild ox; I have been anointed with fresh oil. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
