        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "For behold, Your enemies, O Lord, For behold, Your enemies shall perish; All the workers of iniquity shall be scattered. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
