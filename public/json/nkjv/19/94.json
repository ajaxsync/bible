{
  "book": 19,
  "chapter": 94,
  "sections": [
    {
      "type": "heading",
      "heading": "神審判萬人"
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "O Lord God, to whom vengeance belongs— O God, to whom vengeance belongs, shine forth! "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "O Lord God, to whom vengeance belongs— O God, to whom vengeance belongs, shine forth!"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "Rise up, O Judge of the earth; Render punishment to the proud. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": "Rise up, O Judge of the earth; Render punishment to the proud."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "Lord, how long will the wicked, How long will the wicked triumph? "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": "Lord, how long will the wicked, How long will the wicked triumph?"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "They utter speech, and speak insolent things; All the workers of iniquity boast in themselves. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": "They utter speech, and speak insolent things; All the workers of iniquity boast in themselves."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "They break in pieces Your people, O Lord, And afflict Your heritage. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": "They break in pieces Your people, O Lord, And afflict Your heritage."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "They slay the widow and the stranger, And murder the fatherless. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": "They slay the widow and the stranger, And murder the fatherless."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "Yet they say, “The Lord does not see, Nor does the God of Jacob understand.” "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "Yet they say, “The Lord does not see, Nor does the God of Jacob understand.”"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "Understand, you senseless among the people; And you fools, when will you be wise? "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": "Understand, you senseless among the people; And you fools, when will you be wise?"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "He who planted the ear, shall He not hear? He who formed the eye, shall He not see? "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "He who planted the ear, shall He not hear? He who formed the eye, shall He not see?"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "He who instructs the nations, shall He not correct, He who teaches man knowledge? "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "He who instructs the nations, shall He not correct, He who teaches man knowledge?"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 11,
          "hasVerseLabel": true,
          "verseText": "The Lord  knows the thoughts of man, That they are futile. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 12,
          "hasVerseLabel": true,
          "verseText": "Blessed is the man whom You instruct, O Lord, And teach out of Your law, "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": "Blessed is the man whom You instruct, O Lord, And teach out of Your law,"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 13,
          "hasVerseLabel": true,
          "verseText": "That You may give him rest from the days of adversity, Until the pit is dug for the wicked. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": "That You may give him rest from the days of adversity, Until the pit is dug for the wicked."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 14,
          "hasVerseLabel": true,
          "verseText": "For the Lord will not cast off His people, Nor will He forsake His inheritance. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": "For the Lord will not cast off His people, Nor will He forsake His inheritance."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 15,
          "hasVerseLabel": true,
          "verseText": "But judgment will return to righteousness, And all the upright in heart will follow it. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": "But judgment will return to righteousness, And all the upright in heart will follow it."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 16,
          "hasVerseLabel": true,
          "verseText": "Who will rise up for me against the evildoers? Who will stand up for me against the workers of iniquity? "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 16,
          "hasVerseLabel": false,
          "verseText": "Who will rise up for me against the evildoers? Who will stand up for me against the workers of iniquity?"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 16,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 17,
          "hasVerseLabel": true,
          "verseText": "Unless the Lord  had  been my help, My soul would soon have settled in silence. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 17,
          "hasVerseLabel": false,
          "verseText": "Unless the Lord  had  been my help, My soul would soon have settled in silence."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 17,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 18,
          "hasVerseLabel": true,
          "verseText": "If I say, “My foot slips,” Your mercy, O Lord, will hold me up. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 18,
          "hasVerseLabel": false,
          "verseText": "If I say, “My foot slips,” Your mercy, O Lord, will hold me up."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 18,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 19,
          "hasVerseLabel": true,
          "verseText": "In the multitude of my anxieties within me, Your comforts delight my soul. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 19,
          "hasVerseLabel": false,
          "verseText": "In the multitude of my anxieties within me, Your comforts delight my soul."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 19,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 20,
          "hasVerseLabel": true,
          "verseText": "Shall the throne of iniquity, which devises evil by law, Have fellowship with You? "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 20,
          "hasVerseLabel": false,
          "verseText": "Shall the throne of iniquity, which devises evil by law, Have fellowship with You?"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 20,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 21,
          "hasVerseLabel": true,
          "verseText": "They gather together against the life of the righteous, And condemn innocent blood. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 21,
          "hasVerseLabel": false,
          "verseText": "They gather together against the life of the righteous, And condemn innocent blood."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 21,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 22,
          "hasVerseLabel": true,
          "verseText": "But the Lord has been my defense, And my God the rock of my refuge. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 22,
          "hasVerseLabel": false,
          "verseText": "But the Lord has been my defense, And my God the rock of my refuge."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 22,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 23,
          "hasVerseLabel": true,
          "verseText": "He has brought on them their own iniquity, And shall cut them off in their own wickedness; The Lord our God shall cut them off. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 23,
          "hasVerseLabel": false,
          "verseText": "He has brought on them their own iniquity, And shall cut them off in their own wickedness; The Lord our God shall cut them off."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 23,
          "hasVerseLabel": false,
          "verseText": "He has brought on them their own iniquity, And shall cut them off in their own wickedness; The Lord our God shall cut them off."
        }
      ]
    }
  ]
}