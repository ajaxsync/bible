          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "Oh, worship the Lord  in the beauty of holiness! Tremble before Him, all the earth. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "Oh, worship the Lord  in the beauty of holiness! Tremble before Him, all the earth."
