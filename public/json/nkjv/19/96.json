    {
      "type": "ref-heading",
      "heading": "（代上16‧23－33）"
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "Oh, sing to the Lord a new song! Sing to the Lord, all the earth. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "Oh, sing to the Lord a new song! Sing to the Lord, all the earth."
