      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "Say among the nations, “The Lord reigns; The world also is firmly established, It shall not be moved; He shall judge the peoples righteously.” "
        }
      ]
    },
