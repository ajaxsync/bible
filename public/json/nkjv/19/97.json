          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "A fire goes before Him, And burns up His enemies round about. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
