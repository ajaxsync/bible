          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 24,
          "hasVerseLabel": true,
          "verseText": "The fear of the wicked will come upon him, And the desire of the righteous will be granted. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 24,
          "hasVerseLabel": false,
          "verseText": "The fear of the wicked will come upon him, And the desire of the righteous will be granted."
