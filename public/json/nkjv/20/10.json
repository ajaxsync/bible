          "verseText": " "
        },
        {
          "verseNum": 27,
          "hasVerseLabel": true,
          "verseText": "The fear of the Lord prolongs days, But the years of the wicked will be shortened. "
        }
      ]
    },
    {
      "type": "line-quote",
