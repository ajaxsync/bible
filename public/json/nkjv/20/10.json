          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 20,
          "hasVerseLabel": true,
          "verseText": "The tongue of the righteous is choice silver; The heart of the wicked is  worth little. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 20,
          "hasVerseLabel": false,
          "verseText": "The tongue of the righteous is choice silver; The heart of the wicked is  worth little."
