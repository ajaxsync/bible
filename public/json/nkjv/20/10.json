          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 19,
          "hasVerseLabel": true,
          "verseText": "In the multitude of words sin is not lacking, But he who restrains his lips is wise. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 19,
          "hasVerseLabel": false,
          "verseText": "In the multitude of words sin is not lacking, But he who restrains his lips is wise."
