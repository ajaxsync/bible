          "verseText": " "
        },
        {
          "verseNum": 25,
          "hasVerseLabel": true,
          "verseText": "When the whirlwind passes by, the wicked is no more, But the righteous has an everlasting foundation. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 25,
          "hasVerseLabel": false,
          "verseText": "When the whirlwind passes by, the wicked is no more, But the righteous has an everlasting foundation."
        }
