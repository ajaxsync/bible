          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "The righteousness of the upright will deliver them, But the unfaithful will be caught by their lust. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": "The righteousness of the upright will deliver them, But the unfaithful will be caught by their lust."
