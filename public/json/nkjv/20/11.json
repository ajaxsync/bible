          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "The hypocrite with his mouth destroys his neighbor, But through knowledge the righteous will be delivered. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "The hypocrite with his mouth destroys his neighbor, But through knowledge the righteous will be delivered."
