          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "The righteousness of the blameless will direct his way aright, But the wicked will fall by his own wickedness. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": "The righteousness of the blameless will direct his way aright, But the wicked will fall by his own wickedness."
