        },
        {
          "verseNum": 14,
          "hasVerseLabel": true,
          "verseText": "Where there  is no counsel, the people fall; But in the multitude of counselors there  is safety. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": "Where there  is no counsel, the people fall; But in the multitude of counselors there  is safety."
