          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "When a wicked man dies, his expectation will perish, And the hope of the unjust perishes. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "When a wicked man dies, his expectation will perish, And the hope of the unjust perishes."
