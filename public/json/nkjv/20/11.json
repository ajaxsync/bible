{
  "book": 20,
  "chapter": 11,
  "sections": [
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "Dishonest scales are an abomination to the Lord, But a just weight is His delight. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "Dishonest scales are an abomination to the Lord, But a just weight is His delight."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "When pride comes, then comes shame; But with the humble is wisdom. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": "When pride comes, then comes shame; But with the humble is wisdom."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
