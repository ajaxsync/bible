        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "When it goes well with the righteous, the city rejoices; And when the wicked perish, there  is jubilation. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "When it goes well with the righteous, the city rejoices; And when the wicked perish, there  is jubilation."
