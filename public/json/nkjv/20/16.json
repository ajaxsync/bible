          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 16,
          "hasVerseLabel": true,
          "verseText": "How much better to get wisdom than gold! And to get understanding is to be chosen rather than silver. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 16,
          "hasVerseLabel": false,
          "verseText": "How much better to get wisdom than gold! And to get understanding is to be chosen rather than silver."
        }
