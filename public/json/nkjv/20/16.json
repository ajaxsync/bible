          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 20,
          "hasVerseLabel": true,
          "verseText": "He who heeds the word wisely will find good, And whoever trusts in the Lord, happy is he. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 20,
          "hasVerseLabel": false,
          "verseText": "He who heeds the word wisely will find good, And whoever trusts in the Lord, happy is he."
