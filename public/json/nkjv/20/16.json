          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "Divination is on the lips of the king; His mouth must not transgress in judgment. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "Divination is on the lips of the king; His mouth must not transgress in judgment."
        }
      ]
    },
