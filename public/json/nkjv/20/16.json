        },
        {
          "verseNum": 25,
          "hasVerseLabel": true,
          "verseText": "There is a way that  seems right to a man, But its end is the way of death. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 25,
          "hasVerseLabel": false,
          "verseText": "There is a way that  seems right to a man, But its end is the way of death."
