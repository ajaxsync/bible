        },
        {
          "verseNum": 16,
          "hasVerseLabel": true,
          "verseText": "Why is  there in the hand of a fool the purchase price of wisdom, Since he  has no heart for  it? "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 16,
          "hasVerseLabel": false,
