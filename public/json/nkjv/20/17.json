        },
        {
          "verseNum": 20,
          "hasVerseLabel": true,
          "verseText": "He who has a deceitful heart finds no good, And he who has a perverse tongue falls into evil. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 20,
          "hasVerseLabel": false,
