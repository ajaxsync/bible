        },
        {
          "verseNum": 21,
          "hasVerseLabel": true,
          "verseText": "He who begets a scoffer does  so to his sorrow, And the father of a fool has no joy. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 21,
          "hasVerseLabel": false,
          "verseText": "He who begets a scoffer does  so to his sorrow, And the father of a fool has no joy."
