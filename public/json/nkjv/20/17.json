        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "An evildoer gives heed to false lips; A liar listens eagerly to a spiteful tongue. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": "An evildoer gives heed to false lips; A liar listens eagerly to a spiteful tongue."
