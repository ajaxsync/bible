        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "The refining pot is for silver and the furnace for gold, But the Lord tests the hearts. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
