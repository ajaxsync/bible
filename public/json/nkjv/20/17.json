        },
        {
          "verseNum": 28,
          "hasVerseLabel": true,
          "verseText": "Even a fool is counted wise when he holds his peace; When he shuts his lips, he  is  considered perceptive. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 28,
          "hasVerseLabel": false,
