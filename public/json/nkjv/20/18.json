  "sections": [
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "A man who isolates himself seeks his own desire; He rages against all wise judgment. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
