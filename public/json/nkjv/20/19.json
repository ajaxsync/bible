          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 28,
          "hasVerseLabel": true,
          "verseText": "A disreputable witness scorns justice, And the mouth of the wicked devours iniquity. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 28,
          "hasVerseLabel": false,
          "verseText": "A disreputable witness scorns justice, And the mouth of the wicked devours iniquity."
        }
      ]
    },
    {
      "type": "line-quote",
