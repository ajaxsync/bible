        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "Luxury is not fitting for a fool, Much less for a servant to rule over princes. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "Luxury is not fitting for a fool, Much less for a servant to rule over princes."
