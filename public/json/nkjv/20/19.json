    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "All the brothers of the poor hate him; How much more do his friends go far from him! He may pursue them  with words, yet they abandon him. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "All the brothers of the poor hate him; How much more do his friends go far from him! He may pursue them  with words, yet they abandon him."
        }
      ]
    },
    {
