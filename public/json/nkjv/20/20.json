    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "Wine is a mocker, Strong drink is a brawler, And whoever is led astray by it is not wise. "
        }
      ]
    },
    {
