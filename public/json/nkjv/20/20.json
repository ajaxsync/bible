          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "It  is honorable for a man to stop striving, Since any fool can start a quarrel. "
        }
      ]
    },
    {
