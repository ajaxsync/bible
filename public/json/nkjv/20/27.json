        {
          "verseNum": 13,
          "hasVerseLabel": true,
          "verseText": "Take the garment of him who is surety for a stranger, And hold it in pledge when he is surety for a seductress. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
