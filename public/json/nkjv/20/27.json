        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "Do not forsake your own friend or your father’s friend, Nor go to your brother’s house in the day of your calamity; Better is a neighbor nearby than a brother far away. "
        }
      ]
    },
    {
