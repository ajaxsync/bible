        },
        {
          "verseNum": 14,
          "hasVerseLabel": true,
          "verseText": "He who blesses his friend with a loud voice, rising early in the morning, It will be counted a curse to him. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
