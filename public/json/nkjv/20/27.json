          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "Ointment and perfume delight the heart, And the sweetness of a man’s friend gives  delight by hearty counsel. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "Ointment and perfume delight the heart, And the sweetness of a man’s friend gives  delight by hearty counsel."
