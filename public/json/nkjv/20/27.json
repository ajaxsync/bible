        {
          "verseNum": 11,
          "hasVerseLabel": true,
          "verseText": "My son, be wise, and make my heart glad, That I may answer him who reproaches me. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": false,
          "verseText": "My son, be wise, and make my heart glad, That I may answer him who reproaches me."
