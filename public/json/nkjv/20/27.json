        },
        {
          "verseNum": 15,
          "hasVerseLabel": true,
          "verseText": "A continual dripping on a very rainy day And a contentious woman are alike; "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 15,
          "hasVerseLabel": false,
