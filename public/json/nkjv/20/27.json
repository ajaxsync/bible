        },
        {
          "verseNum": 18,
          "hasVerseLabel": true,
          "verseText": "Whoever keeps the fig tree will eat its fruit; So he who waits on his master will be honored. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 18,
          "hasVerseLabel": false,
