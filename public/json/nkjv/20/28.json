          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "Whoever causes the upright to go astray in an evil way, He himself will fall into his own pit; But the blameless will inherit good. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "Whoever causes the upright to go astray in an evil way, He himself will fall into his own pit; But the blameless will inherit good."
        }
      ]
    },
