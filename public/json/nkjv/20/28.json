          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "One who turns away his ear from hearing the law, Even his prayer is an abomination. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "One who turns away his ear from hearing the law, Even his prayer is an abomination."
        }
      ]
