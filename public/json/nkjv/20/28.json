        },
        {
          "verseNum": 25,
          "hasVerseLabel": true,
          "verseText": "He who is of a proud heart stirs up strife, But he who trusts in the Lord will be prospered. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
