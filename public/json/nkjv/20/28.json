          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "A poor man who oppresses the poor Is  like a driving rain which leaves no food. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": "A poor man who oppresses the poor Is  like a driving rain which leaves no food."
        }
      ]
