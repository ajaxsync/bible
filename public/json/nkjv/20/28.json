          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 19,
          "hasVerseLabel": true,
          "verseText": "He who tills his land will have plenty of bread, But he who follows frivolity will have poverty enough! "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 19,
          "hasVerseLabel": false,
          "verseText": "He who tills his land will have plenty of bread, But he who follows frivolity will have poverty enough!"
