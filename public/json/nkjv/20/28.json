        },
        {
          "verseNum": 18,
          "hasVerseLabel": true,
          "verseText": "Whoever walks blamelessly will be saved, But he  who  is perverse in  his ways will suddenly fall. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 18,
          "hasVerseLabel": false,
          "verseText": "Whoever walks blamelessly will be saved, But he  who  is perverse in  his ways will suddenly fall."
