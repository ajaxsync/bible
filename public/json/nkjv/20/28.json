          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 13,
          "hasVerseLabel": true,
          "verseText": "He who covers his sins will not prosper, But whoever confesses and forsakes them will have mercy. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": "He who covers his sins will not prosper, But whoever confesses and forsakes them will have mercy."
