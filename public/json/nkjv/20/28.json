          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "Because of the transgression of a land, many are its princes; But by a man of understanding and knowledge Right will be prolonged. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": "Because of the transgression of a land, many are its princes; But by a man of understanding and knowledge Right will be prolonged."
