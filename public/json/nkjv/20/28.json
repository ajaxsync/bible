        },
        {
          "verseNum": 27,
          "hasVerseLabel": true,
          "verseText": "He who gives to the poor will not lack, But he who hides his eyes will have many curses. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 27,
          "hasVerseLabel": false,
          "verseText": "He who gives to the poor will not lack, But he who hides his eyes will have many curses."
        }
