  "sections": [
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "The wicked flee when no one pursues, But the righteous are bold as a lion. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "The wicked flee when no one pursues, But the righteous are bold as a lion."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
