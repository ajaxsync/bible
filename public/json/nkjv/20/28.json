          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 12,
          "hasVerseLabel": true,
          "verseText": "When the righteous rejoice, there  is great glory; But when the wicked arise, men hide themselves. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": "When the righteous rejoice, there  is great glory; But when the wicked arise, men hide themselves."
        }
      ]
    },
    {
