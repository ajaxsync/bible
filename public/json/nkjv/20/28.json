        },
        {
          "verseNum": 16,
          "hasVerseLabel": true,
          "verseText": "A ruler who lacks understanding is a great oppressor, But he who hates covetousness will prolong his days. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 16,
          "hasVerseLabel": false,
          "verseText": "A ruler who lacks understanding is a great oppressor, But he who hates covetousness will prolong his days."
        }
      ]
