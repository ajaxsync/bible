          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 26,
          "hasVerseLabel": true,
          "verseText": "He who trusts in his own heart is a fool, But whoever walks wisely will be delivered. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 26,
          "hasVerseLabel": false,
          "verseText": "He who trusts in his own heart is a fool, But whoever walks wisely will be delivered."
        }
