          "verseText": " "
        },
        {
          "verseNum": 16,
          "hasVerseLabel": true,
          "verseText": "When the wicked are multiplied, transgression increases; But the righteous will see their fall. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 16,
          "hasVerseLabel": false,
          "verseText": "When the wicked are multiplied, transgression increases; But the righteous will see their fall."
