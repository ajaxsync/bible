        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "Scoffers set a city aflame, But wise men turn away wrath. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
