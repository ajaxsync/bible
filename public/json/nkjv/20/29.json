          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "The righteous considers the cause of the poor, But the wicked does not understand such knowledge. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "The righteous considers the cause of the poor, But the wicked does not understand such knowledge."
