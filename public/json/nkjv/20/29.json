        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "By transgression an evil man is snared, But the righteous sings and rejoices. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
