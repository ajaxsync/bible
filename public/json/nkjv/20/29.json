        },
        {
          "verseNum": 13,
          "hasVerseLabel": true,
          "verseText": "The poor man and the oppressor have this in common: The Lord gives light to the eyes of both. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": "The poor man and the oppressor have this in common: The Lord gives light to the eyes of both."
