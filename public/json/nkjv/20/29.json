        },
        {
          "verseNum": 15,
          "hasVerseLabel": true,
          "verseText": "The rod and rebuke give wisdom, But a child left to  himself brings shame to his mother. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": "The rod and rebuke give wisdom, But a child left to  himself brings shame to his mother."
