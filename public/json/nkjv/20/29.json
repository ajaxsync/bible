        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "If a wise man contends with a foolish man, Whether the  fool rages or laughs, there  is no peace. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
