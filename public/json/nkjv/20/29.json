          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "Whoever loves wisdom makes his father rejoice, But a companion of harlots wastes his wealth. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": "Whoever loves wisdom makes his father rejoice, But a companion of harlots wastes his wealth."
