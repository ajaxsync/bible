{
  "book": 25,
  "chapter": 3,
  "sections": [
    {
      "type": "heading",
      "heading": "刑罰、悔改、希望"
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "I am the man who has seen affliction by the rod of His wrath. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "I am the man who has seen affliction by the rod of His wrath."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "He has led me and made me walk In darkness and not in light. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": "He has led me and made me walk In darkness and not in light."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "Surely He has turned His hand against me Time and time again throughout the day. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "He has aged my flesh and my skin, And broken my bones. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "He has aged my flesh and my skin, And broken my bones. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "He has besieged me And surrounded me with bitterness and woe. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "He has besieged me And surrounded me with bitterness and woe. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "He has set me in dark places Like the dead of long ago. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": "He has set me in dark places Like the dead of long ago."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "He has hedged me in so that I cannot get out; He has made my chain heavy. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "He has hedged me in so that I cannot get out; He has made my chain heavy."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "Even when I cry and shout, He shuts out my prayer. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": "Even when I cry and shout, He shuts out my prayer."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "He has blocked my ways with hewn stone; He has made my paths crooked. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "He has blocked my ways with hewn stone; He has made my paths crooked."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "He has  been to me a bear lying in wait, Like a lion in ambush. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "He has  been to me a bear lying in wait, Like a lion in ambush."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 11,
          "hasVerseLabel": true,
          "verseText": "He has turned aside my ways and torn me in pieces; He has made me desolate. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": false,
          "verseText": "He has turned aside my ways and torn me in pieces; He has made me desolate."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 12,
          "hasVerseLabel": true,
          "verseText": "He has bent His bow And set me up as a target for the arrow. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 13,
          "hasVerseLabel": true,
          "verseText": "He has caused the arrows of His quiver To pierce my loins. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 14,
          "hasVerseLabel": true,
          "verseText": "I have become the ridicule of all my people— Their taunting song all the day. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": "I have become the ridicule of all my people— Their taunting song all the day."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 15,
          "hasVerseLabel": true,
          "verseText": "He has filled me with bitterness, He has made me drink wormwood. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 16,
          "hasVerseLabel": true,
          "verseText": "He has also broken my teeth with gravel, And covered me with ashes. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 16,
          "hasVerseLabel": false,
          "verseText": "He has also broken my teeth with gravel, And covered me with ashes."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 16,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 17,
          "hasVerseLabel": true,
          "verseText": "You have moved my soul far from peace; I have forgotten prosperity. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 17,
          "hasVerseLabel": false,
          "verseText": "You have moved my soul far from peace; I have forgotten prosperity."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 17,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 18,
          "hasVerseLabel": true,
          "verseText": "And I said, “My strength and my hope Have perished from the Lord.” "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 18,
          "hasVerseLabel": false,
          "verseText": "And I said, “My strength and my hope Have perished from the Lord.”"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 18,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 19,
          "hasVerseLabel": true,
          "verseText": "Remember my affliction and roaming, The wormwood and the gall. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 19,
          "hasVerseLabel": false,
          "verseText": "Remember my affliction and roaming, The wormwood and the gall."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 19,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 20,
          "hasVerseLabel": true,
          "verseText": "My soul still remembers And sinks within me. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 20,
          "hasVerseLabel": false,
          "verseText": "My soul still remembers And sinks within me."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 20,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 21,
          "hasVerseLabel": true,
          "verseText": "This I recall to my mind, Therefore I have hope. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 21,
          "hasVerseLabel": false,
          "verseText": "This I recall to my mind, Therefore I have hope."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 21,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 22,
          "hasVerseLabel": true,
          "verseText": "Through the Lord’s mercies we are not consumed, Because His compassions fail not. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 22,
          "hasVerseLabel": false,
          "verseText": "Through the Lord’s mercies we are not consumed, Because His compassions fail not."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 22,
          "hasVerseLabel": false,
          "verseText": "Through the Lord’s mercies we are not consumed, Because His compassions fail not."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 22,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 23,
          "hasVerseLabel": true,
          "verseText": "They  are new every morning; Great is Your faithfulness. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 23,
          "hasVerseLabel": false,
          "verseText": "They  are new every morning; Great is Your faithfulness."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 23,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 24,
          "hasVerseLabel": true,
          "verseText": "“The Lord  is my portion,” says my soul, “Therefore I hope in Him!” "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 24,
          "hasVerseLabel": false,
          "verseText": "“The Lord  is my portion,” says my soul, “Therefore I hope in Him!”"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 24,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 25,
          "hasVerseLabel": true,
          "verseText": "The Lord  is good to those who wait for Him, To the soul who seeks Him. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 25,
          "hasVerseLabel": false,
          "verseText": "The Lord  is good to those who wait for Him, To the soul who seeks Him."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 25,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 26,
          "hasVerseLabel": true,
          "verseText": "It  is good that one should hope and wait quietly For the salvation of the Lord. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 26,
          "hasVerseLabel": false,
          "verseText": "It  is good that one should hope and wait quietly For the salvation of the Lord."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 26,
          "hasVerseLabel": false,
          "verseText": "It  is good that one should hope and wait quietly For the salvation of the Lord."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 26,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 27,
          "hasVerseLabel": true,
          "verseText": "It  is good for a man to bear The yoke in his youth. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 27,
          "hasVerseLabel": false,
          "verseText": "It  is good for a man to bear The yoke in his youth."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 27,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 28,
          "hasVerseLabel": true,
          "verseText": "Let him sit alone and keep silent, Because God has laid it on him; "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 28,
          "hasVerseLabel": false,
          "verseText": "Let him sit alone and keep silent, Because God has laid it on him;"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 28,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 29,
          "hasVerseLabel": true,
          "verseText": "Let him put his mouth in the dust— There may yet be hope. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 29,
          "hasVerseLabel": false,
          "verseText": "Let him put his mouth in the dust— There may yet be hope."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 29,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 30,
          "hasVerseLabel": true,
          "verseText": "Let him give his cheek to the one who strikes him, And be full of reproach. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 30,
          "hasVerseLabel": false,
          "verseText": "Let him give his cheek to the one who strikes him, And be full of reproach."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 30,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 31,
          "hasVerseLabel": true,
          "verseText": "For the Lord will not cast off forever. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 31,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 32,
          "hasVerseLabel": true,
          "verseText": "Though He causes grief, Yet He will show compassion According to the multitude of His mercies. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 32,
          "hasVerseLabel": false,
          "verseText": "Though He causes grief, Yet He will show compassion According to the multitude of His mercies."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 32,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 33,
          "hasVerseLabel": true,
          "verseText": "For He does not afflict willingly, Nor grieve the children of men. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 33,
          "hasVerseLabel": false,
          "verseText": "For He does not afflict willingly, Nor grieve the children of men."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 33,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 34,
          "hasVerseLabel": true,
          "verseText": "To crush under one’s feet All the prisoners of the earth, "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 34,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 35,
          "hasVerseLabel": true,
          "verseText": "To turn aside the justice due a man Before the face of the Most High, "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 35,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 36,
          "hasVerseLabel": true,
          "verseText": "Or subvert a man in his cause— The Lord does not approve. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 36,
          "hasVerseLabel": false,
          "verseText": "Or subvert a man in his cause— The Lord does not approve."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 36,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 37,
          "hasVerseLabel": true,
          "verseText": "Who is he who speaks and it comes to pass, When the Lord has not commanded it? "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 37,
          "hasVerseLabel": false,
          "verseText": "Who is he who speaks and it comes to pass, When the Lord has not commanded it?"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 37,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 38,
          "hasVerseLabel": true,
          "verseText": "Is  it not from the mouth of the Most High That woe and well-being proceed? "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 38,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 39,
          "hasVerseLabel": true,
          "verseText": "Why should a living man complain, A man for the punishment of his sins? "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 39,
          "hasVerseLabel": false,
          "verseText": "Why should a living man complain, A man for the punishment of his sins?"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 39,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 40,
          "hasVerseLabel": true,
          "verseText": "Let us search out and examine our ways, And turn back to the Lord; "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 40,
          "hasVerseLabel": false,
          "verseText": "Let us search out and examine our ways, And turn back to the Lord;"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 40,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 41,
          "hasVerseLabel": true,
          "verseText": "Let us lift our hearts and hands To God in heaven. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 41,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 42,
          "hasVerseLabel": true,
          "verseText": "We have transgressed and rebelled; You have not pardoned. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 42,
          "hasVerseLabel": false,
          "verseText": "We have transgressed and rebelled; You have not pardoned."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 42,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 43,
          "hasVerseLabel": true,
          "verseText": "You have covered Yourself with anger And pursued us; You have slain and not pitied. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 43,
          "hasVerseLabel": false,
          "verseText": "You have covered Yourself with anger And pursued us; You have slain and not pitied."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 43,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 44,
          "hasVerseLabel": true,
          "verseText": "You have covered Yourself with a cloud, That prayer should not pass through. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 44,
          "hasVerseLabel": false,
          "verseText": "You have covered Yourself with a cloud, That prayer should not pass through."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 44,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 45,
          "hasVerseLabel": true,
          "verseText": "You have made us an offscouring and refuse In the midst of the peoples. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 45,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 46,
          "hasVerseLabel": true,
          "verseText": "All our enemies Have opened their mouths against us. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 46,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 47,
          "hasVerseLabel": true,
          "verseText": "Fear and a snare have come upon us, Desolation and destruction. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 47,
          "hasVerseLabel": false,
          "verseText": "Fear and a snare have come upon us, Desolation and destruction."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 47,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 48,
          "hasVerseLabel": true,
          "verseText": "My eyes overflow with rivers of water For the destruction of the daughter of my people. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 48,
          "hasVerseLabel": false,
          "verseText": "My eyes overflow with rivers of water For the destruction of the daughter of my people."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 48,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 49,
          "hasVerseLabel": true,
          "verseText": "My eyes flow and do not cease, Without interruption, "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 49,
          "hasVerseLabel": false,
          "verseText": "My eyes flow and do not cease, Without interruption,"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 49,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 50,
          "hasVerseLabel": true,
          "verseText": "Till the Lord from heaven Looks down and sees. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 50,
          "hasVerseLabel": false,
          "verseText": "Till the Lord from heaven Looks down and sees."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 50,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 51,
          "hasVerseLabel": true,
          "verseText": "My eyes bring suffering to my soul Because of all the daughters of my city. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 51,
          "hasVerseLabel": false,
          "verseText": "My eyes bring suffering to my soul Because of all the daughters of my city."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 51,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 52,
          "hasVerseLabel": true,
          "verseText": "My enemies without cause Hunted me down like a bird. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 52,
          "hasVerseLabel": false,
          "verseText": "My enemies without cause Hunted me down like a bird."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 52,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 53,
          "hasVerseLabel": true,
          "verseText": "They silenced my life in the pit And threw stones at me. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 53,
          "hasVerseLabel": false,
          "verseText": "They silenced my life in the pit And threw stones at me."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 53,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 54,
          "hasVerseLabel": true,
          "verseText": "The waters flowed over my head; I said, “I am cut off!” "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 54,
          "hasVerseLabel": false,
          "verseText": "The waters flowed over my head; I said, “I am cut off!”"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 54,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 55,
          "hasVerseLabel": true,
          "verseText": "I called on Your name, O Lord, From the lowest pit. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 55,
          "hasVerseLabel": false,
          "verseText": "I called on Your name, O Lord, From the lowest pit."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 55,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 56,
          "hasVerseLabel": true,
          "verseText": "You have heard my voice: “Do not hide Your ear From my sighing, from my cry for help.” "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 56,
          "hasVerseLabel": false,
          "verseText": "You have heard my voice: “Do not hide Your ear From my sighing, from my cry for help.”"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 56,
          "hasVerseLabel": false,
          "verseText": "You have heard my voice: “Do not hide Your ear From my sighing, from my cry for help.”"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 56,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 57,
          "hasVerseLabel": true,
          "verseText": "You drew near on the day I called on You, And said, “Do not fear!” "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 57,
          "hasVerseLabel": false,
          "verseText": "You drew near on the day I called on You, And said, “Do not fear!”"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 57,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 58,
          "hasVerseLabel": true,
          "verseText": "O Lord, You have pleaded the case for my soul; You have redeemed my life. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 58,
          "hasVerseLabel": false,
          "verseText": "O Lord, You have pleaded the case for my soul; You have redeemed my life."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 58,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 59,
          "hasVerseLabel": true,
          "verseText": "O Lord, You have seen how I am wronged; Judge my case. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 59,
          "hasVerseLabel": false,
          "verseText": "O Lord, You have seen how I am wronged; Judge my case."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 59,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 60,
          "hasVerseLabel": true,
          "verseText": "You have seen all their vengeance, All their schemes against me. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 60,
          "hasVerseLabel": false,
          "verseText": "You have seen all their vengeance, All their schemes against me."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 60,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 61,
          "hasVerseLabel": true,
          "verseText": "You have heard their reproach, O Lord, All their schemes against me, "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 61,
          "hasVerseLabel": false,
          "verseText": "You have heard their reproach, O Lord, All their schemes against me,"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 61,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 62,
          "hasVerseLabel": true,
          "verseText": "The lips of my enemies And their whispering against me all the day. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 62,
          "hasVerseLabel": false,
          "verseText": "The lips of my enemies And their whispering against me all the day."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 62,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 63,
          "hasVerseLabel": true,
          "verseText": "Look at their sitting down and their rising up; I am their taunting song. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 63,
          "hasVerseLabel": false,
          "verseText": "Look at their sitting down and their rising up; I am their taunting song."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 63,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 64,
          "hasVerseLabel": true,
          "verseText": "Repay them, O Lord, According to the work of their hands. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 64,
          "hasVerseLabel": false,
          "verseText": "Repay them, O Lord, According to the work of their hands."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 64,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 65,
          "hasVerseLabel": true,
          "verseText": "Give them a veiled heart; Your curse be upon them! "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 65,
          "hasVerseLabel": false,
          "verseText": "Give them a veiled heart; Your curse be upon them!"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 65,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 66,
          "hasVerseLabel": true,
          "verseText": "In Your anger, Pursue and destroy them From under the heavens of the Lord. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 66,
          "hasVerseLabel": false,
          "verseText": "In Your anger, Pursue and destroy them From under the heavens of the Lord."
        }
      ]
    }
  ]
