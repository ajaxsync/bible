          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 33,
          "hasVerseLabel": true,
          "verseText": "God is my strong fortress, and he makes my way perfect. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
