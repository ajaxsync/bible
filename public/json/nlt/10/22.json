    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 31,
          "hasVerseLabel": false,
          "verseText": "“God’s way is perfect. All the Lord’s promises prove true. He is a shield for all who look to him for protection."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 31,
