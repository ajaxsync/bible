    {
      "type": "paragraph",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "David sang this song to the Lord on the day the Lord rescued him from all his enemies and from Saul. "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "He sang: “The Lord is my rock, my fortress, and my savior; "
        }
      ]
    },
    {
