      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 13,
          "hasVerseLabel": true,
          "verseText": "“‘Yet your real motive— your true intent— "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": "“‘Yet your real motive— your true intent—"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 14,
          "hasVerseLabel": true,
          "verseText": "was to watch me, and if I sinned, you would not forgive my guilt. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": "was to watch me, and if I sinned, you would not forgive my guilt."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 15,
          "hasVerseLabel": true,
          "verseText": "If I am guilty, too bad for me; and even if I’m innocent, I can’t hold my head high, because I am filled with shame and misery. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": "If I am guilty, too bad for me; and even if I’m innocent, I can’t hold my head high, because I am filled with shame and misery."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": "If I am guilty, too bad for me; and even if I’m innocent, I can’t hold my head high, because I am filled with shame and misery."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": "If I am guilty, too bad for me; and even if I’m innocent, I can’t hold my head high, because I am filled with shame and misery."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
