          "verseNum": 17,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 18,
          "hasVerseLabel": true,
          "verseText": "“‘Why, then, did you deliver me from my mother’s womb? Why didn’t you let me die at birth? "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 18,
          "hasVerseLabel": false,
          "verseText": "“‘Why, then, did you deliver me from my mother’s womb? Why didn’t you let me die at birth?"
        }
