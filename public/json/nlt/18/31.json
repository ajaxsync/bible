      "type": "line-quote",
      "contents": [
        {
          "verseNum": 34,
          "hasVerseLabel": false,
          "verseText": "Have I feared the crowd or the contempt of the masses, so that I kept quiet and stayed indoors?"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 34,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 35,
          "hasVerseLabel": true,
          "verseText": "“If only someone would listen to me! Look, I will sign my name to my defense. Let the Almighty answer me. Let my accuser write out the charges against me. "
        }
