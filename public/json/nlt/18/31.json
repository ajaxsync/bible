          "verseText": " "
        },
        {
          "verseNum": 13,
          "hasVerseLabel": true,
          "verseText": "“If I have been unfair to my male or female servants when they brought their complaints to me, "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": "“If I have been unfair to my male or female servants when they brought their complaints to me,"
