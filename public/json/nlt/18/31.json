          "verseNum": 36,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 37,
          "hasVerseLabel": true,
          "verseText": "For I would tell him exactly what I have done. I would come before him like a prince. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 37,
          "hasVerseLabel": false,
          "verseText": "For I would tell him exactly what I have done. I would come before him like a prince."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 37,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 38,
          "hasVerseLabel": true,
          "verseText": "“If my land accuses me and all its furrows cry out together, "
        }
