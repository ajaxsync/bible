    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 35,
          "hasVerseLabel": false,
          "verseText": "“If only someone would listen to me! Look, I will sign my name to my defense. Let the Almighty answer me. Let my accuser write out the charges against me."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 35,
          "hasVerseLabel": false,
          "verseText": "“If only someone would listen to me! Look, I will sign my name to my defense. Let the Almighty answer me. Let my accuser write out the charges against me."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 35,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 36,
          "hasVerseLabel": true,
          "verseText": "I would face the accusation proudly. I would wear it like a crown. "
        }
      ]
    },
