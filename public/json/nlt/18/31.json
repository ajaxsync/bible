      "contents": [
        {
          "verseNum": 21,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 22,
          "hasVerseLabel": true,
          "verseText": "then let my shoulder be wrenched out of place! Let my arm be torn from its socket! "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 22,
          "hasVerseLabel": false,
          "verseText": "then let my shoulder be wrenched out of place! Let my arm be torn from its socket!"
        }
      ]
    },
