      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": "“Have I lied to anyone or deceived anyone?"
        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "Let God weigh me on the scales of justice, for he knows my integrity. "
        }
      ]
    },
    {
