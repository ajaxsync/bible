    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 33,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 34,
          "hasVerseLabel": true,
          "verseText": "Have I feared the crowd or the contempt of the masses, so that I kept quiet and stayed indoors? "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 34,
          "hasVerseLabel": false,
          "verseText": "Have I feared the crowd or the contempt of the masses, so that I kept quiet and stayed indoors?"
        }
