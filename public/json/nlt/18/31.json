      "contents": [
        {
          "verseNum": 28,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 29,
          "hasVerseLabel": true,
          "verseText": "“Have I ever rejoiced when disaster struck my enemies, or become excited when harm came their way? "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 29,
          "hasVerseLabel": false,
          "verseText": "“Have I ever rejoiced when disaster struck my enemies, or become excited when harm came their way?"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 29,
          "hasVerseLabel": false,
          "verseText": "“Have I ever rejoiced when disaster struck my enemies, or become excited when harm came their way?"
        },
        {
          "verseNum": 30,
          "hasVerseLabel": true,
          "verseText": "No, I have never sinned by cursing anyone or by asking for revenge. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 30,
          "hasVerseLabel": false,
          "verseText": "No, I have never sinned by cursing anyone or by asking for revenge."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 30,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 31,
          "hasVerseLabel": true,
          "verseText": "“My servants have never said, ‘He let others go hungry.’ "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 31,
          "hasVerseLabel": false,
          "verseText": "“My servants have never said, ‘He let others go hungry.’"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 31,
          "hasVerseLabel": false,
          "verseText": "“My servants have never said, ‘He let others go hungry.’"
        },
        {
          "verseNum": 32,
          "hasVerseLabel": true,
          "verseText": "I have never turned away a stranger but have opened my doors to everyone. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 32,
          "hasVerseLabel": false,
          "verseText": "I have never turned away a stranger but have opened my doors to everyone."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 32,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 33,
          "hasVerseLabel": true,
          "verseText": "“Have I tried to hide my sins like other people do, concealing my guilt in my heart? "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 33,
          "hasVerseLabel": false,
          "verseText": "“Have I tried to hide my sins like other people do, concealing my guilt in my heart?"
        }
