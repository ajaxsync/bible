      "contents": [
        {
          "verseNum": 20,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 21,
          "hasVerseLabel": true,
          "verseText": "“If I raised my hand against an orphan, knowing the judges would take my side, "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 21,
          "hasVerseLabel": false,
          "verseText": "“If I raised my hand against an orphan, knowing the judges would take my side,"
        }
      ]
    },
    {
