          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "If I have strayed from his pathway, or if my heart has lusted for what my eyes have seen, or if I am guilty of any other sin, "
        }
