          "verseNum": 27,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 28,
          "hasVerseLabel": true,
          "verseText": "When you supply it, they gather it. You open your hand to feed them, and they are richly satisfied. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 28,
          "hasVerseLabel": false,
          "verseText": "When you supply it, they gather it. You open your hand to feed them, and they are richly satisfied."
