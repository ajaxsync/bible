          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "God has promised this by his holiness: “I will divide up Shechem with joy. I will measure out the valley of Succoth. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "God has promised this by his holiness: “I will divide up Shechem with joy. I will measure out the valley of Succoth."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "God has promised this by his holiness: “I will divide up Shechem with joy. I will measure out the valley of Succoth."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "Gilead is mine, and Manasseh, too. Ephraim, my helmet, will produce my warriors, and Judah, my scepter, will produce my kings. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": "Gilead is mine, and Manasseh, too. Ephraim, my helmet, will produce my warriors, and Judah, my scepter, will produce my kings."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": "Gilead is mine, and Manasseh, too. Ephraim, my helmet, will produce my warriors, and Judah, my scepter, will produce my kings."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": "Gilead is mine, and Manasseh, too. Ephraim, my helmet, will produce my warriors, and Judah, my scepter, will produce my kings."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
