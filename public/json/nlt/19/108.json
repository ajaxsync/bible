          "verseText": " "
        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "Be exalted, O God, above the highest heavens. May your glory shine over all the earth. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": "Be exalted, O God, above the highest heavens. May your glory shine over all the earth."
