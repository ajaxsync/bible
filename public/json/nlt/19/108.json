          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "But Moab, my washbasin, will become my servant, and I will wipe my feet on Edom and shout in triumph over Philistia.” "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "But Moab, my washbasin, will become my servant, and I will wipe my feet on Edom and shout in triumph over Philistia.”"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "But Moab, my washbasin, will become my servant, and I will wipe my feet on Edom and shout in triumph over Philistia.”"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "Who will bring me into the fortified city? Who will bring me victory over Edom? "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "Who will bring me into the fortified city? Who will bring me victory over Edom?"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 11,
          "hasVerseLabel": true,
          "verseText": "Have you rejected us, O God? Will you no longer march with our armies? "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": false,
          "verseText": "Have you rejected us, O God? Will you no longer march with our armies?"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
