          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "For your unfailing love is higher than the heavens. Your faithfulness reaches to the clouds. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": "For your unfailing love is higher than the heavens. Your faithfulness reaches to the clouds."
