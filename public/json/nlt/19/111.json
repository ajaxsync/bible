          "verseText": " "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "How amazing are the deeds of the Lord! All who delight in him should ponder them. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": "How amazing are the deeds of the Lord! All who delight in him should ponder them."
