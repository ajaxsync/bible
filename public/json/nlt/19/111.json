          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "He gives food to those who fear him; he always remembers his covenant. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
