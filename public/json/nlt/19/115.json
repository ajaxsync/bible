  "sections": [
    {
      "type": "heading",
      "heading": "獨一真神"
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "Not to us, O Lord, not to us, but to your name goes all the glory for your unfailing love and faithfulness. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "Not to us, O Lord, not to us, but to your name goes all the glory for your unfailing love and faithfulness."
        }
      ]
    },
    {
