        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "The Lord keeps watch over you as you come and go, both now and forever. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
