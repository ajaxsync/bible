        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "You will enjoy the fruit of your labor. How joyful and prosperous you will be! "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": "You will enjoy the fruit of your labor. How joyful and prosperous you will be!"
