          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "And may those who pass by refuse to give them this blessing: “The Lord bless you; we bless you in the Lord’s name.” "
        }
