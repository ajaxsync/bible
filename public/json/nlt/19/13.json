        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "Turn and answer me, O Lord my God! Restore the sparkle to my eyes, or I will die. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
