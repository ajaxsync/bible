      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "From the depths of despair, O Lord, I call for your help. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "Hear my cry, O Lord. Pay attention to my prayer. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": "Hear my cry, O Lord. Pay attention to my prayer."
