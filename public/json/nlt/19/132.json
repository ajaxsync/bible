          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "May your priests be clothed in godliness; may your loyal servants sing for joy. "
        }
      ]
    },
    {
