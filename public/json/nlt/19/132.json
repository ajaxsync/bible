          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 14,
          "hasVerseLabel": true,
          "verseText": "“This is my resting place forever,” he said. “I will live here, for this is the home I desired. "
        }
      ]
    },
    {
