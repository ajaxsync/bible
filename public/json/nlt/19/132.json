          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "We heard that the Ark was in Ephrathah; then we found it in the distant countryside of Jaar. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": "We heard that the Ark was in Ephrathah; then we found it in the distant countryside of Jaar."
