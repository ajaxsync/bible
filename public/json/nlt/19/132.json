          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "until I find a place to build a house for the Lord, a sanctuary for the Mighty One of Israel.” "
        }
      ]
    },
    {
