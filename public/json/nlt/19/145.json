          "verseNum": 17,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 18,
          "hasVerseLabel": true,
          "verseText": "The Lord is close to all who call on him, yes, to all who call on him in truth. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 18,
          "hasVerseLabel": false,
          "verseText": "The Lord is close to all who call on him, yes, to all who call on him in truth."
