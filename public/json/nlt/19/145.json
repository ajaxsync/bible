          "verseNum": 16,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 17,
          "hasVerseLabel": true,
          "verseText": "The Lord is righteous in everything he does; he is filled with kindness. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 17,
          "hasVerseLabel": false,
          "verseText": "The Lord is righteous in everything he does; he is filled with kindness."
