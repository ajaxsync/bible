      "heading": "讚美的聖詩"
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "Praise the Lord! Sing to the Lord a new song. Sing his praises in the assembly of the faithful. "
