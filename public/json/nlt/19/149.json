          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "to bind their kings with shackles and their leaders with iron chains, "
        }
      ]
    },
    {
