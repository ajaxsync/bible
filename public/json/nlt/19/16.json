    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "Troubles multiply for those who chase after other gods. I will not take part in their sacrifices of blood or even speak the names of their gods. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": "Troubles multiply for those who chase after other gods. I will not take part in their sacrifices of blood or even speak the names of their gods."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": "Troubles multiply for those who chase after other gods. I will not take part in their sacrifices of blood or even speak the names of their gods."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": "Troubles multiply for those who chase after other gods. I will not take part in their sacrifices of blood or even speak the names of their gods."
        }
