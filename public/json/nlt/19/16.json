  "sections": [
    {
      "type": "heading",
      "heading": "為信心穩固而祈禱"
    },
    {
      "type": "desc",
      "contents": []
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "Keep me safe, O God, for I have come to you for refuge. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "Keep me safe, O God, for I have come to you for refuge."
