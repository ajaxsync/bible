      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 13,
          "hasVerseLabel": true,
          "verseText": "The Lord thundered from heaven; the voice of the Most High resounded amid the hail and burning coals. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": "The Lord thundered from heaven; the voice of the Most High resounded amid the hail and burning coals."
