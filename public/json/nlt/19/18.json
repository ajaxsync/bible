          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 15,
          "hasVerseLabel": true,
          "verseText": "Then at your command, O Lord, at the blast of your breath, the bottom of the sea could be seen, and the foundations of the earth were laid bare. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": "Then at your command, O Lord, at the blast of your breath, the bottom of the sea could be seen, and the foundations of the earth were laid bare."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": "Then at your command, O Lord, at the blast of your breath, the bottom of the sea could be seen, and the foundations of the earth were laid bare."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": "Then at your command, O Lord, at the blast of your breath, the bottom of the sea could be seen, and the foundations of the earth were laid bare."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 16,
          "hasVerseLabel": true,
          "verseText": "He reached down from heaven and rescued me; he drew me out of deep waters. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 16,
          "hasVerseLabel": false,
          "verseText": "He reached down from heaven and rescued me; he drew me out of deep waters."
