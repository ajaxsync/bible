          "verseNum": 32,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 33,
          "hasVerseLabel": true,
          "verseText": "He makes me as surefooted as a deer, enabling me to stand on mountain heights. "
        }
      ]
    },
