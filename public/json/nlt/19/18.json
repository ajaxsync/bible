          "verseNum": 33,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 34,
          "hasVerseLabel": true,
          "verseText": "He trains my hands for battle; he strengthens my arm to draw a bronze bow. "
