          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "Smoke poured from his nostrils; fierce flames leaped from his mouth. Glowing coals blazed forth from him. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": "Smoke poured from his nostrils; fierce flames leaped from his mouth. Glowing coals blazed forth from him."
