      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "He opened the heavens and came down; dark storm clouds were beneath his feet. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
