{
  "book": 19,
  "chapter": 21,
  "sections": [
    {
      "type": "heading",
      "heading": "為勝利而歌頌"
    },
    {
      "type": "desc",
      "contents": []
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "How the king rejoices in your strength, O Lord! He shouts with joy because you give him victory. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "How the king rejoices in your strength, O Lord! He shouts with joy because you give him victory."
