          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "He asked you to preserve his life, and you granted his request. The days of his life stretch on forever. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": "He asked you to preserve his life, and you granted his request. The days of his life stretch on forever."
