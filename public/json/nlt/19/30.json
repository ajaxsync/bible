    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "I will exalt you, Lord, for you rescued me. You refused to let my enemies triumph over me. "
        }
      ]
    },
    {
