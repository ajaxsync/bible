{
  "book": 19,
  "chapter": 36,
  "sections": [
    {
      "type": "heading",
      "heading": "人的邪惡"
    },
    {
      "type": "desc",
      "contents": []
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "Sin whispers to the wicked, deep within their hearts. They have no fear of God at all. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "Sin whispers to the wicked, deep within their hearts. They have no fear of God at all."
        }
