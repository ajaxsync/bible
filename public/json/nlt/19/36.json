    {
      "type": "heading",
      "heading": "神的良善"
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "Your unfailing love, O Lord, is as vast as the heavens; your faithfulness reaches beyond the clouds. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": "Your unfailing love, O Lord, is as vast as the heavens; your faithfulness reaches beyond the clouds."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "Your righteousness is like the mighty mountains, your justice like the ocean depths. You care for people and animals alike, O Lord. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": "Your righteousness is like the mighty mountains, your justice like the ocean depths. You care for people and animals alike, O Lord."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": "Your righteousness is like the mighty mountains, your justice like the ocean depths. You care for people and animals alike, O Lord."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "How precious is your unfailing love, O God! All humanity finds shelter in the shadow of your wings. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "How precious is your unfailing love, O God! All humanity finds shelter in the shadow of your wings."
