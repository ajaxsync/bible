        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "The nations are in chaos, and their kingdoms crumble! God’s voice thunders, and the earth melts! "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": "The nations are in chaos, and their kingdoms crumble! God’s voice thunders, and the earth melts!"
