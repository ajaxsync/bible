          "verseNum": 20,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 21,
          "hasVerseLabel": true,
          "verseText": "His words are as smooth as butter, but in his heart is war. His words are as soothing as lotion, but underneath are daggers! "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 21,
          "hasVerseLabel": false,
          "verseText": "His words are as smooth as butter, but in his heart is war. His words are as soothing as lotion, but underneath are daggers!"
        }
      ]
    },
