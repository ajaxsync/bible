        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "Break off their fangs, O God! Smash the jaws of these lions, O Lord! "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": "Break off their fangs, O God! Smash the jaws of these lions, O Lord!"
