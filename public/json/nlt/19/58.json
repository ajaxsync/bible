        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "May they be like snails that dissolve into slime, like a stillborn child who will never see the sun. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
