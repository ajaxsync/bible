          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "End the evil of those who are wicked, and defend the righteous. For you look deep within the mind and heart, O righteous God. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "End the evil of those who are wicked, and defend the righteous. For you look deep within the mind and heart, O righteous God."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "End the evil of those who are wicked, and defend the righteous. For you look deep within the mind and heart, O righteous God."
