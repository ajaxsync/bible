{
  "book": 19,
  "chapter": 7,
  "sections": [
    {
      "type": "heading",
      "heading": "為公義而祈禱"
    },
    {
      "type": "desc",
      "contents": []
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "I come to you for protection, O Lord my God. Save me from my persecutors—rescue me! "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "I come to you for protection, O Lord my God. Save me from my persecutors—rescue me!"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "If you don’t, they will maul me like a lion, tearing me to pieces with no one to rescue me. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 2,
          "hasVerseLabel": false,
          "verseText": "If you don’t, they will maul me like a lion, tearing me to pieces with no one to rescue me."
