          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "Arise, O Lord, in anger! Stand up against the fury of my enemies! Wake up, my God, and bring justice! "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": "Arise, O Lord, in anger! Stand up against the fury of my enemies! Wake up, my God, and bring justice!"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": "Arise, O Lord, in anger! Stand up against the fury of my enemies! Wake up, my God, and bring justice!"
        }
      ]
    },
