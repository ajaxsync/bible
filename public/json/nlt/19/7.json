          "verseText": " "
        },
        {
          "verseNum": 14,
          "hasVerseLabel": true,
          "verseText": "The wicked conceive evil; they are pregnant with trouble and give birth to lies. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": "The wicked conceive evil; they are pregnant with trouble and give birth to lies."
