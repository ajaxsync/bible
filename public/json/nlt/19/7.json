          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "The Lord judges the nations. Declare me righteous, O Lord, for I am innocent, O Most High! "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
          "verseText": "The Lord judges the nations. Declare me righteous, O Lord, for I am innocent, O Most High!"
        }
      ]
    },
