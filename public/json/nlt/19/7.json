          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 13,
          "hasVerseLabel": true,
          "verseText": "He will prepare his deadly weapons and shoot his flaming arrows. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
