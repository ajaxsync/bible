          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 11,
          "hasVerseLabel": true,
          "verseText": "Make vows to the Lord your God, and keep them. Let everyone bring tribute to the Awesome One. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": false,
          "verseText": "Make vows to the Lord your God, and keep them. Let everyone bring tribute to the Awesome One."
        }
