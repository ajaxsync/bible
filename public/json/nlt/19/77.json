          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 15,
          "hasVerseLabel": true,
          "verseText": "By your strong arm, you redeemed your people, the descendants of Jacob and Joseph. Interlude "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": "By your strong arm, you redeemed your people, the descendants of Jacob and Joseph. Interlude"
