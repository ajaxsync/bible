      "contents": [
        {
          "verseNum": 58,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 59,
          "hasVerseLabel": true,
          "verseText": "When God heard them, he was very angry, and he completely rejected Israel. "
        }
      ]
    },
