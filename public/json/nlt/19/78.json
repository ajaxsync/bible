        {
          "verseNum": 52,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 53,
          "hasVerseLabel": true,
          "verseText": "He kept them safe so they were not afraid; but the sea covered their enemies. "
        }
