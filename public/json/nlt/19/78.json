        {
          "verseNum": 64,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 65,
          "hasVerseLabel": true,
          "verseText": "Then the Lord rose up as though waking from sleep, like a warrior aroused from a drunken stupor. "
        }
