        {
          "verseNum": 59,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 60,
          "hasVerseLabel": true,
          "verseText": "Then he abandoned his dwelling at Shiloh, the Tabernacle where he had lived among the people. "
        }
