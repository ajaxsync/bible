        {
          "verseNum": 63,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 64,
          "hasVerseLabel": true,
          "verseText": "Their priests were slaughtered, and their widows could not mourn their deaths. "
