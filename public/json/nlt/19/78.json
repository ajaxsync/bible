          "verseNum": 36,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 37,
          "hasVerseLabel": true,
          "verseText": "Their hearts were not loyal to him. They did not keep his covenant. "
        }
