          "verseNum": 62,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 63,
          "hasVerseLabel": true,
          "verseText": "Their young men were killed by fire; their young women died before singing their wedding songs. "
        }
