          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 45,
          "hasVerseLabel": true,
          "verseText": "He sent vast swarms of flies to consume them and hordes of frogs to ruin them. "
        }
      ]
    },
