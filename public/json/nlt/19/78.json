          "verseNum": 60,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 61,
          "hasVerseLabel": true,
          "verseText": "He allowed the Ark of his might to be captured; he surrendered his glory into enemy hands. "
        }
