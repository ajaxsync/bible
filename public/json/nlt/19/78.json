      "contents": [
        {
          "verseNum": 65,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 66,
          "hasVerseLabel": true,
          "verseText": "He routed his enemies and sent them to eternal shame. "
        }
      ]
