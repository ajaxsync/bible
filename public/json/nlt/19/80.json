          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 19,
          "hasVerseLabel": true,
          "verseText": "Turn us again to yourself, O Lord God of Heaven’s Armies. Make your face shine down upon us. Only then will we be saved. "
        }
      ]
    },
