    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "I will sing of the Lord’s unfailing love forever! Young and old will hear of your faithfulness. "
        }
      ]
