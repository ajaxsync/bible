        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "The Lord said, “I have made a covenant with David, my chosen servant. I have sworn this oath to him: "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": "The Lord said, “I have made a covenant with David, my chosen servant. I have sworn this oath to him:"
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "‘I will establish your descendants as kings forever; they will sit on your throne from now until eternity.’” Interlude "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": "‘I will establish your descendants as kings forever; they will sit on your throne from now until eternity.’” Interlude"
