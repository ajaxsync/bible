          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 17,
          "hasVerseLabel": true,
          "verseText": "The wicked will go down to the grave. This is the fate of all the nations who ignore God. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 17,
          "hasVerseLabel": false,
          "verseText": "The wicked will go down to the grave. This is the fate of all the nations who ignore God."
        }
      ]
