          "verseNum": 17,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 18,
          "hasVerseLabel": true,
          "verseText": "But the needy will not be ignored forever; the hopes of the poor will not always be crushed. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 18,
          "hasVerseLabel": false,
          "verseText": "But the needy will not be ignored forever; the hopes of the poor will not always be crushed."
        }
