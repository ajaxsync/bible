        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "Great is the Lord! He is most worthy of praise! He is to be feared above all gods. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
