        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "Publish his glorious deeds among the nations. Tell everyone about the amazing things he does. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
