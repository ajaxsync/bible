        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "You who love the Lord, hate evil! He protects the lives of his godly people and rescues them from the power of the wicked. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "You who love the Lord, hate evil! He protects the lives of his godly people and rescues them from the power of the wicked."
