  "sections": [
    {
      "type": "heading",
      "heading": "神是最高的統治者"
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "The Lord is king! Let the earth rejoice! Let the farthest coastlands be glad. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
