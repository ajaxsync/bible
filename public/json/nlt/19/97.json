        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "Jerusalem has heard and rejoiced, and all the towns of Judah are glad because of your justice, O Lord! "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "Jerusalem has heard and rejoiced, and all the towns of Judah are glad because of your justice, O Lord! "
