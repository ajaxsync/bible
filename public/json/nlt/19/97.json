        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "Those who worship idols are disgraced— all who brag about their worthless gods— for every god must bow to him. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
          "verseText": "Those who worship idols are disgraced— all who brag about their worthless gods— for every god must bow to him."
