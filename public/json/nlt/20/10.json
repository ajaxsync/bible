          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 31,
          "hasVerseLabel": true,
          "verseText": "The mouth of the godly person gives wise advice, but the tongue that deceives will be cut off. "
        }
      ]
    },
