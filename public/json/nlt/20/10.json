          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 32,
          "hasVerseLabel": true,
          "verseText": "The lips of the godly speak helpful words, but the mouth of the wicked speaks perverse words. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 32,
          "hasVerseLabel": false,
          "verseText": "The lips of the godly speak helpful words, but the mouth of the wicked speaks perverse words."
