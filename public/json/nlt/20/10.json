          "verseNum": 28,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 29,
          "hasVerseLabel": true,
          "verseText": "The way of the Lord is a stronghold to those with integrity, but it destroys the wicked. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
