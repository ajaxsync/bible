          "verseNum": 27,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 28,
          "hasVerseLabel": true,
          "verseText": "The hopes of the godly result in happiness, but the expectations of the wicked come to nothing. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 28,
          "hasVerseLabel": false,
          "verseText": "The hopes of the godly result in happiness, but the expectations of the wicked come to nothing."
        }
