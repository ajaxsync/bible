          "verseNum": 26,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 27,
          "hasVerseLabel": true,
          "verseText": "Fear of the Lord lengthens one’s life, but the years of the wicked are cut short. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 27,
          "hasVerseLabel": false,
          "verseText": "Fear of the Lord lengthens one’s life, but the years of the wicked are cut short."
        }
