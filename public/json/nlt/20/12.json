          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 18,
          "hasVerseLabel": true,
          "verseText": "Some people make cutting remarks, but the words of the wise bring healing. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
