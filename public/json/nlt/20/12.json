        {
          "verseNum": 11,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 12,
          "hasVerseLabel": true,
          "verseText": "Thieves are jealous of each other’s loot, but the godly are well rooted and bear their own fruit. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 12,
          "hasVerseLabel": false,
          "verseText": "Thieves are jealous of each other’s loot, but the godly are well rooted and bear their own fruit."
