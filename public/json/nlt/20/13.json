        },
        {
          "verseNum": 19,
          "hasVerseLabel": true,
          "verseText": "It is pleasant to see dreams come true, but fools refuse to turn from evil to attain them. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 19,
