        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "The godly hate lies; the wicked cause shame and disgrace. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
