        },
        {
          "verseNum": 16,
          "hasVerseLabel": true,
          "verseText": "Wise people think before they act; fools don’t—and even brag about their foolishness. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 16,
          "hasVerseLabel": false,
