        },
        {
          "verseNum": 6,
          "hasVerseLabel": true,
          "verseText": "Godliness guards the path of the blameless, but the evil are misled by sin. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 6,
          "hasVerseLabel": false,
          "verseText": "Godliness guards the path of the blameless, but the evil are misled by sin."
