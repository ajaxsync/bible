        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "The life of the godly is full of light and joy, but the light of the wicked will be snuffed out. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "The life of the godly is full of light and joy, but the light of the wicked will be snuffed out."
