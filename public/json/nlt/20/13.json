        },
        {
          "verseNum": 13,
          "hasVerseLabel": true,
          "verseText": "People who despise advice are asking for trouble; those who respect a command will succeed. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": "People who despise advice are asking for trouble; those who respect a command will succeed."
