    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "A wise child accepts a parent’s discipline; a mocker refuses to listen to correction. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
