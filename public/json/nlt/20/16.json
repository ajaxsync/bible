          "verseNum": 21,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 22,
          "hasVerseLabel": true,
          "verseText": "Discretion is a life-giving fountain to those who possess it, but discipline is wasted on fools. "
        }
