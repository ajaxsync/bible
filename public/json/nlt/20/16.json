          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "The Lord has made everything for his own purposes, even the wicked for a day of disaster. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": "The Lord has made everything for his own purposes, even the wicked for a day of disaster."
        }
      ]
    },
