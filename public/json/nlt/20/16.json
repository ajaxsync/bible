          "verseNum": 19,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 20,
          "hasVerseLabel": true,
          "verseText": "Those who listen to instruction will prosper; those who trust the Lord will be joyful. "
        }
