        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "A wise servant will rule over the master’s disgraceful son and will share the inheritance of the master’s children. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
