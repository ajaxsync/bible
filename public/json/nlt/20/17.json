  "sections": [
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "Better a dry crust eaten in peace than a house filled with feasting—and conflict. "
        }
      ]
    },
    {
