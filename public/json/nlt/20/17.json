        },
        {
          "verseNum": 17,
          "hasVerseLabel": true,
          "verseText": "A friend is always loyal, and a brother is born to help in time of need. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 17,
          "hasVerseLabel": false,
