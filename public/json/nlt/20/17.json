          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 19,
          "hasVerseLabel": true,
          "verseText": "Anyone who loves to quarrel loves sin; anyone who trusts in high walls invites disaster. "
        }
