        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "Those who mock the poor insult their Maker; those who rejoice at the misfortune of others will be punished. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
