        },
        {
          "verseNum": 11,
          "hasVerseLabel": true,
          "verseText": "Evil people are eager for rebellion, but they will be severely punished. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 11,
          "hasVerseLabel": false,
          "verseText": "Evil people are eager for rebellion, but they will be severely punished."
