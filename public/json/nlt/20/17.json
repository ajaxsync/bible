          "verseText": " "
        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "Fire tests the purity of silver and gold, but the Lord tests the heart. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
