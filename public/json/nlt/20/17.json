        },
        {
          "verseNum": 27,
          "hasVerseLabel": true,
          "verseText": "A truly wise person uses few words; a person with understanding is even-tempered. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 27,
          "hasVerseLabel": false,
          "verseText": "A truly wise person uses few words; a person with understanding is even-tempered."
