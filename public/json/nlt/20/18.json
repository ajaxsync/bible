        },
        {
          "verseNum": 19,
          "hasVerseLabel": true,
          "verseText": "An offended friend is harder to win back than a fortified city. Arguments separate friends like a gate locked with bars. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 19,
          "hasVerseLabel": false,
          "verseText": "An offended friend is harder to win back than a fortified city. Arguments separate friends like a gate locked with bars."
