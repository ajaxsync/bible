          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 17,
          "hasVerseLabel": true,
          "verseText": "The first to speak in court sounds right— until the cross-examination begins. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
