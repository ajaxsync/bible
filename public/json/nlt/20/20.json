        },
        {
          "verseNum": 13,
          "hasVerseLabel": true,
          "verseText": "If you love sleep, you will end in poverty. Keep your eyes open, and there will be plenty to eat! "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": "If you love sleep, you will end in poverty. Keep your eyes open, and there will be plenty to eat!"
