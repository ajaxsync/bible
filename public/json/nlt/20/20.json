        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "False weights and unequal measures— the Lord detests double standards of every kind. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "False weights and unequal measures— the Lord detests double standards of every kind."
