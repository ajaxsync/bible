  "sections": [
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": true,
          "verseText": "The king’s heart is like a stream of water directed by the Lord; he guides it wherever he pleases. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 1,
          "hasVerseLabel": false,
          "verseText": "The king’s heart is like a stream of water directed by the Lord; he guides it wherever he pleases."
