          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 2,
          "hasVerseLabel": true,
          "verseText": "People may be right in their own eyes, but the Lord examines their heart. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
