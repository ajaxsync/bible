        },
        {
          "verseNum": 4,
          "hasVerseLabel": true,
          "verseText": "Don’t wear yourself out trying to get rich. Be wise enough to know when to quit. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": "Don’t wear yourself out trying to get rich. Be wise enough to know when to quit."
