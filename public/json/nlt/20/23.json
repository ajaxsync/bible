          "verseNum": 25,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 26,
          "hasVerseLabel": true,
          "verseText": "O my son, give me your heart. May your eyes take delight in following my ways. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 26,
          "hasVerseLabel": false,
          "verseText": "O my son, give me your heart. May your eyes take delight in following my ways."
