          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "Don’t cheat your neighbor by moving the ancient boundary markers; don’t take the land of defenseless orphans. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "Don’t cheat your neighbor by moving the ancient boundary markers; don’t take the land of defenseless orphans."
