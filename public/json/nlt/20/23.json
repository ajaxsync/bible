        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "Don’t waste your breath on fools, for they will despise the wisest advice. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": "Don’t waste your breath on fools, for they will despise the wisest advice."
