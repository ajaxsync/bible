      "type": "line-quote",
      "contents": [
        {
          "verseNum": 29,
          "hasVerseLabel": true,
          "verseText": "Who has anguish? Who has sorrow? Who is always fighting? Who is always complaining? Who has unnecessary bruises? Who has bloodshot eyes? "
        }
      ]
    },
