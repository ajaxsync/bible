          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 27,
          "hasVerseLabel": true,
          "verseText": "A prostitute is a dangerous trap; a promiscuous woman is as dangerous as falling into a narrow well. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 27,
          "hasVerseLabel": false,
          "verseText": "A prostitute is a dangerous trap; a promiscuous woman is as dangerous as falling into a narrow well."
