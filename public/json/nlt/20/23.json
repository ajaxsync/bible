          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 17,
          "hasVerseLabel": true,
          "verseText": "Don’t envy sinners, but always continue to fear the Lord. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 17,
          "hasVerseLabel": false,
          "verseText": "Don’t envy sinners, but always continue to fear the Lord."
