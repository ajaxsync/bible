          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 31,
          "hasVerseLabel": true,
          "verseText": "Don’t gaze at the wine, seeing how red it is, how it sparkles in the cup, how smoothly it goes down. "
        }
      ]
    },
