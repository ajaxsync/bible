          "verseNum": 9,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "If you fail under pressure, your strength is too small. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "If you fail under pressure, your strength is too small."
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
