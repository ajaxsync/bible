      "contents": [
        {
          "verseNum": 21,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 22,
          "hasVerseLabel": true,
          "verseText": "You cannot separate fools from their foolishness, even though you grind them like grain with mortar and pestle. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 22,
          "hasVerseLabel": false,
          "verseText": "You cannot separate fools from their foolishness, even though you grind them like grain with mortar and pestle."
