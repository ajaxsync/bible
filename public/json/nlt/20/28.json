        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "Those who lead good people along an evil path will fall into their own trap, but the honest will inherit good things. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
          "verseText": "Those who lead good people along an evil path will fall into their own trap, but the honest will inherit good things."
