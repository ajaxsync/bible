        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "Income from charging high interest rates will end up in the pocket of someone who is kind to the poor. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
