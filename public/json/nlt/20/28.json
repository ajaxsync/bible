          "verseText": " "
        },
        {
          "verseNum": 14,
          "hasVerseLabel": true,
          "verseText": "Blessed are those who fear to do wrong, but the stubborn are headed for serious trouble. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 14,
          "hasVerseLabel": false,
          "verseText": "Blessed are those who fear to do wrong, but the stubborn are headed for serious trouble."
