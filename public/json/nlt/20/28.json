        },
        {
          "verseNum": 16,
          "hasVerseLabel": true,
          "verseText": "A ruler with no understanding will oppress his people, but one who hates corruption will have a long life. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 16,
          "hasVerseLabel": false,
