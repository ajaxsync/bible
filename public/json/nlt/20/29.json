        },
        {
          "verseNum": 8,
          "hasVerseLabel": true,
          "verseText": "Mockers can get a whole town agitated, but the wise will calm anger. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 8,
          "hasVerseLabel": false,
