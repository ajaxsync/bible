        },
        {
          "verseNum": 10,
          "hasVerseLabel": true,
          "verseText": "The bloodthirsty hate blameless people, but the upright seek to help them. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 10,
          "hasVerseLabel": false,
