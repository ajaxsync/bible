        },
        {
          "verseNum": 9,
          "hasVerseLabel": true,
          "verseText": "If a wise person takes a fool to court, there will be ranting and ridicule but no satisfaction. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 9,
          "hasVerseLabel": false,
