        },
        {
          "verseNum": 7,
          "hasVerseLabel": true,
          "verseText": "The godly care about the rights of the poor; the wicked don’t care at all. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 7,
          "hasVerseLabel": false,
