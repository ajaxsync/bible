        },
        {
          "verseNum": 15,
          "hasVerseLabel": true,
          "verseText": "To discipline a child produces wisdom, but a mother is disgraced by an undisciplined child. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 15,
          "hasVerseLabel": false,
          "verseText": "To discipline a child produces wisdom, but a mother is disgraced by an undisciplined child."
