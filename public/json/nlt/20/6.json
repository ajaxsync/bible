        {
          "verseNum": 4,
          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 5,
          "hasVerseLabel": true,
          "verseText": "Save yourself like a gazelle escaping from a hunter, like a bird fleeing from a net. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 5,
          "hasVerseLabel": false,
          "verseText": "Save yourself like a gazelle escaping from a hunter, like a bird fleeing from a net."
        }
