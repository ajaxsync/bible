          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 13,
          "hasVerseLabel": true,
          "verseText": "signaling their deceit with a wink of the eye, a nudge of the foot, or the wiggle of fingers. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 13,
          "hasVerseLabel": false,
          "verseText": "signaling their deceit with a wink of the eye, a nudge of the foot, or the wiggle of fingers."
        }
