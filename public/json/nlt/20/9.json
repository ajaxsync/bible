          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 3,
          "hasVerseLabel": true,
          "verseText": "She has sent her servants to invite everyone to come. She calls out from the heights overlooking the city. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
        {
          "verseNum": 3,
          "hasVerseLabel": false,
          "verseText": "She has sent her servants to invite everyone to come. She calls out from the heights overlooking the city."
        }
