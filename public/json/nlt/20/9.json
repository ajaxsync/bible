          "hasVerseLabel": false,
          "verseText": " "
        },
        {
          "verseNum": 14,
          "hasVerseLabel": true,
          "verseText": "She sits in her doorway on the heights overlooking the city. "
        }
      ]
    },
    {
      "type": "line-quote",
      "contents": [
